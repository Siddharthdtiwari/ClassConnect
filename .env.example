# Environment Variables — ClassConnect

# Copy this file to `.env` and fill in your values.
# NEVER commit your actual `.env` file to GitHub.

# ── MongoDB ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# ── Cloudinary (file uploads) ─────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_HEADER_URL=https://res.cloudinary.com/your_cloud/image/upload/your_header.jpg

# ── Razorpay (payment gateway) ────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Session ───────────────────────────────────────────────
# Use a long, random string in production (e.g. openssl rand -hex 32)
SESSION_SECRET=change_this_to_a_long_random_secret
