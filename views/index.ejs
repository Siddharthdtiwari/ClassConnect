  <script>
  // MOBILE MENU
  function toggleMobileMenu(){
    document.getElementById('mobile-menu').classList.toggle('active');
    const overlay = document.getElementById('mm-overlay');
    if(overlay) overlay.classList.toggle('active');
  }

  // THEME — key matches background.js and sidebar ('classconnect_theme')
  function setTheme(t,e){if(e)e.stopPropagation();document.documentElement.setAttribute('data-theme',t);localStorage.setItem('classconnect_theme',t);}
  function toggleTheme(){setTheme(document.documentElement.getAttribute('data-theme')==='dark'?'light':'dark');}

  // CURSOR
  const cur=document.getElementById('cur');
  document.addEventListener('mousemove',e=>{cur.style.left=e.clientX+'px';cur.style.top=e.clientY+'px'});
  document.querySelectorAll('a,button,.stacked-container,.theme-pill').forEach(el=>{
    el.addEventListener('mouseenter',()=>cur.classList.add('xl'));
    el.addEventListener('mouseleave',()=>cur.classList.remove('xl'));
  });

  // SCORE BAR ANIMATION
  const bo=new IntersectionObserver(en=>{en.forEach(e=>{if(e.isIntersecting)e.target.querySelectorAll('.bi').forEach((b,i)=>setTimeout(()=>{b.style.width=b.dataset.w+'%'},i*140+200))})},{threshold:.25});
  const sc=document.getElementById('sc-card');if(sc)bo.observe(sc);

  // SCROLL REVEAL
  const io=new IntersectionObserver(en=>{en.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in')})},{threshold:.07});
  document.querySelectorAll('.rv').forEach(el=>io.observe(el));

  // STACKED CARDS
  document.querySelectorAll('.stacked-container').forEach(c=>{
    c.addEventListener('click',()=>{
      Array.from(c.querySelectorAll('.stacked-card')).forEach(card=>{
        const cn=Array.from(card.classList).find(x=>/^c\d+$/.test(x));
        if(cn){const n=parseInt(cn.slice(1)),tot=c.querySelectorAll('.stacked-card').length;card.classList.remove(cn);card.classList.add('c'+(n===1?tot:n-1))}
      });
    });
  });

  // CONTACT AJAX
  const cf=document.getElementById('cf'),msg=document.getElementById('cf-msg'),btn=document.getElementById('cf-btn');
  cf.addEventListener('submit',async e=>{
    e.preventDefault();btn.textContent='Sending…';btn.disabled=true;msg.className='cf-msg';msg.textContent='';
    try{
      const d=new FormData(cf);
      const r=await fetch('/contact',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded','X-CSRF-Token':d.get('_csrf')},body:new URLSearchParams(d)});
      const j=await r.json();
      if(j.ok){msg.className='cf-msg ok';msg.textContent="✓ Sent! We'll reply within 24 hours.";cf.reset()}
      else throw new Error(j.error||'Failed');
    }catch(er){msg.className='cf-msg err';msg.textContent='✗ '+er.message}
    finally{btn.textContent='Submit Inquiry →';btn.disabled=false}
  });
  </script>
