<head>
  <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@300;400;700;900&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/background.css" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: ['class', '[data-theme="dark"]'],
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
            unbounded: ['Unbounded', 'sans-serif'],
            mono: ['Space Mono', 'monospace'],
          },
          colors: {
            theme: {
              bg: 'var(--bg)',
              bg2: 'var(--bg2)',
              bgc: 'var(--bgc)',
              bgch: 'var(--bgch)',
              fg: 'var(--fg)',
              fd: 'var(--fd)',
              fdd: 'var(--fdd)',
              b: 'var(--b)',
              bd: 'var(--bd)',
              pt: 'var(--pt)',
              lt: 'var(--lt)',
              p: 'var(--p)',
              pm: 'var(--pm)'
            }
          }
        }
      }
    }
  </script>
  <script src="/js/background.js" defer></script>
  <script>
    // Global fetch interceptor for CSRF protection
    const originalFetch = window.fetch;
    window.fetch = async function() {
      let [resource, config] = arguments;
      if (config && ['POST', 'PUT', 'DELETE', 'PATCH'].includes(config.method?.toUpperCase())) {
        const token = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
        if (token) {
          config.headers = {
            ...config.headers,
            'x-csrf-token': token
          };
        }
      }
      return originalFetch(resource, config);
    };
  </script>
</head>

<div class="grain"></div>
<div class="orb orb1"></div>
<div class="orb orb2"></div>
<div id="particles-container"></div>