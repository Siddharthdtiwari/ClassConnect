<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Class Content</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body {
      font-family: "Inter", sans-serif;
    }

    .text-brand-purple { color: #5d3a9b; }
    .border-brand-purple { border-color: #5d3a9b; }
    .bg-brand-purple-light { background-color: #f3e8ff; }

    .premium-banner {
      background: linear-gradient(135deg, #4b2d84 0%, #7c52ca 100%);
      color: white;
      box-shadow: 0 10px 25px -5px rgba(93, 58, 155, 0.3);
    }

    .glass-profile {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.5);
      box-shadow: 0 4px 30px rgba(93, 58, 155, 0.08);
    }

    .tab-btn {
      padding: 0.5rem 1.5rem;
      border-radius: 9999px;
      font-weight: 600;
      font-size: 0.875rem;
      border: 2px solid #e5e7eb;
      color: #6b7280;
      background: white;
      transition: all 0.25s ease;
      cursor: pointer;
    }

    .tab-btn:hover {
      border-color: #5d3a9b;
      color: #5d3a9b;
      background: #f3e8ff;
    }

    .tab-btn.active {
      background: #5d3a9b;
      color: white;
      border-color: #5d3a9b;
      box-shadow: 0 4px 14px rgba(93, 58, 155, 0.35);
    }

    .content-card {
      transition: all 0.3s ease;
      border-radius: 12px;
      border: 1px solid #e5e7eb;
      background: white;
    }

    .content-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 24px -5px rgba(93, 58, 155, 0.12);
      border-color: rgba(93, 58, 155, 0.25);
    }

    .btn-download {
      background: #5d3a9b;
      color: white;
      font-weight: 600;
      font-size: 0.8rem;
      padding: 0.45rem 1.1rem;
      border-radius: 9999px;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      transition: all 0.2s ease;
      box-shadow: 0 2px 8px rgba(93, 58, 155, 0.25);
      white-space: nowrap;
    }

    .btn-download:hover {
      background: #4b2d84;
      transform: translateY(-1px);
      box-shadow: 0 4px 14px rgba(93, 58, 155, 0.3);
    }
  </style>
</head>

<%- include('../partials/background') %>

<body class="text-gray-800">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
    <!-- Premium Banner Header -->
    <header class="mb-10 premium-banner rounded-2xl p-6 sm:p-12 text-center relative overflow-hidden">
      <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-white opacity-10"></div>
      <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-48 h-48 rounded-full bg-white opacity-5"></div>
      <div class="relative z-10">
        <div class="flex justify-center sm:justify-start mb-5">
          <a href="/student/dashboard" class="inline-flex items-center text-sm font-bold text-white py-2 px-4 rounded-full shadow-sm transition-all" style="border: 1px solid rgba(255,255,255,0.4); background: rgba(255,255,255,0.12);" onmouseover="this.style.background='white';this.style.color='#5d3a9b';" onmouseout="this.style.background='rgba(255,255,255,0.12)';this.style.color='white';">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Back to Dashboard
          </a>
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight mb-2 tracking-tight">
          📚 Study Materials
        </h1>
        <p class="text-purple-100 font-medium text-base sm:text-lg">Browse textbooks, notes, and question papers.</p>
      </div>
    </header>

    <!-- Glass Container -->
    <div class="glass-profile p-6 sm:p-8 rounded-2xl mb-10">
      <!-- Tab Buttons -->
      <div class="mb-8">
        <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3">Filter by Type</p>
        <div id="subject-tabs" class="flex flex-wrap gap-3">
          <button class="tab-btn active" data-subject="textbook">📖 Textbooks</button>
          <button class="tab-btn" data-subject="notes">📝 Notes</button>
          <button class="tab-btn" data-subject="questionPaper">📄 Question Papers</button>
        </div>
      </div>

      <div id="content-area"></div>
    </div>
  </div>

  <div id="materials-data" data-materials='<%- JSON.stringify(materials || []) %>'></div>
  <div id="tests-data" data-tests='<%- JSON.stringify(tests || []) %>'></div>

  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const subjectTabsContainer = document.getElementById("subject-tabs");
      const contentArea = document.getElementById("content-area");
      const materials = JSON.parse(
        document.getElementById("materials-data").dataset.materials || "[]"
      );
      const tests = JSON.parse(
        document.getElementById("tests-data").dataset.tests || "[]"
      );
      const contentData = {
        textbook: {
          title: "Textbooks",
          items: []
        },
        notes: {
          title: "Notes",
          items: []
        },
        questionPaper: {
          title: "Question Papers",
          items: []
        },
      };

      (materials || []).forEach((mat) => {
        if (!mat.subject || !mat.materialType) return;
        const key = mat.materialType;
        if (!contentData[key]) return;
        contentData[key].items.push({
          id: mat._id,
          type: mat.materialType,
          subject: mat.subject,
          topic: mat.description || "",
          filePath: mat.filePath,
        });
      });

      (tests || []).forEach((test) => {
        if (!test.subject) return;
        contentData.questionPaper.items.push({
          id: test._id,
          type: "test",
          testName: test.testName,
          subject: test.subject,
          topic: test.topic || "",
          filePath: test.questionPaper,
        });
      });

      function renderContent(tabKey) {
        const data = contentData[tabKey];
        if (!data || !data.items.length) {
          contentArea.innerHTML = `<p class="text-gray-500">No content available for this type yet.</p>`;
          return;
        }

        const itemsHtml = data.items
          .map((item) => {
            let mainTitle = "";
            let infoHtml = "";
            let typeBadge = "";

            if (item.type.toLowerCase() === "test") {
              mainTitle = item.testName || "Unnamed Test";
              infoHtml = `<p class="text-sm text-gray-400 mt-0.5">Subject: <span class="font-semibold text-gray-600">${item.subject}</span> &bull; Topic: ${item.topic}</p>`;
              typeBadge = `<span class="text-xs font-bold px-2 py-0.5 rounded-full bg-amber-50 text-amber-600 border border-amber-200">Question Paper</span>`;
            } else {
              mainTitle = item.topic || item.subject;
              infoHtml = `<p class="text-sm text-gray-400 mt-0.5">Subject: <span class="font-semibold text-gray-600">${item.subject}</span></p>`;
              const typeLabels = { textbook: { bg: 'bg-blue-50', text: 'text-blue-600', border: 'border-blue-200', label: 'Textbook' }, notes: { bg: 'bg-green-50', text: 'text-green-600', border: 'border-green-200', label: 'Notes' } };
              const t = typeLabels[item.type] || { bg: 'bg-purple-50', text: 'text-brand-purple', border: 'border-purple-200', label: item.type };
              typeBadge = `<span class="text-xs font-bold px-2 py-0.5 rounded-full ${t.bg} ${t.text} border ${t.border}">${t.label}</span>`;
            }

            return `
    <div class="content-card p-4 sm:p-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div class="flex items-center gap-4 min-w-0">
            <div class="flex-shrink-0 w-12 h-12 flex items-center justify-center rounded-xl bg-purple-50">${getIcon(item.type)}</div>
            <div class="min-w-0">
                <div class="flex items-center gap-2 flex-wrap mb-1">${typeBadge}</div>
                <p class="font-bold text-gray-900 text-base leading-snug truncate">${mainTitle}</p>
                ${infoHtml}
            </div>
        </div>
        <div class="flex-shrink-0">
            ${
              item.filePath
                ? `<a href="${item.filePath}" target="_blank" class="btn-download"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>Download</a>`
                : `<span class="text-xs text-gray-400 italic">No file</span>`
            }
        </div>
    </div>`;
          })
          .join("");

        contentArea.innerHTML = `<div class="flex flex-col gap-3">${itemsHtml}</div>`;
      }

      function getIcon(type) {
        const iconClasses = "w-10 h-10 flex-shrink-0";
        switch (type.toLowerCase()) {
          case "pdf":
            return `
            <svg class="${iconClasses} text-red-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6 2a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6H6zM13 3.5L18.5 9H13V3.5zM8 13h8v2H8v-2zm0 4h8v2H8v-2zm0-8h8v2H8V9z"/>
            </svg>`;
          case "docx":
          case "doc":
            return `
            <svg class="${iconClasses} text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6 2a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6H6zM13 3.5L18.5 9H13V3.5zM8 9h8v2H8V9zm0 4h8v2H8v-2zm0 4h5v2H8v-2z"/>
            </svg>`;
          default:
            return `
            <svg class="${iconClasses} text-brand-purple" fill="currentColor" viewBox="0 0 24 24">
                <path d="M4 2a2 2 0 00-2 2v16a2 2 0 002 2h16a2 2 0 002-2V8l-6-6H4zM14 3.5L19.5 9H14V3.5zM6 8h5v1H6V8zm0 3h12v1H6v-1zm0 3h12v1H6v-1zm0 3h8v1H6v-1z"/>
            </svg>`;
        }
      }

      subjectTabsContainer.addEventListener("click", function(e) {
        const btn = e.target.closest(".tab-btn");
        if (btn) {
          subjectTabsContainer
            .querySelectorAll(".tab-btn")
            .forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          renderContent(btn.dataset.subject);
        }
      });

      const firstTab = subjectTabsContainer.querySelector(".tab-btn");
      if (firstTab) {
        firstTab.classList.add("active");
        renderContent(firstTab.dataset.subject);
      }
    });
  </script>
</body>

</html>