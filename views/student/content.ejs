<!DOCTYPE html>
<html lang="en" data-theme="light">
<%- include('../partials/background') %>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Study Materials | Tuition Hub</title>
  <style>
    .premium-banner {
      background: linear-gradient(135deg, var(--p) 0%, var(--pm) 100%);
      box-shadow: 0 10px 30px var(--pg);
    }

    .tab-btn {
      padding: 0.6rem 1.75rem;
      border-radius: 9999px;
      font-weight: 700;
      font-family: 'Space Mono', monospace;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      border: 1px solid var(--b);
      color: var(--fd);
      background: var(--bgc);
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      cursor: pointer;
    }
    .tab-btn:hover {
      border-color: var(--p);
      color: var(--pt);
      background: var(--bgch);
      transform: translateY(-2px);
    }
    .tab-btn.active {
      background: var(--p);
      color: white;
      border-color: var(--p);
      box-shadow: 0 4px 15px var(--pg);
    }

    .content-card {
      transition: all 0.3s ease;
      border-radius: 12px;
      border: 1px solid var(--b);
      background: var(--bgc);
    }
    .content-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 25px var(--pg);
      border-color: var(--p);
      background: var(--bgch);
    }
    .icon-wrapper {
      background: linear-gradient(135deg, rgba(124,58,237,0.1), rgba(124,58,237,0.05));
      border: 1px solid rgba(124,58,237,0.2);
    }
  </style>
</head>

<body class="text-theme-fg wrap">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
    <!-- Premium Banner Header -->
    <header class="mb-10 premium-banner rounded-2xl p-6 sm:p-12 text-center relative overflow-hidden">
      <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-white opacity-10"></div>
      <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-48 h-48 rounded-full bg-white opacity-5"></div>
      <div class="relative z-10">
        <div class="flex justify-center sm:justify-start mb-6">
          <a href="/student/dashboard" class="btn-outline bg-white/10 border-white/20 text-white hover:bg-white hover:text-theme-pt">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Dashboard
          </a>
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-unbounded font-extrabold text-white leading-tight mb-2 tracking-tight">
          Study <span class="text-theme-lt">Materials</span>
        </h1>
        <p class="text-white/80 font-mono tracking-widest text-xs uppercase mt-4">Browse textbooks, notes, and question papers</p>
      </div>
    </header>

    <!-- Glass Container -->
    <div class="glass-card p-6 sm:p-10 mb-10">
      <!-- Tab Buttons -->
      <div class="mb-10">
        <p class="text-xs font-mono font-bold uppercase tracking-widest text-theme-fdd mb-4 border-b border-theme-bd pb-2">Filter by Type</p>
        <div id="subject-tabs" class="flex flex-wrap gap-4">
          <button class="tab-btn active" data-subject="textbook"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:5px"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>Textbooks</button>
          <button class="tab-btn" data-subject="notes"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:5px"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>Notes</button>
          <button class="tab-btn" data-subject="questionPaper"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:5px"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><circle cx="10" cy="14" r="2"/><path d="m20 20-1.09-1.09"/></svg>Question Papers</button>
        </div>
      </div>

      <div id="content-area"></div>
    </div>
  </div>

  <div id="materials-data" data-materials='<%- JSON.stringify(materials || []) %>'></div>
  <div id="tests-data" data-tests='<%- JSON.stringify(tests || []) %>'></div>

  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const subjectTabsContainer = document.getElementById("subject-tabs");
      const contentArea = document.getElementById("content-area");
      const materials = JSON.parse(
        document.getElementById("materials-data").dataset.materials || "[]"
      );
      const tests = JSON.parse(
        document.getElementById("tests-data").dataset.tests || "[]"
      );
      const contentData = {
        textbook: {
          title: "Textbooks",
          items: []
        },
        notes: {
          title: "Notes",
          items: []
        },
        questionPaper: {
          title: "Question Papers",
          items: []
        },
      };

      (materials || []).forEach((mat) => {
        if (!mat.subject || !mat.materialType) return;
        const key = mat.materialType;
        if (!contentData[key]) return;
        contentData[key].items.push({
          id: mat._id,
          type: mat.materialType,
          subject: mat.subject,
          topic: mat.description || "",
          filePath: mat.filePath,
        });
      });

      (tests || []).forEach((test) => {
        if (!test.subject) return;
        contentData.questionPaper.items.push({
          id: test._id,
          type: "test",
          testName: test.testName,
          subject: test.subject,
          topic: test.topic || "",
          filePath: test.questionPaper,
        });
      });

      function renderContent(tabKey) {
        const data = contentData[tabKey];
        if (!data || !data.items.length) {
          contentArea.innerHTML = `<div class="p-8 text-center text-theme-fdd border-2 border-dashed border-theme-bd rounded-2xl font-mono text-sm uppercase tracking-widest">No content available for this type yet.</div>`;
          return;
        }

        const itemsHtml = data.items
          .map((item) => {
            let mainTitle = "";
            let infoHtml = "";
            let typeBadge = "";

            if (item.type.toLowerCase() === "test") {
              mainTitle = item.testName || "Unnamed Test";
              infoHtml = `<p class="text-xs font-mono text-theme-fd mt-1 uppercase tracking-wide">SUB: <span class="font-bold text-theme-fg">${item.subject}</span> &bull; TOPIC: ${item.topic}</p>`;
              typeBadge = `<span class="text-xs font-mono font-bold px-3 py-1 rounded-full bg-amber-500/10 text-amber-500 border border-amber-500/30 uppercase tracking-widest">Question Paper</span>`;
            } else {
              mainTitle = item.topic || item.subject;
              infoHtml = `<p class="text-xs font-mono text-theme-fd mt-1 uppercase tracking-wide">SUB: <span class="font-bold text-theme-fg">${item.subject}</span></p>`;
              const typeLabels = { 
                textbook: { bg: 'bg-blue-500/10', text: 'text-blue-500', border: 'border-blue-500/30', label: 'Textbook' }, 
                notes: { bg: 'bg-green-500/10', text: 'text-green-500', border: 'border-green-500/30', label: 'Notes' } 
              };
              const t = typeLabels[item.type] || { bg: 'bg-theme-p/10', text: 'text-theme-pt', border: 'border-theme-p/30', label: item.type };
              typeBadge = `<span class="text-[10px] font-mono font-bold px-3 py-1 rounded-full ${t.bg} ${t.text} border ${t.border} uppercase tracking-widest">${t.label}</span>`;
            }

            return `
    <div class="content-card w-full p-4 sm:p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-5 min-w-0">
        <div class="flex items-center gap-4 sm:gap-5 w-full min-w-0">
            <div class="flex-shrink-0 w-12 h-12 sm:w-14 sm:h-14 flex items-center justify-center rounded-xl sm:rounded-2xl icon-wrapper shadow-inner">${getIcon(item.type)}</div>
            <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 flex-wrap mb-2">${typeBadge}</div>
                <p class="font-unbounded font-bold text-theme-fg text-base sm:text-lg leading-snug break-words">${mainTitle}</p>
                ${infoHtml}
            </div>
        </div>
        <div class="flex-shrink-0 w-full sm:w-auto mt-2 sm:mt-0">
            ${
              item.filePath
                ? `<a href="${item.filePath}" target="_blank" class="btn-primary w-full sm:w-auto text-xs py-2.5 px-5 shadow-lg flex items-center justify-center gap-2 font-bold uppercase tracking-wider"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>View</a>`
                : `<span class="text-xs text-theme-fdd italic font-mono bg-theme-bg/50 px-3 py-1.5 rounded border border-theme-bd flex items-center justify-center">No file attached</span>`
            }
        </div>
    </div>`;
          })
          .join("");

        contentArea.innerHTML = `<div class="flex flex-col gap-4">${itemsHtml}</div>`;
      }

      function getIcon(type) {
        const iconClasses = "w-7 h-7 flex-shrink-0 drop-shadow-sm";
        switch (type.toLowerCase()) {
          case "pdf":
            return `
            <svg class="${iconClasses} text-red-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6 2a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6H6zM13 3.5L18.5 9H13V3.5zM8 13h8v2H8v-2zm0 4h8v2H8v-2zm0-8h8v2H8V9z"/>
            </svg>`;
          case "docx":
          case "doc":
            return `
            <svg class="${iconClasses} text-blue-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6 2a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6H6zM13 3.5L18.5 9H13V3.5zM8 9h8v2H8V9zm0 4h8v2H8v-2zm0 4h5v2H8v-2z"/>
            </svg>`;
          default:
            return `
            <svg class="${iconClasses} text-theme-pt" fill="currentColor" viewBox="0 0 24 24">
                <path d="M4 2a2 2 0 00-2 2v16a2 2 0 002 2h16a2 2 0 002-2V8l-6-6H4zM14 3.5L19.5 9H14V3.5zM6 8h5v1H6V8zm0 3h12v1H6v-1zm0 3h12v1H6v-1zm0 3h8v1H6v-1z"/>
            </svg>`;
        }
      }

      subjectTabsContainer.addEventListener("click", function(e) {
        const btn = e.target.closest(".tab-btn");
        if (btn) {
          subjectTabsContainer
            .querySelectorAll(".tab-btn")
            .forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          renderContent(btn.dataset.subject);
        }
      });

      const firstTab = subjectTabsContainer.querySelector(".tab-btn");
      if (firstTab) {
        firstTab.classList.add("active");
        renderContent(firstTab.dataset.subject);
      }
    });
  </script>
</body>

</html>