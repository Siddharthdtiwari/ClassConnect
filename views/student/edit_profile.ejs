<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Profile</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    body { font-family: "Inter", sans-serif; }

    .text-brand-purple { color: #5d3a9b; }

    .premium-banner {
      background: linear-gradient(135deg, #4b2d84 0%, #7c52ca 100%);
      box-shadow: 0 10px 25px -5px rgba(93, 58, 155, 0.3);
    }

    .glass-card {
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.6);
      box-shadow: 0 8px 32px rgba(93, 58, 155, 0.1);
    }

    .form-input {
      border: 2px solid #e5e7eb;
      border-radius: 10px;
      padding: 0.75rem 1rem;
      width: 100%;
      font-size: 0.95rem;
      color: #1f2937;
      transition: border-color 0.25s ease, box-shadow 0.25s ease;
      background: #fafafa;
    }

    .form-input:focus {
      outline: none;
      border-color: #5d3a9b;
      background: white;
      box-shadow: 0 0 0 3px rgba(93, 58, 155, 0.12);
    }

    .form-input[readonly] {
      background: #f3f4f6;
      color: #9ca3af;
      cursor: not-allowed;
      border-color: #e5e7eb;
    }

    .avatar-zone {
      border: 2px dashed #d1d5db;
      border-radius: 16px;
      transition: all 0.3s ease;
      background: #fafafa;
    }

    .avatar-zone:hover {
      border-color: #5d3a9b;
      background: #f3e8ff;
    }

    .btn-primary {
      background: linear-gradient(135deg, #5d3a9b, #7c52ca);
      color: white;
      font-weight: 700;
      padding: 0.65rem 1.8rem;
      border-radius: 9999px;
      transition: all 0.25s ease;
      box-shadow: 0 4px 12px rgba(93, 58, 155, 0.3);
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 18px rgba(93, 58, 155, 0.4);
    }

    .btn-cancel {
      background: white;
      color: #6b7280;
      font-weight: 600;
      padding: 0.65rem 1.8rem;
      border-radius: 9999px;
      border: 2px solid #e5e7eb;
      transition: all 0.25s ease;
    }

    .btn-cancel:hover {
      border-color: #9ca3af;
      color: #374151;
      background: #f9fafb;
    }
  </style>
</head>
<%- include('../partials/background') %>

<body class="text-gray-800">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">

    <!-- Premium Banner Header -->
    <header class="mb-10 premium-banner rounded-2xl p-6 sm:p-10 text-center relative overflow-hidden">
      <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-white opacity-10"></div>
      <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-48 h-48 rounded-full bg-white opacity-5"></div>

      <div class="relative z-10">
        <div class="flex justify-center sm:justify-start mb-5">
          <a href="/student/dashboard" class="inline-flex items-center text-sm font-bold text-white py-2 px-4 rounded-full shadow-sm transition-all" style="border: 1px solid rgba(255,255,255,0.4); background: rgba(255,255,255,0.12);" onmouseover="this.style.background='white';this.style.color='#5d3a9b';" onmouseout="this.style.background='rgba(255,255,255,0.12)';this.style.color='white';">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Back to Dashboard
          </a>
        </div>
        <div class="w-16 h-16 rounded-2xl bg-white/20 flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-white leading-tight mb-1 tracking-tight">Edit Profile</h1>
        <p class="text-purple-100 font-medium text-base">Keep your personal information up to date.</p>
      </div>
    </header>

    <!-- Form Card -->
    <div class="max-w-2xl mx-auto glass-card p-6 sm:p-10 rounded-2xl">
      <form id="edit-profile-form" action="/student/edit_profile" method="POST" enctype="multipart/form-data">
        <div class="space-y-7">

          <!-- Profile Picture Upload -->
          <div>
            <label class="block text-sm font-bold text-gray-600 mb-3 uppercase tracking-wide">Profile Photo</label>
            <div class="avatar-zone p-6 flex flex-col sm:flex-row items-center gap-6 cursor-pointer" id="avatar-zone-click">
              <div class="relative flex-shrink-0">
                <img id="profile-preview"
                  src="<%= student.profilePhoto || 'https://placehold.co/96x96/f3e8ff/5d3a9b?text=' + student.studentName.charAt(0) %>"
                  alt="Profile"
                  class="w-24 h-24 rounded-full object-cover border-4 border-white shadow-lg" />
                <div class="absolute bottom-0 right-0 w-8 h-8 bg-brand-purple rounded-full flex items-center justify-center shadow-md" style="background:#5d3a9b;">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                </div>
              </div>
              <div class="text-center sm:text-left">
                <p class="font-bold text-gray-800 text-base">Click to change photo</p>
                <p class="text-sm text-gray-400 mt-1">PNG or JPG, up to 4MB</p>
                <input type="file" id="profile-picture-input" name="profilePhoto" class="hidden" accept="image/*" />
              </div>
            </div>
          </div>

          <!-- Full Name -->
          <div>
            <label for="studentName" class="block text-sm font-bold text-gray-600 mb-2 uppercase tracking-wide">Full Name</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
              </div>
              <input type="text" id="studentName" name="studentName" class="form-input pl-10" value="<%= student.studentName %>" placeholder="Your full name" />
            </div>
          </div>

          <!-- Mobile Number -->
          <div>
            <label for="mobileNo" class="block text-sm font-bold text-gray-600 mb-2 uppercase tracking-wide">Mobile Number</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <input type="text" id="mobileNo" name="mobileNo" class="form-input pl-10" value="<%= student.mobileNo %>" placeholder="10-digit mobile number" />
            </div>
          </div>

          <!-- Student ID (read-only) -->
          <div>
            <label for="student-id" class="block text-sm font-bold text-gray-600 mb-2 uppercase tracking-wide flex items-center gap-2">
              Student ID
              <span class="text-xs font-semibold text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full normal-case">Read-only</span>
            </label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"></path></svg>
              </div>
              <input type="text" id="student-id" class="form-input pl-10" value="<%= student.studentId %>" readonly />
            </div>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="mt-10 pt-6 border-t border-gray-100 flex flex-col-reverse sm:flex-row justify-end gap-3">
          <button type="button" onclick="window.location.href='/student/dashboard'" class="btn-cancel">
            Cancel
          </button>
          <button type="submit" class="btn-primary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Save Changes
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const avatarZone = document.getElementById("avatar-zone-click");
      const fileInput = document.getElementById("profile-picture-input");
      const profilePreview = document.getElementById("profile-preview");

      avatarZone.addEventListener("click", () => fileInput.click());

      fileInput.addEventListener("change", (event) => {
        const file = event.target.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = (e) => { profilePreview.src = e.target.result; };
          reader.readAsDataURL(file);
        }
      });
    });
  </script>
</body>

</html>