<!DOCTYPE html>
<html lang="en" data-theme="light">
<%- include('../partials/background') %>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Profile | Tuition Hub</title>
  <style>
    .premium-banner {
      background: linear-gradient(135deg, var(--p) 0%, var(--pm) 100%);
      box-shadow: 0 10px 30px var(--pg);
    }

    .form-input {
      border: 1px solid var(--b);
      border-radius: 12px;
      padding: 0.85rem 1rem 0.85rem 3.25rem;
      width: 100%;
      font-size: 0.95rem;
      color: var(--fg);
      background: var(--bgc);
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .form-input:focus {
      outline: none;
      border-color: var(--p);
      background: var(--bgch);
      box-shadow: 0 0 0 4px var(--pg);
    }

    .form-input[readonly] {
      background: rgba(12,12,12,0.05);
      color: var(--fd);
      cursor: not-allowed;
      border-color: var(--bd);
    }

    .avatar-zone {
      border: 2px dashed var(--b);
      border-radius: 20px;
      transition: all 0.3s ease;
      background: var(--bgc);
    }

    .avatar-zone:hover {
      border-color: var(--p);
      background: var(--bgch);
      transform: translateY(-2px);
      box-shadow: 0 8px 20px var(--pg);
    }
  </style>
</head>

<body class="text-theme-fg wrap">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
    <!-- Premium Banner Header -->
    <header class="mb-10 premium-banner rounded-2xl p-6 sm:p-12 text-center relative overflow-hidden">
      <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-white opacity-10"></div>
      <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-48 h-48 rounded-full bg-white opacity-5"></div>

      <div class="relative z-10">
        <div class="flex justify-center sm:justify-start mb-6">
          <a href="/student/dashboard" class="btn-outline bg-white/10 border-white/20 text-white hover:bg-white hover:text-theme-pt">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Dashboard
          </a>
        </div>
        <div class="w-16 h-16 rounded-3xl bg-white/20 flex items-center justify-center mx-auto mb-6 backdrop-blur-sm border border-white/30 shadow-inner">
          <svg class="w-8 h-8 text-white drop-shadow-md" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-unbounded font-extrabold text-white leading-tight mb-2 tracking-tight">
          Edit <span class="text-theme-lt">Profile</span>
        </h1>
        <p class="text-white/80 font-mono tracking-widest text-xs uppercase mt-4">Keep your personal information up to date</p>
      </div>
    </header>

    <!-- Form Card -->
    <div class="max-w-2xl mx-auto glass-card p-6 sm:p-12">
      <form id="edit-profile-form" action="/student/edit_profile?_csrf=<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
        
        <div class="space-y-8">
          <!-- Profile Picture Upload -->
          <div>
            <label class="block text-xs font-mono font-bold text-theme-fdd mb-3 uppercase tracking-widest">Profile Photo</label>
            <div class="avatar-zone p-8 flex flex-col sm:flex-row items-center gap-8 cursor-pointer" id="avatar-zone-click">
              <div class="relative flex-shrink-0">
                <img id="profile-preview"
                  src="<%= student.profilePhoto || 'https://placehold.co/96x96/f3e8ff/5d3a9b?text=' + student.studentName.charAt(0) %>"
                  alt="Profile"
                  class="w-28 h-28 rounded-full object-cover border-4 border-theme-bg shadow-xl bg-theme-bg" />
                <div class="absolute bottom-0 right-0 w-10 h-10 bg-theme-p text-white rounded-full flex items-center justify-center shadow-lg border-2 border-theme-bg">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                </div>
              </div>
              <div class="text-center sm:text-left">
                <p class="font-unbounded font-bold text-theme-fg text-lg">Click to change photo</p>
                <p class="text-xs font-mono text-theme-fd mt-2 uppercase tracking-wide">PNG or JPG, up to 4MB</p>
                <input type="file" id="profile-picture-input" name="profilePhoto" class="hidden" accept="image/*" />
              </div>
            </div>
          </div>

          <!-- Full Name -->
          <div>
            <label for="studentName" class="block text-xs font-mono font-bold text-theme-fdd mb-3 uppercase tracking-widest">Full Name</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <svg class="w-5 h-5 text-theme-fd" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
              </div>
              <input type="text" id="studentName" name="studentName" class="form-input pl-12" value="<%= student.studentName %>" placeholder="Your full name" />
            </div>
          </div>

          <!-- Mobile Number -->
          <div>
            <label for="mobileNo" class="block text-xs font-mono font-bold text-theme-fdd mb-3 uppercase tracking-widest">Mobile Number</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <svg class="w-5 h-5 text-theme-fd" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <input type="text" id="mobileNo" name="mobileNo" class="form-input pl-12 font-mono" value="<%= student.mobileNo %>" placeholder="10-digit mobile number" />
            </div>
          </div>

          <!-- Email Address -->
          <div>
            <label for="email" class="block text-xs font-mono font-bold text-theme-fdd mb-3 uppercase tracking-widest">Email Address</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <svg class="w-5 h-5 text-theme-fd" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21.3 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <input type="email" id="email" name="email" class="form-input pl-12" value="<%= student.email || '' %>" placeholder="email@example.com" />
            </div>
          </div>

          <!-- Student ID (read-only) -->
          <div>
            <label for="student-id" class="flex items-center gap-3 block text-xs font-mono font-bold text-theme-fdd mb-3 uppercase tracking-widest">
              Student ID
              <span class="text-[10px] font-bold bg-theme-bd text-theme-fd px-2 py-0.5 rounded uppercase tracking-widest border border-theme-b">Read-only</span>
            </label>
            <div class="relative opacity-75">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <svg class="w-5 h-5 text-theme-fdd" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"></path></svg>
              </div>
              <input type="text" id="student-id" class="form-input pl-12 font-mono" value="<%= student.studentId %>" readonly />
            </div>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="mt-12 pt-8 border-t border-theme-bd flex flex-col-reverse sm:flex-row justify-end gap-4">
          <button type="button" onclick="window.location.href='/student/dashboard'" class="btn-outline px-8">
            Cancel
          </button>
          <button type="submit" class="btn-primary px-8 flex items-center justify-center gap-2 text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
            Save Changes
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const avatarZone = document.getElementById("avatar-zone-click");
      const fileInput = document.getElementById("profile-picture-input");
      const profilePreview = document.getElementById("profile-preview");

      avatarZone.addEventListener("click", () => fileInput.click());

      fileInput.addEventListener("change", (event) => {
        const file = event.target.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = (e) => { profilePreview.src = e.target.result; };
          reader.readAsDataURL(file);
        }
      });
    });
  </script>
</body>

</html>