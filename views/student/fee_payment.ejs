<!DOCTYPE html>
<html lang="en" data-theme="light">
<%- include('../partials/background') %>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fee Payment | Tuition Hub</title>
  <style>
    .premium-banner {
      background: linear-gradient(135deg, var(--p) 0%, var(--pm) 100%);
      box-shadow: 0 10px 30px var(--pg);
    }

    .due-card {
      background: linear-gradient(135deg, rgba(252, 211, 77, 0.1) 0%, rgba(253, 230, 138, 0.05) 100%);
      border: 1.5px solid rgba(252, 211, 77, 0.3);
    }

    .cleared-card {
      background: linear-gradient(135deg, rgba(110, 231, 183, 0.1) 0%, rgba(167, 243, 208, 0.05) 100%);
      border: 1.5px solid rgba(110, 231, 183, 0.3);
    }

    .status-paid {
      background: rgba(34, 197, 94, 0.1);
      color: #166534;
      border: 1px solid rgba(34, 197, 94, 0.3);
    }
    .status-due {
      background: rgba(239, 68, 68, 0.1);
      color: #991b1b;
      border: 1px solid rgba(239, 68, 68, 0.3);
    }
    .status-upcoming {
      background: rgba(59, 130, 246, 0.1);
      color: #1e3a8a;
      border: 1px solid rgba(59, 130, 246, 0.3);
    }

    .fee-row {
      transition: all 0.25s ease;
      border-radius: 16px;
      border: 1px solid var(--b);
      background: var(--bgc);
    }
    .fee-row:hover {
      transform: translateX(4px);
      box-shadow: 0 6px 20px var(--pg);
      border-color: var(--p);
      background: var(--bgch);
    }

    .receipt-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.7rem;
      font-family: 'Space Mono', monospace;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 0.4rem 0.85rem;
      border-radius: 9999px;
      background: var(--p);
      color: white;
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      border: 1px solid transparent;
    }
    .receipt-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px var(--pg);
      background: var(--pm);
    }
    .receipt-btn-outline {
      background: transparent;
      color: var(--pt);
      border: 1px solid var(--p);
    }
    .receipt-btn-outline:hover {
      background: var(--p);
      color: white;
    }
  </style>
</head>

<body class="text-theme-fg wrap">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
    <!-- Premium Banner Header -->
    <header class="mb-10 premium-banner rounded-2xl p-6 sm:p-12 text-center relative overflow-hidden">
      <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-white opacity-10"></div>
      <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-48 h-48 rounded-full bg-white opacity-5"></div>
      <div class="relative z-10">
        <div class="flex justify-center sm:justify-start mb-6">
          <a href="/student/dashboard" class="btn-outline bg-white/10 border-white/20 text-white hover:bg-white hover:text-theme-pt">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Dashboard
          </a>
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-unbounded font-extrabold text-white leading-tight mb-2 tracking-tight">
          Fee <span class="text-theme-lt">Payment</span>
        </h1>
        <p class="text-white/80 font-mono tracking-widest text-xs uppercase mt-4">Manage your tuition fees and view payment history</p>
      </div>
    </header>

    <!-- Two-column layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- LEFT: Outstanding Amount -->
      <div class="lg:col-span-1">
        <div class="glass-card p-6 sm:p-8 rounded-2xl h-full flex flex-col gap-8">
          <!-- Amount Due Card -->
          <div class="<%= totalDue > 0 ? 'due-card' : 'cleared-card' %> rounded-2xl p-8 text-center shadow-sm">
            <p class="text-xs font-mono font-bold uppercase tracking-widest mb-4 <%= totalDue > 0 ? 'text-amber-600' : 'text-emerald-600' %>">
              <%= totalDue > 0 ? '⚠️ Amount Due' : '✅ All Cleared' %>
            </p>
            <p class="text-5xl font-unbounded font-extrabold <%= totalDue > 0 ? 'text-amber-600' : 'text-emerald-600' %> my-3 tracking-tight drop-shadow-sm">
              ₹<%= totalDue.toLocaleString() %>
            </p>
            <% if (totalDue > 0) { %>
            <p class="text-xs font-mono tracking-wide text-red-500 font-bold mt-4 bg-red-500/10 inline-block px-3 py-1 rounded border border-red-500/20">
              DUE BY: 10 <%= new Date().toLocaleDateString("en-IN", { month: "short", year: "numeric" }).toUpperCase() %>
            </p>
            <% } else { %>
            <p class="text-xs font-mono tracking-wide text-emerald-600 font-bold mt-4 bg-emerald-500/10 inline-block px-3 py-1 rounded border border-emerald-500/20 uppercase">
              No outstanding dues 🎉
            </p>
            <% } %>
          </div>

          <!-- Pay Button -->
          <% if (totalDue > 0) { %>
          <button id="pay-button"
            class="btn-primary w-full py-4 text-base flex justify-center shadow-xl"
            data-key="<%= razorpayKeyId %>"
            data-amount="<%= totalDue %>"
            data-name="<%= student.studentName %>"
            data-email="student@example.com"
            data-contact="<%= student.mobileNo %>">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
            Pay ₹<%= totalDue.toLocaleString() %> Now
          </button>
          <% } else { %>
          <button class="btn-outline w-full py-4 text-base flex justify-center cursor-not-allowed opacity-50" disabled>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            All Fees Cleared
          </button>
          <% } %>

          <p class="text-[10px] font-mono tracking-widest uppercase text-theme-fdd text-center -mt-4">
            🔒 Secured via Razorpay gateway
          </p>

          <!-- Payment Summary Stats -->
          <div class="bg-theme-bgc rounded-2xl p-6 border border-theme-b shadow-inner">
            <p class="text-xs font-mono font-bold uppercase tracking-widest text-theme-fdd mb-5 border-b border-theme-bd pb-3">Summary</p>
            <div class="space-y-4 font-mono text-sm">
              <div class="flex justify-between items-center">
                <span class="text-theme-fd uppercase tracking-wide">Monthly Fee</span>
                <span class="font-bold text-theme-fg">₹<%= student.monthlyFee.toLocaleString() %></span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-theme-fd uppercase tracking-wide">Months Paid</span>
                <span class="font-bold text-emerald-600"><%= feesByMonth.filter(f => f.status === 'Paid').length %></span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-theme-fd uppercase tracking-wide">Total Paid</span>
                <span class="font-bold text-theme-pt text-base">₹<%= feesByMonth.filter(f => f.status === 'Paid').reduce((sum, f) => sum + (f.amount || 0), 0).toLocaleString() %></span>
              </div>
              <div class="flex justify-between items-center pt-4 border-t border-theme-bd mt-2">
                <span class="text-theme-fd uppercase tracking-wide">Outstanding</span>
                <span class="font-bold text-lg <%= totalDue > 0 ? 'text-red-500' : 'text-emerald-600' %>">₹<%= totalDue.toLocaleString() %></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: Payment History -->
      <div class="lg:col-span-2">
        <div class="glass-card p-6 sm:p-10 rounded-2xl h-full">
          <h2 class="text-2xl font-unbounded font-extrabold text-theme-pt mb-8 flex items-center gap-3 border-b border-theme-bd pb-4">
            <span class="text-3xl drop-shadow-md">🧾</span> Payment History
          </h2>
          <div class="space-y-4">
            <% feesByMonth.forEach(f=> { %>
            <div class="fee-row p-5 sm:p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
              <!-- Left: Month Info -->
              <div class="flex items-center gap-5 min-w-0">
                <div class="flex-shrink-0 w-14 h-14 rounded-2xl flex items-center justify-center shadow-inner border border-white/20 <%= f.status === 'Paid' ? 'bg-emerald-500/10' : f.status === 'Due' ? 'bg-red-500/10' : 'bg-blue-500/10' %>">
                  <svg class="w-6 h-6 <%= f.status === 'Paid' ? 'text-emerald-500' : f.status === 'Due' ? 'text-red-500' : 'text-blue-500' %> drop-shadow-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                </div>
                <div class="min-w-0">
                  <p class="font-unbounded font-bold text-theme-fg text-lg">Tuition Fee — <span class="text-theme-pt"><%= f.month %></span></p>
                  <% if (f.status === "Paid") { %>
                  <p class="text-xs font-mono uppercase tracking-widest text-theme-fdd mt-2">Paid on: <span class="font-bold text-theme-fd"><%= new Date(f.datePaid).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}).toUpperCase() %></span></p>
                  <div class="flex flex-wrap gap-3 mt-4">
                    <a href="/student/receipt/<%= f._id %>/view" target="_blank" class="receipt-btn receipt-btn-outline">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                      View
                    </a>
                    <a href="/student/receipt/<%= f._id %>" target="_blank" download class="receipt-btn">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                      Download
                    </a>
                  </div>
                  <% } else if (f.status === "Due") { %>
                  <p class="text-xs font-mono uppercase tracking-widest text-red-500 font-bold mt-2">Payment pending</p>
                  <% } else { %>
                  <p class="text-xs font-mono uppercase tracking-widest text-theme-fdd mt-2">Not yet due</p>
                  <% } %>
                </div>
              </div>

              <!-- Right: Amount + Badge -->
              <div class="w-full sm:w-auto flex flex-row sm:flex-col items-center sm:items-end justify-between sm:justify-end gap-3 sm:gap-2 pt-4 sm:pt-0 border-t sm:border-t-0 border-theme-bd">
                <p class="font-unbounded font-extrabold text-2xl text-theme-fg drop-shadow-sm">
                  ₹<%= f.status === "Paid" ? f.amount.toLocaleString() : student.monthlyFee.toLocaleString() %>
                </p>
                <span class="px-3 py-1 text-[10px] font-mono uppercase tracking-widest font-bold rounded-full <%= f.status === 'Paid' ? 'status-paid' : f.status === 'Due' ? 'status-due' : 'status-upcoming' %>">
                  <%= f.status %>
                </span>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script src="/js/payment-handler.js"></script>
</body>

</html>