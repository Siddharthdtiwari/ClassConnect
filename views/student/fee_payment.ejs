<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fee Payment</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    body { font-family: "Inter", sans-serif; }
    .text-brand-purple { color: #5d3a9b; }

    .premium-banner {
      background: linear-gradient(135deg, #4b2d84 0%, #7c52ca 100%);
      box-shadow: 0 10px 25px -5px rgba(93, 58, 155, 0.3);
    }

    .glass-card {
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.6);
      box-shadow: 0 8px 32px rgba(93, 58, 155, 0.08);
    }

    .due-card {
      background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
      border: 1.5px solid #fcd34d;
    }

    .cleared-card {
      background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
      border: 1.5px solid #6ee7b7;
    }

    .btn-pay {
      background: linear-gradient(135deg, #5d3a9b, #7c52ca);
      color: white;
      font-weight: 800;
      font-size: 1rem;
      padding: 0.85rem 1.5rem;
      border-radius: 9999px;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      transition: all 0.3s ease;
      box-shadow: 0 6px 20px rgba(93, 58, 155, 0.38);
      letter-spacing: 0.02em;
    }
    .btn-pay:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 28px rgba(93, 58, 155, 0.45);
    }
    .btn-pay:disabled {
      background: linear-gradient(135deg, #d1fae5, #a7f3d0);
      color: #065f46;
      box-shadow: none;
      cursor: not-allowed;
      transform: none;
    }

    .status-paid {
      background: #dcfce7;
      color: #166534;
      border: 1px solid #86efac;
    }
    .status-due {
      background: #fee2e2;
      color: #991b1b;
      border: 1px solid #fca5a5;
    }
    .status-upcoming {
      background: #e0f2fe;
      color: #1e3a8a;
      border: 1px solid #93c5fd;
    }

    .fee-row {
      transition: all 0.25s ease;
      border-radius: 14px;
      border: 1px solid #f3f4f6;
      background: white;
    }
    .fee-row:hover {
      transform: translateX(4px);
      box-shadow: 0 4px 16px rgba(93, 58, 155, 0.08);
      border-color: rgba(93, 58, 155, 0.15);
    }

    .receipt-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0.3rem 0.75rem;
      border-radius: 9999px;
      background: #ede9fe;
      color: #5d3a9b;
      transition: all 0.2s ease;
    }
    .receipt-btn:hover {
      background: #5d3a9b;
      color: white;
    }
  </style>
</head>
<%- include('../partials/background') %>

<body class="text-gray-800">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">

    <!-- Premium Banner Header -->
    <header class="mb-10 premium-banner rounded-2xl p-6 sm:p-10 text-center relative overflow-hidden">
      <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-white opacity-10"></div>
      <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-48 h-48 rounded-full bg-white opacity-5"></div>
      <div class="relative z-10">
        <div class="flex justify-center sm:justify-start mb-5">
          <a href="/student/dashboard" class="inline-flex items-center text-sm font-bold text-white py-2 px-4 rounded-full shadow-sm transition-all" style="border: 1px solid rgba(255,255,255,0.4); background: rgba(255,255,255,0.12);" onmouseover="this.style.background='white';this.style.color='#5d3a9b';" onmouseout="this.style.background='rgba(255,255,255,0.12)';this.style.color='white';">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Back to Dashboard
          </a>
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight mb-2 tracking-tight">
          💳 Fee Payment
        </h1>
        <p class="text-purple-100 font-medium text-base sm:text-lg">Manage your tuition fees and view payment history.</p>
      </div>
    </header>

    <!-- Two-column layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- LEFT: Outstanding Amount -->
      <div class="lg:col-span-1">
        <div class="glass-card p-6 rounded-2xl h-full flex flex-col gap-6">

          <!-- Amount Due Card -->
          <div class="<%= totalDue > 0 ? 'due-card' : 'cleared-card' %> rounded-2xl p-6 text-center">
            <p class="text-sm font-bold uppercase tracking-widest mb-2 <%= totalDue > 0 ? 'text-amber-700' : 'text-emerald-700' %>">
              <%= totalDue > 0 ? '⚠️ Amount Due' : '✅ All Cleared' %>
            </p>
            <p class="text-5xl font-extrabold <%= totalDue > 0 ? 'text-amber-800' : 'text-emerald-800' %> my-2 tracking-tight">
              ₹<%= totalDue.toLocaleString() %>
            </p>
            <% if (totalDue > 0) { %>
            <p class="text-sm text-red-600 font-semibold mt-1">
              Due by: 10 <%= new Date().toLocaleDateString("en-IN", { month: "long", year: "numeric" }) %>
            </p>
            <% } else { %>
            <p class="text-sm text-emerald-600 font-semibold mt-1">No outstanding dues 🎉</p>
            <% } %>
          </div>

          <!-- Pay Button -->
          <% if (totalDue > 0) { %>
          <button id="pay-button"
            class="btn-pay"
            data-key="<%= razorpayKeyId %>"
            data-amount="<%= totalDue %>"
            data-name="<%= student.studentName %>"
            data-email="student@example.com"
            data-contact="<%= student.mobileNo %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
            Pay ₹<%= totalDue.toLocaleString() %> Now
          </button>
          <% } else { %>
          <button class="btn-pay" disabled>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            All Fees Cleared
          </button>
          <% } %>

          <p class="text-xs text-gray-400 text-center -mt-3">
            🔒 Secured via Razorpay payment gateway
          </p>

          <!-- Payment Summary Stats -->
          <div class="bg-gray-50 rounded-xl p-5 border border-gray-100">
            <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4">Summary</p>
            <div class="space-y-3">
              <div class="flex justify-between items-center">
                <span class="text-sm text-gray-500">Monthly Fee</span>
                <span class="font-bold text-gray-800">₹<%= student.monthlyFee.toLocaleString() %></span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-sm text-gray-500">Months Paid</span>
                <span class="font-bold text-green-600"><%= feesByMonth.filter(f => f.status === 'Paid').length %></span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-sm text-gray-500">Total Paid</span>
                <span class="font-extrabold text-brand-purple">₹<%= feesByMonth.filter(f => f.status === 'Paid').reduce((sum, f) => sum + (f.amount || 0), 0).toLocaleString() %></span>
              </div>
              <div class="flex justify-between items-center pt-2 border-t border-gray-200">
                <span class="text-sm text-gray-500">Outstanding</span>
                <span class="font-extrabold <%= totalDue > 0 ? 'text-red-500' : 'text-green-600' %>">₹<%= totalDue.toLocaleString() %></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: Payment History -->
      <div class="lg:col-span-2">
        <div class="glass-card p-6 sm:p-8 rounded-2xl h-full">
          <h2 class="text-xl font-extrabold text-gray-900 mb-6 flex items-center gap-2">
            <span class="text-2xl">🧾</span> Payment History
          </h2>
          <div class="space-y-3">
            <% feesByMonth.forEach(f=> { %>
            <div class="fee-row p-4 sm:p-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
              <!-- Left: Month Info -->
              <div class="flex items-center gap-4 min-w-0">
                <div class="flex-shrink-0 w-11 h-11 rounded-xl flex items-center justify-center <%= f.status === 'Paid' ? 'bg-green-50' : f.status === 'Due' ? 'bg-red-50' : 'bg-blue-50' %>">
                  <svg class="w-5 h-5 <%= f.status === 'Paid' ? 'text-green-500' : f.status === 'Due' ? 'text-red-500' : 'text-blue-400' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                </div>
                <div class="min-w-0">
                  <p class="font-bold text-gray-900 text-base">Tuition Fee — <%= f.month %></p>
                  <% if (f.status === "Paid") { %>
                  <p class="text-xs text-gray-400 mt-0.5">Paid on: <%= new Date(f.datePaid).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) %></p>
                  <div class="flex flex-wrap gap-2 mt-1.5">
                    <a href="/student/receipt/<%= f._id %>/view" target="_blank" class="receipt-btn">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                      View
                    </a>
                    <a href="/student/receipt/<%= f._id %>" target="_blank" download class="receipt-btn">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                      Download
                    </a>
                  </div>
                  <% } else if (f.status === "Due") { %>
                  <p class="text-xs text-red-500 font-semibold mt-0.5">Payment pending</p>
                  <% } else { %>
                  <p class="text-xs text-gray-400 mt-0.5">Not yet due</p>
                  <% } %>
                </div>
              </div>

              <!-- Right: Amount + Badge -->
              <div class="w-full sm:w-auto flex flex-row sm:flex-col items-center sm:items-end justify-between sm:justify-end gap-2 sm:gap-1.5 pt-2 sm:pt-0 border-t sm:border-t-0 border-gray-100">
                <p class="font-extrabold text-xl text-gray-900">
                  ₹<%= f.status === "Paid" ? f.amount.toLocaleString() : student.monthlyFee.toLocaleString() %>
                </p>
                <span class="px-3 py-0.5 text-xs font-bold rounded-full <%= f.status === 'Paid' ? 'status-paid' : f.status === 'Due' ? 'status-due' : 'status-upcoming' %>">
                  <%= f.status %>
                </span>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script src="/js/payment-handler.js"></script>
</body>

</html>