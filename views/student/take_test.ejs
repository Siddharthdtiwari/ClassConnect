<!DOCTYPE html>
<html lang="en" data-theme="light">
<%- include('../partials/background') %>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Class Tests | Tuition Hub</title>
  <style>
    .premium-banner {
      background: linear-gradient(135deg, var(--p) 0%, var(--pm) 100%);
      box-shadow: 0 10px 30px var(--pg);
    }

    .tab-pill {
      padding: 0.5rem 1.25rem;
      border-radius: 9999px;
      font-weight: 700;
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      border: 1px solid var(--b);
      color: var(--fd);
      background: var(--bgc);
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      white-space: nowrap;
    }
    .tab-pill:hover {
      border-color: var(--p);
      color: var(--pt);
      background: var(--bgch);
      transform: translateY(-2px);
    }
    .tab-pill.active {
      background: var(--p);
      color: white;
      border-color: var(--p);
      box-shadow: 0 4px 15px var(--pg);
    }

    .test-card {
      transition: all 0.3s ease;
      border-radius: 16px;
      border: 1px solid var(--b);
      background: var(--bgc);
    }
    .test-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 30px var(--pg);
      border-color: var(--p);
      background: var(--bgch);
    }
    .icon-wrapper {
      background: linear-gradient(135deg, rgba(124,58,237,0.1), rgba(124,58,237,0.05));
      border: 1px solid rgba(124,58,237,0.2);
    }
  </style>
</head>
<script src="/js/subjects.js"></script>

<body class="text-theme-fg wrap">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
    <!-- Premium Banner Header -->
    <header class="mb-10 premium-banner rounded-2xl p-6 sm:p-12 text-center relative overflow-hidden">
      <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-white opacity-10"></div>
      <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-48 h-48 rounded-full bg-white opacity-5"></div>
      <div class="relative z-10">
        <div class="flex justify-center sm:justify-start mb-6">
          <a href="/student/dashboard" class="btn-outline bg-white/10 border-white/20 text-white hover:bg-white hover:text-theme-pt">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Dashboard
          </a>
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-unbounded font-extrabold text-white leading-tight mb-2 tracking-tight">
          Class <span class="text-theme-lt">Tests</span>
        </h1>
        <p class="text-white/80 font-mono tracking-widest text-xs uppercase mt-4">Download test papers for Batch: <strong class="text-white"><%= studentStandard %></strong></p>
      </div>
    </header>

    <div class="glass-card p-6 sm:p-10 rounded-2xl mb-10">
      <!-- Subject Filter Pills -->
      <div class="mb-10">
        <p class="text-xs font-mono font-bold uppercase tracking-widest text-theme-fdd mb-4 border-b border-theme-bd pb-2">Filter by Subject</p>
        <div class="flex flex-wrap gap-3" id="subject-filters">
           <!-- Dynamic Pills Injected Here -->
        </div>
      </div>

      <!-- Tests List -->
      <div id="tests-area">
        <% if (tests.length===0) { %>
        <div class="text-center py-16 border-2 border-dashed border-theme-bd rounded-2xl">
          <div class="text-5xl mb-4 drop-shadow-md"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.4"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
          <h3 class="text-lg font-unbounded font-bold text-theme-fg">No Tests Found</h3>
          <p class="mt-2 text-theme-fdd font-mono text-xs uppercase tracking-widest">No tests available for <strong><%= subject==='overall' ? ('Batch ' + studentStandard) : subject %></strong> yet.</p>
        </div>
        <% } else { %>
        <div class="space-y-5">
          <% tests.forEach(test => { %>
          <div class="test-card p-5 sm:p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-5">
            <!-- Left: Icon + Info -->
            <div class="flex items-center gap-5 min-w-0">
              <div class="flex-shrink-0 w-14 h-14 flex items-center justify-center rounded-2xl icon-wrapper shadow-inner">
                <svg class="w-7 h-7 text-theme-pt drop-shadow-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
              </div>
              <div class="min-w-0">
                <h4 class="text-xl font-unbounded font-extrabold text-theme-fg truncate"><%= test.testName %></h4>
                <div class="flex flex-wrap items-center gap-3 mt-2">
                  <span class="text-[10px] font-mono font-bold px-3 py-1 rounded-full bg-theme-p/10 text-theme-pt border border-theme-p/30 uppercase tracking-widest"><%= test.subject %></span>
                  <% if (test.topic) { %><span class="text-xs font-mono text-theme-fd uppercase tracking-wide">TOPIC: <span class="font-bold text-theme-fg"><%= test.topic %></span></span><% } %>
                  <span class="text-xs font-mono text-theme-fd uppercase tracking-wide">• <span class="font-bold text-theme-fg"><%= test.totalMarks %></span> MARKS</span>
                  <% if (test.testDate) { %>
                  <span class="text-[10px] font-mono font-bold px-3 py-1 rounded-full bg-blue-500/10 text-blue-500 border border-blue-500/30 uppercase tracking-widest">
                    <%= new Date(test.testDate).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}).toUpperCase() %>
                  </span>
                  <% } %>
                </div>
              </div>
            </div>
            <!-- Right: Download -->
            <div class="flex-shrink-0 w-full sm:w-auto mt-4 sm:mt-0">
              <a href="<%= test.questionPaper %>" class="btn-primary w-full sm:w-auto text-xs py-3 px-6 shadow-lg" target="_blank" download>
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                Download Paper
              </a>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const studentBatchName = "<%= studentStandard %>";
      const currentSubject = "<%= subject %>";
      const filtersDiv = document.getElementById("subject-filters");
      
      const subjects = typeof getSubjectsForBatch !== 'undefined' ? getSubjectsForBatch(studentBatchName) : [];
      
      let html = `<a href="/student/take_test?subject=overall" class="tab-pill ${currentSubject === 'overall' ? 'active' : ''}">Overall</a>`;
      
      subjects.forEach(sub => {
        const isActive = currentSubject === sub ? 'active' : '';
        html += `<a href="/student/take_test?subject=${encodeURIComponent(sub)}" class="tab-pill ${isActive}">${sub}</a>`;
      });
      
      filtersDiv.innerHTML = html;
    });
  </script>
</body>

</html>