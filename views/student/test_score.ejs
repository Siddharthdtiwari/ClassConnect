<!DOCTYPE html>
<html lang="en" data-theme="light">
<%- include('../partials/background') %>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Test Scores | Tuition Hub</title>
  <style>
    .premium-banner {
      background: linear-gradient(135deg, var(--p) 0%, var(--pm) 100%);
      box-shadow: 0 10px 30px var(--pg);
    }

    .tab-pill {
      padding: 0.5rem 1.25rem;
      border-radius: 9999px;
      font-weight: 700;
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      border: 1px solid var(--b);
      color: var(--fd);
      background: var(--bgc);
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      white-space: nowrap;
      cursor: pointer;
    }
    .tab-pill:hover {
      border-color: var(--p);
      color: var(--pt);
      background: var(--bgch);
      transform: translateY(-2px);
    }
    .tab-pill.active {
      background: var(--p);
      color: white;
      border-color: var(--p);
      box-shadow: 0 4px 15px var(--pg);
    }

    .stat-card {
      border-radius: 16px;
      padding: 1.5rem;
      text-align: center;
      transition: all 0.3s ease;
      background: var(--bgc);
      border: 1px solid var(--b);
    }
    .stat-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 30px var(--pg);
      border-color: var(--p);
      background: var(--bgch);
    }

    .score-card {
      background: var(--bgc);
      border: 1px solid var(--b);
      border-radius: 16px;
      transition: all 0.3s ease;
    }
    .score-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 25px var(--pg);
      border-color: var(--p);
      background: var(--bgch);
    }

    .progress-track {
      background: var(--bg);
      border-radius: 9999px;
      height: 6px;
      overflow: hidden;
      border: 1px solid var(--b);
    }
    .progress-bar {
      height: 6px;
      border-radius: 9999px;
      width: 0%;
      transition: width 1s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .progress-bar-good    { background: linear-gradient(90deg, #10b981, #059669); }
    .progress-bar-average { background: linear-gradient(90deg, #f59e0b, #d97706); }
    .progress-bar-poor    { background: linear-gradient(90deg, #ef4444, #dc2626); }

    .qp-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-size: 0.65rem;
      font-family: 'Space Mono', monospace;
      font-weight: 700;
      padding: 0.3rem 0.75rem;
      border-radius: 9999px;
      background: var(--bg);
      color: var(--pt);
      border: 1px solid var(--b);
      transition: all 0.2s ease;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      white-space: nowrap;
    }
    .qp-btn:hover { background: var(--p); color: white; border-color: var(--p); transform: translateY(-1px); box-shadow: 0 2px 8px var(--pg); }
  </style>
</head>
<script src="/js/subjects.js"></script>

<body class="text-theme-fg wrap">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
    <!-- Premium Banner Header -->
    <header class="mb-10 premium-banner rounded-2xl p-6 sm:p-12 text-center relative overflow-hidden">
      <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-white opacity-10"></div>
      <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-48 h-48 rounded-full bg-white opacity-5"></div>
      <div class="relative z-10">
        <div class="flex justify-center sm:justify-start mb-6">
          <a href="/student/dashboard" class="btn-outline bg-white/10 border-white/20 text-white hover:bg-white hover:text-theme-pt">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Dashboard
          </a>
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-unbounded font-extrabold text-white leading-tight mb-2 tracking-tight">
          Test <span class="text-theme-lt">Scores</span>
        </h1>
        <p class="text-white/80 font-mono tracking-widest text-xs uppercase mt-4">Review your performance and points earned</p>
      </div>
    </header>

    <!-- Main Glass Container -->
    <div class="glass-card p-6 sm:p-10 rounded-2xl mb-10">
      <!-- Subject Filter Pills -->
      <div class="mb-10">
        <p class="text-xs font-mono font-bold uppercase tracking-widest text-theme-fdd mb-4 border-b border-theme-bd pb-2">Filter by Subject</p>
        <div id="subject-tabs" class="flex flex-wrap gap-3">
          <!-- Dynamic Pills Injected Here -->
        </div>
      </div>

      <!-- Scores Area (JS-rendered) -->
      <div id="scores-area">
        <div class="p-8 text-center text-theme-fdd border-2 border-dashed border-theme-bd rounded-2xl font-mono text-sm uppercase tracking-widest">Select a subject to view your scores.</div>
      </div>
    </div>
  </div>

  <div id="scores-data" data-scores='<%- JSON.stringify(scoresBySubject) %>'></div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const tabs = document.getElementById("subject-tabs");
      const scoresArea = document.getElementById("scores-area");
      const scoresData = JSON.parse(document.getElementById("scores-data").dataset.scores);
      const studentBatchName = "<%= student.batch ? student.batch.name : '' %>";
      
      const subjects = typeof getSubjectsForBatch !== 'undefined' ? getSubjectsForBatch(studentBatchName) : [];
      let tabsHtml = `<button class="tab-pill active" data-subject="overall">📋 Overall</button>`;
      subjects.forEach(sub => {
        tabsHtml += `<button class="tab-pill" data-subject="${sub}">📚 ${sub}</button>`;
      });
      tabs.innerHTML = tabsHtml;

      function getColor(percent) {
        if (percent >= 80) return "progress-bar-good";
        if (percent >= 50) return "progress-bar-average";
        return "progress-bar-poor";
      }

      function getGrade(percent) {
        if (percent >= 90) return { label: "A+", bg: "bg-emerald-500/10 border border-emerald-500/30", text: "text-emerald-500" };
        if (percent >= 80) return { label: "A",  bg: "bg-emerald-500/10 border border-emerald-500/30", text: "text-emerald-500" };
        if (percent >= 70) return { label: "B+", bg: "bg-blue-500/10 border border-blue-500/30",  text: "text-blue-500"  };
        if (percent >= 60) return { label: "B",  bg: "bg-blue-500/10 border border-blue-500/30",  text: "text-blue-500"  };
        if (percent >= 50) return { label: "C",  bg: "bg-amber-500/10 border border-amber-500/30",text: "text-amber-500"};
        return { label: "D", bg: "bg-red-500/10 border border-red-500/30", text: "text-red-500" };
      }

      function render(subject) {
        let tests = [];
        if (subject === "overall") {
          for (const key in scoresData) {
            const arr = scoresData[key] || [];
            arr.forEach(t => { if (!t.subject) t.subject = key; tests.push(t); });
          }
          tests.sort((a, b) => {
            const numA = parseInt((a.testName || "").match(/\d+/)?.[0] ?? 0);
            const numB = parseInt((b.testName || "").match(/\d+/)?.[0] ?? 0);
            return numA - numB;
          });
        } else {
          tests = scoresData[subject] || [];
        }

        if (!tests.length) {
          scoresArea.innerHTML = `
            <div class="text-center py-16 border-2 border-dashed border-theme-bd rounded-2xl">
              <div class="text-5xl mb-4 drop-shadow-md">📝</div>
              <h3 class="text-lg font-unbounded font-bold text-theme-fg">No Scores Yet</h3>
              <p class="mt-2 text-theme-fdd font-mono text-xs uppercase tracking-widest">No test scores available for <strong class="text-theme-fd">${subject === 'overall' ? 'any subject' : subject}</strong> yet.</p>
            </div>`;
          return;
        }

        // ── Summary Stats ──
        const totalTests = tests.length;
        const avgPercent = tests.reduce((sum, t) => {
          return sum + ((Number(t.score) / (Number(t.total) || 100)) * 100);
        }, 0) / totalTests;
        const subjectsAttempted = new Set(tests.map(t => t.subject)).size;
        const avgColor = avgPercent >= 80 ? "#10b981" : avgPercent >= 50 ? "#f59e0b" : "#ef4444";

        const summaryHTML = `
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-10">
            <div class="stat-card shadow-inner" style="background: linear-gradient(135deg, rgba(124,58,237,0.1), rgba(124,58,237,0.02)); border-color: rgba(124,58,237,0.2);">
              <p class="text-[10px] font-mono font-bold uppercase tracking-widest text-theme-pt mb-2">Tests Taken</p>
              <p class="text-5xl font-unbounded font-extrabold text-theme-fg drop-shadow-sm">${totalTests}</p>
            </div>
            <div class="stat-card shadow-inner" style="background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(16,185,129,0.02)); border-color: rgba(16,185,129,0.2);">
              <p class="text-[10px] font-mono font-bold uppercase tracking-widest text-emerald-500 mb-2">Average Score</p>
              <p class="text-5xl font-unbounded font-extrabold drop-shadow-sm" style="color:${avgColor}">${avgPercent.toFixed(1)}<span class="text-2xl">%</span></p>
            </div>
            <div class="stat-card shadow-inner" style="background: linear-gradient(135deg, rgba(59,130,246,0.1), rgba(59,130,246,0.02)); border-color: rgba(59,130,246,0.2);">
              <p class="text-[10px] font-mono font-bold uppercase tracking-widest text-blue-500 mb-2">Subjects</p>
              <p class="text-5xl font-unbounded font-extrabold text-theme-fg drop-shadow-sm">${subjectsAttempted}</p>
            </div>
          </div>`;

        // ── Score Cards ──
        const cardsHTML = `
          <h3 class="text-2xl font-unbounded font-extrabold text-theme-pt mb-6 border-b border-theme-bd pb-4 drop-shadow-sm">
            ${subject === "overall" ? "All Test Results" : subject + " — Test Results"}
          </h3>
          <div class="space-y-5">
            ${tests.map(test => {
              const total   = Number(test.total) || 100;
              const score   = Number(test.score) || 0;
              const percent = ((score / total) * 100);
              const colorClass = getColor(percent);
              const grade = getGrade(percent);
              return `
                <div class="score-card p-5 sm:p-6 shadow-sm">
                  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-5">
                    <!-- Left: icon + info -->
                    <div class="flex items-center gap-5 min-w-0">
                      <div class="flex-shrink-0 w-14 h-14 rounded-2xl flex items-center justify-center shadow-inner ${grade.bg}">
                        <span class="font-unbounded font-extrabold text-xl ${grade.text}">${grade.label}</span>
                      </div>
                      <div class="min-w-0">
                        <p class="font-unbounded font-bold text-theme-fg text-lg truncate mb-2">${test.testName || "Test"}</p>
                        <div class="flex flex-wrap items-center gap-3">
                          <span class="text-[10px] font-mono font-bold px-3 py-1 rounded-full bg-theme-p/10 text-theme-pt border border-theme-p/30 uppercase tracking-widest">${test.subject}</span>
                          ${test.topic ? `<span class="text-xs font-mono text-theme-fd uppercase tracking-wide">TOPIC: <span class="font-bold text-theme-fg">${test.topic}</span></span>` : ""}
                        </div>
                      </div>
                    </div>
                    <!-- Right: score + Q.Paper -->
                    <div class="flex-shrink-0 flex flex-col sm:items-end items-start gap-2 sm:mt-0 mt-4 border-t sm:border-t-0 border-theme-bd pt-4 sm:pt-0">
                      <div class="flex items-center gap-4 w-full sm:w-auto justify-between sm:justify-end">
                        ${test.questionPaper ? `<a href="${test.questionPaper}" target="_blank" class="qp-btn"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>Q. Paper</a>` : ""}
                        <div class="text-right">
                           <p class="text-3xl font-unbounded font-extrabold text-theme-fg leading-none drop-shadow-sm">${score}<span class="text-sm font-mono font-bold text-theme-fd uppercase tracking-widest ml-1">/ ${total}</span></p>
                           <p class="text-xs font-mono font-bold uppercase tracking-widest mt-1" style="color: ${percent >= 80 ? '#10b981' : percent >= 50 ? '#f59e0b' : '#ef4444'}">${percent.toFixed(1)}% SCORE</p>
                        </div>
                      </div>
                    </div>
                  </div>
                  <!-- Progress bar -->
                  <div class="progress-track mt-6">
                    <div class="${colorClass} progress-bar" data-width="${percent.toFixed(2)}"></div>
                  </div>
                </div>`;
            }).join("")}
          </div>`;

        scoresArea.innerHTML = summaryHTML + cardsHTML;

        scoresArea.querySelectorAll(".progress-bar").forEach((bar, i) => {
          setTimeout(() => bar.style.width = `${bar.dataset.width}%`, 50 + i * 50);
        });
      }

      tabs.addEventListener("click", (e) => {
        const btn = e.target.closest(".tab-pill");
        if (btn) {
          tabs.querySelectorAll(".tab-pill").forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
          render(btn.dataset.subject);
        }
      });

      const active = tabs.querySelector(".tab-pill.active");
      if (active) render(active.dataset.subject);
    });
  </script>
</body>

</html>