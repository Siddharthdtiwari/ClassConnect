<%- include('../partials/background') %>
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Exam Timetable | <%= student.studentName %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: "Inter", sans-serif; }
    .text-brand-purple { color: #5d3a9b; }
    .bg-brand-purple-light { background-color: #f3e8ff; }
    .premium-banner {
      background: linear-gradient(135deg, #4b2d84 0%, #7c52ca 100%);
      color: white;
      box-shadow: 0 10px 25px -5px rgba(93, 58, 155, 0.3);
    }
    .glass-profile {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.5);
      box-shadow: 0 4px 30px rgba(93, 58, 155, 0.08);
    }
    .tab-btn {
      padding: 0.5rem 1.5rem;
      border-radius: 9999px;
      font-weight: 600;
      font-size: 0.875rem;
      border: 2px solid #e5e7eb;
      color: #6b7280;
      background: white;
      transition: all 0.25s ease;
      cursor: pointer;
    }
    .tab-btn:hover { border-color: #5d3a9b; color: #5d3a9b; background: #f3e8ff; }
    .tab-btn.active { background: #5d3a9b; color: white; border-color: #5d3a9b; box-shadow: 0 4px 14px rgba(93,58,155,0.35); }
    .content-card {
      transition: all 0.3s ease;
      border-radius: 12px;
      border: 1px solid #e5e7eb;
      background: white;
    }
    .content-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 24px -5px rgba(93, 58, 155, 0.12);
      border-color: rgba(93, 58, 155, 0.25);
    }
    .btn-action {
      background: #5d3a9b; color: white; font-weight: 600; font-size: 0.8rem;
      padding: 0.45rem 1.1rem; border-radius: 9999px; display: inline-flex;
      align-items: center; gap: 0.35rem; transition: all 0.2s ease;
      box-shadow: 0 2px 8px rgba(93,58,155,0.25); white-space: nowrap;
    }
    .btn-action:hover { background: #4b2d84; transform: translateY(-1px); box-shadow: 0 4px 14px rgba(93,58,155,0.3); }
    .btn-edit {
      font-size: 0.78rem; font-weight: 600; padding: 0.3rem 0.85rem; border-radius: 9999px;
      border: 1px solid #e9d5ff; color: #5d3a9b; background: #f5f3ff; transition: all 0.2s;
    }
    .btn-edit:hover { background: #5d3a9b; color: white; }
    .btn-delete {
      font-size: 0.78rem; font-weight: 600; padding: 0.3rem 0.85rem; border-radius: 9999px;
      border: 1px solid #fee2e2; color: #dc2626; background: #fef2f2; transition: all 0.2s;
    }
    .btn-delete:hover { background: #dc2626; color: white; }
    .badge { display: inline-flex; align-items: center; padding: 2px 10px; border-radius: 9999px; font-size: 0.72rem; font-weight: 700; }
    .badge-ut1  { background:#dbeafe; color:#1e40af; }
    .badge-ut2  { background:#fce7f3; color:#9d174d; }
    .badge-sem1 { background:#d1fae5; color:#065f46; }
    .badge-sem2 { background:#fef3c7; color:#92400e; }
    .badge-ct   { background:#ede9fe; color:#5b21b6; }
    /* ===== PREMIUM MODAL ===== */
    .modal-overlay { position:fixed; inset:0; background:rgba(17,7,35,0.6); backdrop-filter:blur(8px); z-index:50; display:none; align-items:center; justify-content:center; padding:1rem; }
    .modal-overlay.open { display:flex; }
    .modal-box { background:white; border-radius:1.5rem; overflow:hidden; width:100%; max-width:580px; box-shadow:0 32px 64px -12px rgba(75,45,132,0.45); animation:pop 0.25s cubic-bezier(.34,1.56,.64,1); max-height:92vh; display:flex; flex-direction:column; }
    .modal-header { background:linear-gradient(135deg,#3b1f72 0%,#6d3fc4 100%); padding:1.75rem 2rem; color:white; flex-shrink:0; }
    .modal-body { padding:1.75rem 2rem; overflow-y:auto; flex:1; }
    @keyframes pop { from{transform:scale(0.88) translateY(16px);opacity:0} to{transform:scale(1) translateY(0);opacity:1} }
    .etype-pill { cursor:pointer; padding:0.45rem 1rem; border-radius:9999px; font-size:0.82rem; font-weight:700; border:2px solid #e5e7eb; color:#6b7280; background:white; transition:all 0.2s; }
    .etype-pill:hover { border-color:#7c52ca; color:#5d3a9b; background:#f5f3ff; }
    .etype-pill.selected { background:linear-gradient(135deg,#5d3a9b,#7c52ca); color:white; border-color:transparent; box-shadow:0 4px 12px rgba(93,58,155,0.4); transform:translateY(-1px); }
    .subject-row-premium { background:#faf8ff; border:1px solid #ede9fe; border-radius:0.875rem; padding:0.75rem 1rem; display:grid; grid-template-columns:1.5rem 1fr 1fr 1fr auto; gap:0.6rem; align-items:center; transition:border 0.2s; }
    .subject-row-premium:focus-within { border-color:#7c52ca; box-shadow:0 0 0 3px rgba(124,82,202,0.12); }
    @media(max-width:540px) {
      .subject-row-premium { grid-template-columns:1fr 1fr auto; grid-template-rows:auto auto; padding-top:0.65rem; }
      .subject-row-premium .row-num { display:none; }
      .subject-row-premium input:nth-child(2) { grid-column:1/3; grid-row:1; }
      .subject-row-premium button:last-child { grid-column:3; grid-row:1; }
      .subject-row-premium input:nth-child(3) { grid-column:1; grid-row:2; }
      .subject-row-premium input:nth-child(4) { grid-column:2/4; grid-row:2; }
    }
    .row-num { width:1.5rem; height:1.5rem; border-radius:9999px; background:linear-gradient(135deg,#5d3a9b,#a855f7); color:white; display:flex; align-items:center; justify-content:center; font-size:0.7rem; font-weight:800; flex-shrink:0; }
    .srow-input { border:none; background:transparent; padding:0.35rem 0.5rem; font-size:0.85rem; font-weight:500; border-bottom:1.5px solid #e5e7eb; border-radius:0; width:100%; transition:border-color 0.2s; }
    .srow-input:focus { outline:none; border-bottom-color:#7c52ca; }
    .add-row-btn { border:2px dashed #d8b4fe; border-radius:0.875rem; padding:0.65rem; text-align:center; color:#7c52ca; font-size:0.82rem; font-weight:700; cursor:pointer; transition:all 0.2s; margin-top:0.5rem; }
    .add-row-btn:hover { background:#f5f3ff; border-color:#7c52ca; }
    .btn-glow { background:linear-gradient(135deg,#5d3a9b 0%,#7c52ca 100%); color:white; font-weight:800; font-size:0.95rem; padding:0.9rem; border-radius:0.875rem; width:100%; transition:all 0.25s; box-shadow:0 4px 20px rgba(93,58,155,0.45); letter-spacing:0.01em; }
    .btn-glow:hover { box-shadow:0 8px 32px rgba(93,58,155,0.6); transform:translateY(-2px); }
    input, select, textarea { border-radius:0.6rem; border:1px solid #e5e7eb; padding:0.55rem 0.85rem; font-size:0.9rem; transition:border 0.2s, box-shadow 0.2s; }
    input:focus, select:focus, textarea:focus { outline:none; border-color:#5d3a9b; box-shadow:0 0 0 3px rgba(93,58,155,0.15); }
    label { font-size:0.8rem; font-weight:700; color:#374151; display:block; margin-bottom:0.3rem; }
  </style>
</head>

<body class="text-gray-800">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">

    <!-- Premium Banner — Study Materials style -->
    <header class="mb-10 premium-banner rounded-2xl p-6 sm:p-12 text-center relative overflow-hidden">
      <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-white opacity-10"></div>
      <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-48 h-48 rounded-full bg-white opacity-5"></div>
      <div class="relative z-10">
        <!-- Back button top-left -->
        <div class="flex justify-start mb-5">
          <a href="/student/dashboard"
            class="inline-flex items-center text-sm font-bold text-white py-2 px-4 rounded-full shadow-sm transition-all"
            style="border:1px solid rgba(255,255,255,0.4); background:rgba(255,255,255,0.12);"
            onmouseover="this.style.background='white';this.style.color='#5d3a9b';"
            onmouseout="this.style.background='rgba(255,255,255,0.12)';this.style.color='white';">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Back to Dashboard
          </a>
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight mb-2 tracking-tight">
          📅 Exam Timetable
        </h1>
        <p class="text-purple-100 font-medium text-base sm:text-lg">Class <%= student.standard %> — Track your upcoming exams and portions.</p>
      </div>
    </header>

    <!-- Toast Notifications -->
    <% if (success) { %>
    <div id="toast-success" class="mb-6 flex items-center gap-3 bg-green-50 border border-green-200 text-green-800 rounded-xl px-5 py-3 shadow-sm">
      <span class="text-lg">✅</span><span class="font-semibold text-sm"><%= success %></span>
    </div>
    <% } %>
    <% if (error) { %>
    <div id="toast-error" class="mb-6 flex items-center gap-3 bg-red-50 border border-red-200 text-red-800 rounded-xl px-5 py-3 shadow-sm">
      <span class="text-lg">❌</span><span class="font-semibold text-sm"><%= error %></span>
    </div>
    <% } %>

    <!-- Glass Container -->
    <div class="glass-profile p-6 sm:p-8 rounded-2xl mb-10">

      <!-- Top row: filter label + Add button -->
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3">Filter by Exam Type</p>
          <div id="exam-tabs" class="flex flex-wrap gap-3">
            <button class="tab-btn active" data-type="All">🗓 All Exams</button>
            <button class="tab-btn" data-type="Unit Test 1">Unit Test 1</button>
            <button class="tab-btn" data-type="Unit Test 2">Unit Test 2</button>
            <button class="tab-btn" data-type="Semester 1">Semester 1</button>
            <button class="tab-btn" data-type="Semester 2">Semester 2</button>
            <button class="tab-btn" data-type="Class Test">Class Test</button>
          </div>
        </div>
        <button onclick="openAddModal()" class="btn-action self-start sm:self-auto shrink-0">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add Exams
        </button>
      </div>

      <!-- Entry Cards -->
      <% if (entries.length === 0) { %>
      <div class="flex flex-col items-center justify-center py-20 text-center">
        <div class="text-6xl mb-4">📋</div>
        <p class="text-xl font-bold text-gray-700 mb-2">No Exam Entries Yet</p>
        <p class="text-gray-400 text-sm">Click <strong>"+ Add Exams"</strong> to schedule your first exam.</p>
      </div>
      <% } else { %>
      <div class="flex flex-col gap-3" id="entries-list">
        <% entries.forEach(entry => {
          const typeMap = { 'Unit Test 1':'badge-ut1','Unit Test 2':'badge-ut2','Semester 1':'badge-sem1','Semester 2':'badge-sem2','Class Test':'badge-ct' };
          const badgeClass = typeMap[entry.examType] || 'badge-ct';
          const formattedDate = new Date(entry.examDate).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'});
          const inputDate = new Date(entry.examDate).toISOString().split('T')[0];
          const isPast = new Date(entry.examDate) < new Date();
        %>
        <div class="content-card p-4 sm:p-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 <%= isPast ? 'opacity-60' : '' %>" data-type="<%= entry.examType %>">
          <div class="flex items-center gap-4 min-w-0 flex-1">
            <div class="flex-shrink-0 w-12 h-12 flex items-center justify-center rounded-xl bg-purple-50 text-2xl">
              <%= entry.examType === 'Semester 1' || entry.examType === 'Semester 2' ? '📝' : entry.examType === 'Class Test' ? '✍️' : '📖' %>
            </div>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 flex-wrap mb-1">
                <span class="badge <%= badgeClass %>"><%= entry.examType %></span>
                <% if (isPast) { %><span class="badge" style="background:#f3f4f6;color:#6b7280">Past</span><% } %>
              </div>
              <p class="font-bold text-gray-900 text-base leading-snug"><%= entry.subject %></p>
              <p class="text-sm text-gray-400 mt-0.5">
                📅 <span class="font-semibold text-gray-600"><%= formattedDate %></span>
                &nbsp;·&nbsp; 📚 Chapters: <span class="font-semibold text-gray-600"><%= entry.chapters %></span>
              </p>
              <p class="text-xs text-gray-400 mt-1">
                <%= entry.addedBy === 'teacher' ? '👩‍🏫' : '🎓' %> Added by <span class="font-semibold"><%= entry.addedByName %></span>
              </p>
            </div>
          </div>
          <div class="flex items-center gap-2 flex-shrink-0">
            <button onclick="openEditModal(this)"
              data-id="<%= entry._id %>"
              data-examtype="<%= entry.examType %>"
              data-subject="<%= entry.subject %>"
              data-date="<%= inputDate %>"
              data-chapters="<%= entry.chapters %>"
              class="btn-edit">✏️ Edit</button>
            <form method="POST" action="/student/timetable/delete/<%= entry._id %>" onsubmit="return confirm('Delete this entry?')">
              <button type="submit" class="btn-delete">🗑️</button>
            </form>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>
  </div>

  <!-- =================== ADD MODAL PREMIUM =================== -->
  <div class="modal-overlay" id="add-modal">
    <div class="modal-box">
      <!-- Gradient Header -->
      <div class="modal-header">
        <div class="flex justify-between items-start">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-2xl">📅</span>
              <h2 class="text-2xl font-extrabold tracking-tight">Schedule Exams</h2>
            </div>
            <p class="text-purple-200 text-sm">Add multiple subjects at once for any exam type</p>
          </div>
          <button onclick="closeModal('add-modal')" class="text-white/60 hover:text-white text-3xl font-light leading-none mt-1">&times;</button>
        </div>
      </div>

      <!-- Body -->
      <div class="modal-body">
        <form method="POST" action="/student/timetable/bulk" id="add-form-student" onsubmit="return validateStudentForm()">
          <!-- Step 1: Exam Type -->
          <div class="mb-6">
            <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3">① Select Exam Type</p>
            <div class="flex flex-wrap gap-2" id="etype-pills">
              <% [['Unit Test 1','🧪'],['Unit Test 2','🧫'],['Semester 1','📘'],['Semester 2','📗'],['Class Test','✍️']].forEach(([t,icon]) => { %>
              <button type="button" class="etype-pill" data-val="<%= t %>" onclick="selectEtype(this)"><%= icon %> <%= t %></button>
              <% }) %>
            </div>
            <input type="hidden" name="examType" id="hidden-examType" />
          </div>

          <!-- Step 2: Subjects -->
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3">② Add Subjects &amp; Dates</p>
            <div id="subject-rows" class="space-y-2.5"></div>
            <div class="add-row-btn mt-3" onclick="addSubjectRow()">
              ＋ Add another subject
            </div>
          </div>

          <button type="submit" class="btn-glow mt-7">Save All Exams ✓</button>
        </form>
      </div>
    </div>
  </div>

  <!-- =================== EDIT MODAL =================== -->
  <div class="modal-overlay" id="edit-modal">
    <div class="modal-box p-6 sm:p-8">
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-xl font-extrabold text-brand-purple">✏️ Edit Exam Entry</h2>
        <button onclick="closeModal('edit-modal')" class="text-gray-400 hover:text-gray-700 text-2xl font-bold leading-none">&times;</button>
      </div>
      <form method="POST" id="edit-form" class="space-y-5">
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-1" for="edit-examType">Exam Type</label>
          <select id="edit-examType" name="examType" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-300 focus:border-purple-400 transition-all font-medium text-gray-800" required>
            <option>Unit Test 1</option><option>Unit Test 2</option>
            <option>Semester 1</option><option>Semester 2</option><option>Class Test</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-1" for="edit-subject">Subject</label>
          <select id="edit-subject" name="subject" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-300 focus:border-purple-400 transition-all font-medium text-gray-800" required>
            <option value="English">English</option>
            <option value="Maths I">Maths I</option>
            <option value="Maths II">Maths II</option>
            <option value="Science I">Science I</option>
            <option value="Science II">Science II</option>
            <option value="History-Civics">History-Civics</option>
            <option value="Geography">Geography</option>
            <option value="Hindi">Hindi</option>
            <option value="Marathi">Marathi</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-1" for="edit-examDate">Exam Date</label>
          <input id="edit-examDate" name="examDate" type="date" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-300 focus:border-purple-400 transition-all font-medium text-gray-800" required />
        </div>
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-1" for="edit-chapters">Chapters / Portions</label>
          <textarea id="edit-chapters" name="chapters" rows="2" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-300 focus:border-purple-400 transition-all font-medium text-gray-800" required></textarea>
        </div>
        <button type="submit" class="w-full py-3 mt-4 btn-solid-purple rounded-xl font-bold shadow-md hover:shadow-lg transition-all text-lg tracking-wide justify-center">Update Exam ✓</button>
      </form>
    </div>
  </div>

  <script>
    function openAddModal() {
      document.getElementById('subject-rows').innerHTML = '';
      // reset pills
      document.querySelectorAll('.etype-pill').forEach(p => p.classList.remove('selected'));
      document.getElementById('hidden-examType').value = '';
      addSubjectRow();
      document.getElementById('add-modal').classList.add('open');
    }
    function selectEtype(pill) {
      document.querySelectorAll('.etype-pill').forEach(p => p.classList.remove('selected'));
      pill.classList.add('selected');
      document.getElementById('hidden-examType').value = pill.dataset.val;
    }
    function addSubjectRow() {
      const rows = document.getElementById('subject-rows');
      const num = rows.children.length + 1;
      const div = document.createElement('div');
      div.className = 'subject-row-premium';
      div.innerHTML = `
        <span class="row-num">${num}</span>
        <select name="subjects[]" required class="srow-input cursor-pointer bg-transparent">
          <option value="" disabled selected>Select Subject...</option>
          <option value="English">English</option>
          <option value="Maths I">Maths I</option>
          <option value="Maths II">Maths II</option>
          <option value="Science I">Science I</option>
          <option value="Science II">Science II</option>
          <option value="History-Civics">History-Civics</option>
          <option value="Geography">Geography</option>
          <option value="Hindi">Hindi</option>
          <option value="Marathi">Marathi</option>
        </select>
        <input name="dates[]" type="date" required class="srow-input" />
        <input name="chapters[]" type="text" placeholder="Ch. 1, 2…" class="srow-input" />
        <button type="button" onclick="removeRow(this)" class="text-red-300 hover:text-red-500 text-xl font-bold leading-none flex-shrink-0">&times;</button>`;
      rows.appendChild(div);
      renumberRows();
    }
    function removeRow(btn) {
      btn.closest('.subject-row-premium').remove();
      renumberRows();
    }
    function renumberRows() {
      document.querySelectorAll('#subject-rows .row-num').forEach((el,i) => el.textContent = i+1);
    }
    function validateStudentForm() {
      if (!document.getElementById('hidden-examType').value) {
        alert("Please select an Exam Type (e.g. Unit Test 1) before saving.");
        return false;
      }
      return true;
    }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }
    function openEditModal(btn) {
      const form = document.getElementById('edit-form');
      form.action = '/student/timetable/edit/' + btn.dataset.id;
      document.getElementById('edit-examType').value = btn.dataset.examtype;
      document.getElementById('edit-subject').value = btn.dataset.subject;
      document.getElementById('edit-examDate').value = btn.dataset.date;
      document.getElementById('edit-chapters').value = btn.dataset.chapters;
      document.getElementById('edit-modal').classList.add('open');
    }
    document.querySelectorAll('.modal-overlay').forEach(o => o.addEventListener('click', function(e){ if(e.target===this) closeModal(this.id); }));

    // Tab filtering
    document.getElementById('exam-tabs').addEventListener('click', function(e) {
      const btn = e.target.closest('.tab-btn');
      if (!btn) return;
      this.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const type = btn.dataset.type;
      document.querySelectorAll('#entries-list [data-type]').forEach(row => {
        row.style.display = (type === 'All' || row.dataset.type === type) ? '' : 'none';
      });
    });

    // Auto-dismiss toasts
    setTimeout(() => {
      ['toast-success','toast-error'].forEach(id => { const el=document.getElementById(id); if(el) el.style.display='none'; });
    }, 4000);
  </script>
</body>
</html>
