<!DOCTYPE html>
<html lang="en" data-theme="light">
<%- include('../partials/background') %>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Exam Timetable | Tuition Hub</title>
  <script src="/js/subjects.js"></script>
  <style>
    .premium-banner {
      background: linear-gradient(135deg, var(--p) 0%, var(--pm) 100%);
      box-shadow: 0 10px 30px var(--pg);
    }
    
    .tab-btn {
      padding: 0.5rem 1.25rem;
      border-radius: 9999px;
      font-weight: 700;
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      border: 1px solid var(--b);
      color: var(--fd);
      background: var(--bgc);
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      cursor: pointer;
    }
    .tab-btn:hover { border-color: var(--p); color: var(--pt); background: var(--bgch); transform: translateY(-2px); }
    .tab-btn.active { background: var(--p); color: white; border-color: var(--p); box-shadow: 0 4px 15px var(--pg); }
    
    .content-card {
      transition: all 0.3s ease;
      border-radius: 16px;
      border: 1px solid var(--b);
      background: var(--bgc);
    }
    .content-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 30px var(--pg);
      border-color: var(--p);
      background: var(--bgch);
    }
    
    .badge { display: inline-flex; align-items: center; padding: 4px 12px; border-radius: 9999px; font-size: 0.65rem; font-family: 'Space Mono', monospace; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; }
    .badge-ut1  { background: rgba(59,130,246,0.1); color: #3b82f6; border: 1px solid rgba(59,130,246,0.3); }
    .badge-ut2  { background: rgba(236,72,153,0.1); color: #ec4899; border: 1px solid rgba(236,72,153,0.3); }
    .badge-sem1 { background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.3); }
    .badge-sem2 { background: rgba(245,158,11,0.1); color: #f59e0b; border: 1px solid rgba(245,158,11,0.3); }
    .badge-ct   { background: var(--bg); color: var(--pt); border: 1px solid var(--b); }
    
    /* ===== PREMIUM MODAL ===== */
    .modal-overlay { position:fixed; inset:0; background:rgba(17,7,35,0.6); backdrop-filter:blur(10px); z-index:50; display:none; align-items:center; justify-content:center; padding:1rem; }
    .modal-overlay.open { display:flex; }
    .modal-box { background:var(--bgc); border:1px solid var(--b); border-radius:1.5rem; overflow:hidden; width:100%; max-width:600px; box-shadow:0 32px 64px -12px rgba(0,0,0,0.3); animation:pop 0.3s cubic-bezier(.34,1.56,.64,1); max-height:92vh; display:flex; flex-direction:column; }
    .modal-header { background:linear-gradient(135deg, var(--p) 0%, var(--pm) 100%); padding:2rem; color:white; flex-shrink:0; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .modal-body { padding:2rem; overflow-y:auto; flex:1; }
    @keyframes pop { from{transform:scale(0.95) translateY(20px);opacity:0} to{transform:scale(1) translateY(0);opacity:1} }
    
    .etype-pill { cursor:pointer; padding:0.6rem 1.25rem; border-radius:9999px; font-size:0.7rem; font-family: 'Space Mono', monospace; font-weight:700; text-transform: uppercase; letter-spacing: 0.1em; border:1px solid var(--b); color:var(--fd); background:var(--bg); transition:all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .etype-pill:hover { border-color:var(--p); color:var(--pt); background:var(--bgch); transform: translateY(-2px); }
    .etype-pill.selected { background:var(--p); color:white; border-color:var(--p); box-shadow:0 4px 15px var(--pg); transform:translateY(-2px); }
    
    .subject-row-premium { background:var(--bg); border:1px solid var(--b); border-radius:1rem; padding:1rem; display:grid; grid-template-columns:2rem 1fr 1fr 1fr auto; gap:0.75rem; align-items:center; transition:all 0.2s; margin-bottom: 0.75rem; }
    .subject-row-premium:focus-within { border-color:var(--p); box-shadow:0 0 0 3px var(--pg); background:var(--bgc); }
    @media(max-width:540px) {
      .subject-row-premium { grid-template-columns:1fr 1fr auto; grid-template-rows:auto auto; padding:1rem; }
      .subject-row-premium .row-num { display:none; }
      .subject-row-premium *:nth-child(2) { grid-column:1/3; grid-row:1; }
      .subject-row-premium *:nth-child(5) { grid-column:3; grid-row:1; }
      .subject-row-premium *:nth-child(3) { grid-column:1; grid-row:2; }
      .subject-row-premium *:nth-child(4) { grid-column:2/4; grid-row:2; }
    }
    
    .row-num { width:2rem; height:2rem; border-radius:9999px; background:var(--p); color:white; display:flex; align-items:center; justify-content:center; font-family: 'Space Mono', monospace; font-size:0.7rem; font-weight:800; flex-shrink:0; box-shadow: 0 2px 8px var(--pg); }
    .srow-input { border:none; background:transparent; padding:0.5rem; font-size:0.85rem; font-weight:600; font-family: 'Inter', sans-serif; color: var(--fg); border-bottom: 2px solid var(--bd); border-radius:0; width:100%; transition:border-color 0.2s; }
    .srow-input:focus { outline:none; border-bottom-color:var(--p); }
    
    .add-row-btn { border:2px dashed var(--bd); border-radius:1rem; padding:0.85rem; text-align:center; color:var(--pt); font-size:0.75rem; font-family: 'Space Mono', monospace; text-transform: uppercase; letter-spacing: 0.1em; font-weight:700; cursor:pointer; transition:all 0.2s; margin-top:1rem; background: var(--bg); }
    .add-row-btn:hover { background:var(--bgch); border-color:var(--p); color: var(--p); transform: translateY(-1px); }
    
    input, select, textarea { border-radius:0.75rem; border:1px solid var(--b); padding:0.75rem 1rem; font-size:0.9rem; color: var(--fg); background: var(--bgc); transition:all 0.2s; font-family: 'Inter', sans-serif; font-weight: 500; }
    input:focus, select:focus, textarea:focus { outline:none; border-color:var(--p); box-shadow:0 0 0 3px var(--pg); }
    label { font-size:0.7rem; font-family: 'Space Mono', monospace; text-transform: uppercase; letter-spacing: 0.1em; font-weight:700; color:var(--fd); display:block; margin-bottom:0.5rem; }
  </style>
</head>

<body class="text-theme-fg wrap">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">

    <!-- Premium Banner Header -->
    <header class="mb-10 premium-banner rounded-2xl p-6 sm:p-12 text-center relative overflow-hidden">
      <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-white opacity-10"></div>
      <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-48 h-48 rounded-full bg-white opacity-5"></div>
      <div class="relative z-10">
        <div class="flex justify-center sm:justify-start mb-6">
          <a href="/student/dashboard" class="btn-outline bg-white/10 border-white/20 text-white hover:bg-white hover:text-theme-pt">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Dashboard
          </a>
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-unbounded font-extrabold text-white leading-tight mb-2 tracking-tight">
          Exam <span class="text-theme-lt">Timetable</span>
        </h1>
        <p class="text-white/80 font-mono tracking-widest text-xs uppercase mt-4">Batch: <strong class="text-white"><%= student.batch ? student.batch.name : 'Unassigned' %></strong> — Track your upcoming exams</p>
      </div>
    </header>

    <!-- Toast Notifications -->
    <% if (success) { %>
    <div id="toast-success" class="mb-8 flex items-center gap-4 bg-emerald-500/10 border border-emerald-500/30 text-emerald-600 rounded-2xl px-6 py-4 shadow-sm backdrop-blur-md">
      <span class="text-xl drop-shadow-sm">✅</span><span class="font-bold font-mono text-sm uppercase tracking-wide"><%= success %></span>
    </div>
    <% } %>
    <% if (error) { %>
    <div id="toast-error" class="mb-8 flex items-center gap-4 bg-red-500/10 border border-red-500/30 text-red-600 rounded-2xl px-6 py-4 shadow-sm backdrop-blur-md">
      <span class="text-xl drop-shadow-sm">❌</span><span class="font-bold font-mono text-sm uppercase tracking-wide"><%= error %></span>
    </div>
    <% } %>

    <!-- Glass Container -->
    <div class="glass-card p-6 sm:p-10 rounded-2xl mb-10">

      <!-- Top row: filter label + Add button -->
      <div class="flex flex-col xl:flex-row xl:items-end justify-between gap-6 mb-10 border-b border-theme-bd pb-6">
        <div>
          <p class="text-xs font-mono font-bold uppercase tracking-widest text-theme-fdd mb-4">Filter by Exam Type</p>
          <div id="exam-tabs" class="flex flex-wrap gap-3">
            <button class="tab-btn active" data-type="All">🗓 All Exams</button>
            <button class="tab-btn" data-type="Unit Test 1">Unit Test 1</button>
            <button class="tab-btn" data-type="Unit Test 2">Unit Test 2</button>
            <button class="tab-btn" data-type="Semester 1">Semester 1</button>
            <button class="tab-btn" data-type="Semester 2">Semester 2</button>
            <button class="tab-btn" data-type="Class Test">Class Test</button>
          </div>
        </div>
        <button onclick="openAddModal()" class="btn-primary shrink-0 py-3 px-6 shadow-lg">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
          Add Exams
        </button>
      </div>

      <!-- Entry Cards -->
      <% if (entries.length === 0) { %>
      <div class="flex flex-col items-center justify-center py-20 text-center border-2 border-dashed border-theme-bd rounded-2xl">
        <div class="text-5xl mb-6 drop-shadow-md">📋</div>
        <p class="text-xl font-unbounded font-extrabold text-theme-fg mb-2">No Exam Entries Yet</p>
        <p class="text-theme-fdd font-mono text-xs uppercase tracking-widest">Click <strong class="text-theme-fd">"+ Add Exams"</strong> to schedule your first exam.</p>
      </div>
      <% } else { %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5" id="entries-list">
        <% entries.forEach(entry => {
          const typeMap = { 'Unit Test 1':'badge-ut1','Unit Test 2':'badge-ut2','Semester 1':'badge-sem1','Semester 2':'badge-sem2','Class Test':'badge-ct' };
          const badgeClass = typeMap[entry.examType] || 'badge-ct';
          const formattedDate = new Date(entry.examDate).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}).toUpperCase();
          const inputDate = new Date(entry.examDate).toISOString().split('T')[0];
          const isPast = new Date(entry.examDate) < new Date();
        %>
        <div class="content-card p-6 flex flex-col justify-between gap-5 <%= isPast ? 'opacity-60 grayscale-[30%]' : 'shadow-sm' %>" data-type="<%= entry.examType %>">
          
          <div class="flex items-start justify-between gap-4">
             <div class="flex items-center gap-4 min-w-0">
               <div class="flex-shrink-0 w-14 h-14 flex items-center justify-center rounded-2xl bg-theme-p/10 shadow-inner border border-theme-p/20 text-2xl drop-shadow-sm">
                 <%= entry.examType === 'Semester 1' || entry.examType === 'Semester 2' ? '📝' : entry.examType === 'Class Test' ? '✍️' : '📖' %>
               </div>
               <div class="min-w-0">
                 <p class="font-unbounded font-extrabold text-theme-fg text-lg leading-snug truncate mb-1"><%= entry.subject %></p>
                 <div class="flex items-center gap-2 flex-wrap">
                   <span class="badge <%= badgeClass %>"><%= entry.examType %></span>
                   <% if (isPast) { %><span class="badge bg-theme-bg border border-theme-bd text-theme-fd">Past</span><% } %>
                 </div>
               </div>
             </div>
             
             <div class="flex flex-col gap-2 flex-shrink-0 items-end">
               <button onclick="openEditModal(this)"
                 data-id="<%= entry._id %>"
                 data-examtype="<%= entry.examType %>"
                 data-subject="<%= entry.subject %>"
                 data-date="<%= inputDate %>"
                 data-chapters="<%= entry.chapters %>"
                 class="p-2 rounded-xl bg-theme-bg border border-theme-bd text-theme-fd hover:bg-theme-p hover:text-white hover:border-theme-p transition-all shadow-sm">
                 <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>  
               </button>
               <form method="POST" action="/student/timetable/delete/<%= entry._id %>" onsubmit="return confirm('Delete this entry?')">
                 <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
                 <button type="submit" class="p-2 rounded-xl bg-red-500/10 border border-red-500/30 text-red-500 hover:bg-red-500 hover:text-white transition-all shadow-sm">
                   <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                 </button>
               </form>
             </div>
          </div>

          <div class="bg-theme-bg p-4 rounded-xl border border-theme-bd flex flex-col gap-2 mt-2 shadow-inner">
             <div class="flex justify-between items-center font-mono text-xs">
                <span class="text-theme-fd uppercase tracking-widest font-bold">Date</span>
                <span class="text-theme-fg font-bold bg-theme-bgc px-2 py-1 rounded border border-theme-b"><%= formattedDate %></span>
             </div>
             <div class="flex justify-between items-center font-mono text-xs">
                <span class="text-theme-fd uppercase tracking-widest font-bold">Chapters</span>
                <span class="text-theme-fg font-bold truncate max-w-[60%] text-right"><%= entry.chapters %></span>
             </div>
          </div>
          
          <div class="mt-1">
             <p class="text-[10px] font-mono uppercase tracking-widest text-theme-fdd text-right">
               ADDED BY <span class="font-bold text-theme-fd"><%= entry.addedByName %></span> <%= entry.addedBy === 'teacher' ? '👩‍🏫' : '🎓' %>
             </p>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>
  </div>

  <!-- =================== ADD MODAL PREMIUM =================== -->
  <div class="modal-overlay" id="add-modal">
    <div class="modal-box">
      <!-- Gradient Header -->
      <div class="modal-header">
        <div class="flex justify-between items-start">
          <div>
            <div class="flex items-center gap-3 mb-2">
              <span class="text-3xl drop-shadow-md">📅</span>
              <h2 class="text-2xl font-unbounded font-extrabold tracking-tight">Schedule Exams</h2>
            </div>
            <p class="text-white/80 font-mono text-xs uppercase tracking-widest">Add multiple subjects at once</p>
          </div>
          <button onclick="closeModal('add-modal')" class="text-white/60 hover:text-white text-3xl font-light leading-none mt-1 transition-colors">&times;</button>
        </div>
      </div>

      <!-- Body -->
      <div class="modal-body">
        <form method="POST" action="/student/timetable/bulk" id="add-form-student" onsubmit="return validateStudentForm()">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
          <!-- Step 1: Exam Type -->
          <div class="mb-8">
            <p class="text-[10px] font-mono font-bold uppercase tracking-widest text-theme-fdd mb-4 border-b border-theme-bd pb-2">① Select Exam Type</p>
            <div class="flex flex-wrap gap-3" id="etype-pills">
              <% [['Unit Test 1','🧪'],['Unit Test 2','🧫'],['Semester 1','📘'],['Semester 2','📗'],['Class Test','✍️']].forEach(([t,icon]) => { %>
              <button type="button" class="etype-pill" data-val="<%= t %>" onclick="selectEtype(this)"><%= icon %> <%= t %></button>
              <% }) %>
            </div>
            <input type="hidden" name="examType" id="hidden-examType" />
          </div>

          <!-- Step 2: Subjects -->
          <div>
            <p class="text-[10px] font-mono font-bold uppercase tracking-widest text-theme-fdd mb-4 border-b border-theme-bd pb-2">② Add Subjects &amp; Dates</p>
            <div id="subject-rows"></div>
            <div class="add-row-btn" onclick="addSubjectRow()">
              ＋ Add another subject
            </div>
          </div>

          <button type="submit" class="btn-primary w-full py-4 text-base mt-8 shadow-xl">Save All Exams ✓</button>
        </form>
      </div>
    </div>
  </div>

  <!-- =================== EDIT MODAL =================== -->
  <div class="modal-overlay" id="edit-modal">
    <div class="modal-box">
      <div class="modal-header">
         <div class="flex justify-between items-center">
            <h2 class="text-xl font-unbounded font-extrabold flex items-center gap-2"><span class="text-2xl drop-shadow-md">✏️</span> Edit Exam</h2>
            <button onclick="closeModal('edit-modal')" class="text-white/60 hover:text-white text-3xl font-light leading-none transition-colors">&times;</button>
         </div>
      </div>
      <div class="modal-body">
         <form method="POST" id="edit-form" class="space-y-6">
           <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
           <div>
             <label for="edit-examType">Exam Type</label>
             <select id="edit-examType" name="examType" class="w-full" required>
               <option>Unit Test 1</option><option>Unit Test 2</option>
               <option>Semester 1</option><option>Semester 2</option><option>Class Test</option>
             </select>
           </div>
           <div>
             <label for="edit-subject">Subject</label>
             <select id="edit-subject" name="subject" class="w-full" required>
               <option value="" disabled selected>Select Subject...</option>
             </select>
           </div>
           <div>
             <label for="edit-examDate">Exam Date</label>
             <input id="edit-examDate" name="examDate" type="date" class="w-full" required />
           </div>
           <div>
             <label for="edit-chapters">Chapters / Portions</label>
             <textarea id="edit-chapters" name="chapters" rows="2" class="w-full" required></textarea>
           </div>
           <button type="submit" class="btn-primary w-full py-4 text-base mt-4 shadow-xl">Update Exam ✓</button>
         </form>
      </div>
    </div>
  </div>

  <script>
    const studentBatchName = "<%= student.batch ? student.batch.name : '' %>";

    function openAddModal() {
      document.getElementById('subject-rows').innerHTML = '';
      // reset pills
      document.querySelectorAll('.etype-pill').forEach(p => p.classList.remove('selected'));
      document.getElementById('hidden-examType').value = '';
      addSubjectRow();
      document.getElementById('add-modal').classList.add('open');
    }
    function selectEtype(pill) {
      document.querySelectorAll('.etype-pill').forEach(p => p.classList.remove('selected'));
      pill.classList.add('selected');
      document.getElementById('hidden-examType').value = pill.dataset.val;
    }
    function addSubjectRow() {
      const rows = document.getElementById('subject-rows');
      const num = rows.children.length + 1;
      const div = document.createElement('div');
      div.className = 'subject-row-premium';
      
      const subjectOptions = typeof getSubjectOptionsHtml !== 'undefined' ? getSubjectOptionsHtml(studentBatchName) : '<option value="" disabled selected>Select Subject...</option>';

      div.innerHTML = `
        <span class="row-num">${num}</span>
        <select name="subjects[]" required class="srow-input cursor-pointer">
          ${subjectOptions}
        </select>
        <input name="dates[]" type="date" required class="srow-input" />
        <input name="chapters[]" type="text" placeholder="Ch. 1, 2…" class="srow-input" />
        <button type="button" onclick="removeRow(this)" class="text-red-400 hover:text-red-600 hover:bg-red-500/10 p-2 rounded-full text-xl font-bold leading-none flex-shrink-0 transition-colors">&times;</button>`;
      rows.appendChild(div);
      renumberRows();
    }
    function removeRow(btn) {
      btn.closest('.subject-row-premium').remove();
      renumberRows();
    }
    function renumberRows() {
      document.querySelectorAll('#subject-rows .row-num').forEach((el,i) => el.textContent = i+1);
    }
    function validateStudentForm() {
      if (!document.getElementById('hidden-examType').value) {
        alert("Please select an Exam Type (e.g. Unit Test 1) before saving.");
        return false;
      }
      return true;
    }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }
    function openEditModal(btn) {
      const form = document.getElementById('edit-form');
      form.action = '/student/timetable/edit/' + btn.dataset.id;
      document.getElementById('edit-examType').value = btn.dataset.examtype;
      
      const subjectDropdown = document.getElementById('edit-subject');
      if (typeof updateSubjectDropdowns !== 'undefined') {
        updateSubjectDropdowns([subjectDropdown], studentBatchName);
      }
      subjectDropdown.value = btn.dataset.subject;
      
      document.getElementById('edit-examDate').value = btn.dataset.date;
      document.getElementById('edit-chapters').value = btn.dataset.chapters;
      document.getElementById('edit-modal').classList.add('open');
    }
    document.querySelectorAll('.modal-overlay').forEach(o => o.addEventListener('click', function(e){ if(e.target===this) closeModal(this.id); }));

    // Tab filtering
    document.getElementById('exam-tabs').addEventListener('click', function(e) {
      const btn = e.target.closest('.tab-btn');
      if (!btn) return;
      this.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const type = btn.dataset.type;
      document.querySelectorAll('#entries-list [data-type]').forEach(row => {
        row.style.display = (type === 'All' || row.dataset.type === type) ? '' : 'none';
      });
    });

    // Auto-dismiss toasts
    setTimeout(() => {
      ['toast-success','toast-error'].forEach(id => { const el=document.getElementById(id); if(el) el.style.opacity='0'; setTimeout(()=> { if(el) el.style.display='none'; }, 300); });
    }, 4000);
  </script>
</body>
</html>
