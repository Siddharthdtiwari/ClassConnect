<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add Teacher</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;600;900&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <%- include('../partials/background') %>

  <style>
    /* Premium Dashboard Styles */
    .dash-greeting {
      font-family: 'Unbounded', sans-serif;
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.03em;
    }
    .dash-sub {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--fdd);
      margin-top: 8px;
    }
    .stat-card {
      background: var(--bgc);
      backdrop-filter: blur(16px);
      border: 1px solid var(--bd);
      border-radius: 18px;
      padding: 24px;
      transition: all 0.35s cubic-bezier(.34,1.56,.64,1);
      position: relative;
      overflow: hidden;
    }
  </style>
</head>


<body class="text-theme-fg m-0 p-0 overflow-hidden" style="background: var(--bg);">
  <div style="display: flex; height: 100vh; overflow: hidden;">
    <%- include('../partials/teacher_sidebar') %>
    
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
      <main style="flex: 1; overflow-y: auto; overflow-x: hidden;">
        <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
    <header class="mb-10">
      <h1 class="dash-greeting">Add <span style="color: var(--pt);">Teacher</span></h1>
      <p class="dash-sub">Register new faculty to the system</p>
    </header>

    <div class="stat-card p-6 sm:p-10 max-w-xl mx-auto mb-10">
      <div class="mb-8 border-b border-theme-bd pb-6 flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-purple-500/10 flex items-center justify-center text-theme-pt">
          <svg class="w-5 h-5 text-theme-pt" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path></svg>
        </div>
        <h2 class="text-lg font-bold tracking-tight text-theme-fg" style="font-family: 'Unbounded', sans-serif;">Teacher Details</h2>
      </div>

      <form id="add-student-form" class="space-y-6" action="/teacher/add_teacher" method="post">
<input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
        <div>
          <label for="teacherId" class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Teacher ID</label>
          <input type="text" id="teacherId" name="teacherId" placeholder="e.g., THECTH0" class="w-full bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p focus:outline-none py-3 px-4 font-semibold text-sm" />
        </div>
        <div>
          <label for="teacherName" class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Teacher Name</label>
          <input type="text" id="teacherName" name="teacherName" placeholder="e.g., Anaya Patel" class="w-full bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p focus:outline-none py-3 px-4 font-semibold text-sm" />
        </div>
        <div>
          <label for="email" class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Teacher Email</label>
          <input type="email" id="email" name="email" placeholder="abc@gmail.com" class="w-full bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p focus:outline-none py-3 px-4 font-semibold text-sm" />
        </div>
        <div>
          <label for="subjects" class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Subjects</label>
          <input type="text" id="subjects" name="subjects" placeholder="Maths" class="w-full bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p focus:outline-none py-3 px-4 font-semibold text-sm" />
        </div>
        <div>
          <label for="password" class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Password</label>
          <input type="password" id="password" name="password" placeholder="Password" class="w-full bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p focus:outline-none py-3 px-4 font-semibold text-sm" />
        </div>

        <div class="pt-4 flex justify-end gap-4 mt-8">
          <a href="/teacher/dashboard" class="py-3 px-6 rounded-xl text-center font-bold text-theme-fdd hover:text-theme-fg hover:bg-theme-bg2 transition-colors border border-transparent">
            Cancel
          </a>
          <button type="submit" class="btn-solid-purple py-3 px-8 shadow-md">
            Add Teacher
          </button>
        </div>
      </form>

      <div id="message-box" class="mt-6 p-4 rounded-md text-center hidden"></div>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const addForm = document.getElementById("add-student-form");
      const messageBox = document.getElementById("message-box");

      function showMessage(message, type = "success") {
        messageBox.textContent = message;
        messageBox.classList.remove(
          "hidden",
          "bg-red-100",
          "text-red-700",
          "bg-green-100",
          "text-green-700"
        );
        if (type === "success") {
          messageBox.classList.add("bg-green-100", "text-green-700");
        } else if (type === "error") {
          messageBox.classList.add("bg-red-100", "text-red-700");
        }
        messageBox.classList.remove("hidden");
        setTimeout(() => {
          messageBox.classList.add("hidden");
        }, 3000);
      }
    });
  </script>
      </main>
    </div>
  </div>
</body>


</html>