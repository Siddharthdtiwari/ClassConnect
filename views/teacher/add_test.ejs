<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add Test</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script src="/js/subjects.js"></script>
</head>
<%- include('../partials/background') %>


<body class="text-theme-fg m-0 p-0 overflow-hidden" style="background: var(--bg);">
  <div style="display: flex; height: 100vh; overflow: hidden;">
    <%- include('../partials/teacher_sidebar') %>
    
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
      <main style="flex: 1; overflow-y: auto; overflow-x: hidden;">
        <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900">
        Add New Test
      </h1>
      <p class="text-gray-600 mt-1">
        Create a new test and upload the question paper file or provide a link.
      </p>
    </header>

    <div class="glass-card p-6 sm:p-8 max-w-md mx-auto mb-10">
      <form id="add-test-form" class="space-y-6" action="/teacher/add_test?_csrf=<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>" method="POST" enctype="multipart/form-data">
<input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
<input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
        <div>
          <label for="test-name" class="block text-sm font-medium text-gray-700">Test Name</label>
          <input type="text" id="test-name" name="testName" placeholder="e.g., Class Test 1" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-purple focus:ring focus:ring-brand-purple focus:ring-opacity-50" required />
        </div>

        <div>
          <label for="batchId" class="block text-sm font-medium text-gray-700">Batch</label>
          
          <select id="batchId" name="batchId" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-purple focus:ring focus:ring-brand-purple focus:ring-opacity-50" required onchange="handleBatchChange(this)">
            <option value="" disabled selected>Select Batch</option>
            <% if (typeof batches !== 'undefined' && batches.length > 0) { %>
              <% batches.forEach(batch => { %>
                <option value="<%= batch._id %>"><%= batch.name %> (<%= batch.academicYear %>)</option>
              <% }) %>
            <% } else { %>
              <option value="" disabled>No active batches found</option>
            <% } %>
          </select>

        </div>

        <div>
          <label for="subject" class="block text-sm font-medium text-gray-700">Subject</label>
          <select id="subject" name="subject" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-purple focus:ring focus:ring-brand-purple focus:ring-opacity-50" required>
            <option value="" disabled selected>Select Subject...</option>
          </select>
        </div>

        <div>
          <label for="topic" class="block text-sm font-medium text-gray-700">Topic</label>
          <input type="text" id="topic" name="topic" placeholder="e.g., Chemical Reactions" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-purple focus:ring focus:ring-brand-purple focus:ring-opacity-50" required />
        </div>

        <div>
          <label for="total-marks" class="block text-sm font-medium text-gray-700">Total Marks</label>
          <input type="number" id="total-marks" name="totalMarks" placeholder="e.g., 25" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-purple focus:ring focus:ring-brand-purple focus:ring-opacity-50" required />
        </div>

        <div>
          <label for="test-date" class="block text-sm font-medium text-gray-700">Test Date</label>
          <input type="date" id="test-date" name="testDate" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-brand-purple focus:ring focus:ring-brand-purple focus:ring-opacity-50" />
          <p class="text-xs text-gray-400 mt-1">Optional — the date the test was/will be conducted.</p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">Question Paper (File or Link)</label>

          <div class="mt-1">
            <input type="url" id="question-paper-link" name="questionPaperLink" placeholder="Paste link to question paper (e.g., Google Drive, Dropbox)" class="block w-full rounded-md border-gray-700 shadow-sm focus:border-brand-purple focus:ring focus:ring-brand-purple focus:ring-opacity-50" />
          </div>

          <p class="text-xs text-gray-500 my-2 text-center">OR</p>

          <div>
            <label for="question-paper-file" class="sr-only">Upload Question Paper File</label>
            <input type="file" id="question-paper-file" name="questionPaperFile" class="block w-full text-sm text-gray-700 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-brand-purple file:text-brand-purple hover:file:bg-opacity-80" />
          </div>

          <p id="file-link-warning" class="text-xs text-red-500 mt-2 hidden">
            Please provide either a file or a link.
          </p>
        </div>
        <button type="submit" class="w-full py-3 px-4 btn-solid-purple mt-6 shadow-md">
          Add Test
        </button>
      </form>

      <div id="message-box" class="mt-6 p-4 rounded-md text-center hidden"></div>
    </div>
  </div>

  <script>
    function handleBatchChange(selectEl) {
      const option = selectEl.options[selectEl.selectedIndex];
      const batchName = option ? option.text : '';
      const subjectDropdown = document.getElementById('subject');
      if (typeof updateSubjectDropdowns !== 'undefined') {
        updateSubjectDropdowns([subjectDropdown], batchName);
      }
    }

    document.addEventListener("DOMContentLoaded", () => {
      const addTestForm = document.getElementById("add-test-form");
      const messageBox = document.getElementById("message-box");
      const questionPaperFile = document.getElementById("question-paper-file");
      const questionPaperLink = document.getElementById("question-paper-link");
      const warningMessage = document.getElementById("file-link-warning");

      function showMessage(message, type = "success") {
        messageBox.textContent = message;
        messageBox.classList.remove(
          "hidden",
          "bg-red-100",
          "text-red-700",
          "bg-green-100",
          "text-green-700"
        );
        if (type === "success") {
          messageBox.classList.add("bg-green-100", "text-green-700");
        } else if (type === "error") {
          messageBox.classList.add("bg-red-100", "text-red-700");
        }
        messageBox.classList.remove("hidden");
        setTimeout(() => {
          messageBox.classList.add("hidden");
        }, 3000);
      }

      addTestForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        const isFileProvided = questionPaperFile.files.length > 0;
        const isLinkProvided = questionPaperLink.value.trim() !== "";

        if (!isFileProvided && !isLinkProvided) {
          warningMessage.classList.remove("hidden");
          showMessage("Please provide either a file or a link.", "error");
          return;
        } else {
          warningMessage.classList.add("hidden");
        }

        const formData = new FormData(addTestForm);

        try {
          const res = await fetch("/teacher/add_test", {
            method: "POST",
            body: formData,
          });

          const result = await res.json();

          if (result.success) {
            showMessage(result.message, "success");
            addTestForm.reset();
          } else {
            showMessage(result.message, "error");
          }
        } catch (err) {
          console.error(err);
          showMessage("Error submitting test", "error");
        }
      });
    });
  </script>
      </main>
    </div>
  </div>
</body>


</html>