<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Data Management Audit Trail | Tuition Hub</title>
  <%- include('../partials/background') %>
  <style>
    .dash-greeting {
      font-family: 'Unbounded', sans-serif;
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.03em;
    }
    .dash-sub {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--fdd);
      margin-top: 8px;
    }
    .stat-card {
      background: var(--bgc);
      backdrop-filter: blur(16px);
      border: 1px solid var(--bd);
      border-radius: 18px;
      padding: 24px;
      transition: all 0.35s cubic-bezier(.34,1.56,.64,1);
    }
    .action-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 10px;
      border-radius: 6px;
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .action-create { background: var(--gg); color: var(--gt); border: 1px solid rgba(52, 211, 153, 0.2); }
    .action-update { background: var(--pg2); color: var(--pt); border: 1px solid var(--pg); }
    .action-delete { background: var(--rg); color: var(--rt); border: 1px solid rgba(248, 113, 113, 0.2); }
    .action-repost { background: var(--lg); color: var(--lt); border: 1px solid rgba(189, 224, 69, 0.2); }
    .action-bulk { background: var(--lg); color: var(--lt); border: 1px solid rgba(189, 224, 69, 0.2); }
  </style>
</head>
<body class="text-theme-fg m-0 p-0 overflow-hidden" style="background: var(--bg);">
  <div style="display: flex; height: 100vh; overflow: hidden;">
    <%- include('../partials/teacher_sidebar') %>
    
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden;">
      <main style="flex: 1; overflow-y: auto;">
        <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
          
          <header class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
            <div>
              <div class="flex items-center gap-3 mb-2">
                <a href="/teacher/reports" class="text-theme-fdd hover:text-theme-pt transition-colors">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                </a>
                <h1 class="dash-greeting">Audit <span style="color: var(--pt);">Trail</span></h1>
              </div>
              <p class="dash-sub">Tracking system-wide data changes and administrative actions</p>
            </div>
            
            <form action="/teacher/reports/audit" method="GET" class="flex gap-3">
              <select name="action" class="bg-theme-bgc text-theme-fg border border-theme-b rounded-xl px-4 py-2 text-sm font-semibold focus:outline-none focus:border-theme-p">
                <option value="">All Actions</option>
                <option value="CREATE" <%= queryAction === 'CREATE' ? 'selected' : '' %>>Create</option>
                <option value="UPDATE" <%= queryAction === 'UPDATE' ? 'selected' : '' %>>Update</option>
                <option value="DELETE" <%= queryAction === 'DELETE' ? 'selected' : '' %>>Delete</option>
                <option value="REPOST" <%= queryAction === 'REPOST' ? 'selected' : '' %>>Repost</option>
                <option value="BULK_UPDATE" <%= queryAction === 'BULK_UPDATE' ? 'selected' : '' %>>Bulk Update</option>
              </select>
              
              <select name="entity" class="bg-theme-bgc text-theme-fg border border-theme-b rounded-xl px-4 py-2 text-sm font-semibold focus:outline-none focus:border-theme-p">
                <option value="">All Entities</option>
                <option value="User" <%= queryEntity === 'User' ? 'selected' : '' %>>Students</option>
                <option value="Fee" <%= queryEntity === 'Fee' ? 'selected' : '' %>>Fees</option>
                <option value="Batch" <%= queryEntity === 'Batch' ? 'selected' : '' %>>Batches</option>
                <option value="Test" <%= queryEntity === 'Test' ? 'selected' : '' %>>Tests</option>
                <option value="Score" <%= queryEntity === 'Score' ? 'selected' : '' %>>Scores</option>
                <option value="Attendance" <%= queryEntity === 'Attendance' ? 'selected' : '' %>>Attendance</option>
                <option value="StudyMaterial" <%= queryEntity === 'StudyMaterial' ? 'selected' : '' %>>Study Materials</option>
              </select>
              <button type="submit" class="btn-solid-purple px-4 py-2">Filter</button>
            </form>
          </header>

          <div class="stat-card p-0 overflow-hidden border border-theme-bd">
            <div class="overflow-x-auto">
              <table class="w-full text-left border-collapse">
                <thead>
                  <tr class="bg-theme-bg2 border-b border-theme-bd text-[10px] uppercase font-mono tracking-widest text-theme-fdd">
                    <th class="p-4 font-bold">Date & Time</th>
                    <th class="p-4 font-bold">Action</th>
                    <th class="p-4 font-bold">Entity</th>
                    <th class="p-4 font-bold">Details</th>
                    <th class="p-4 font-bold text-right">Performed By</th>
                  </tr>
                </thead>
                <tbody class="text-sm font-semibold divide-y divide-theme-bd">
                  <% if (logs.length === 0) { %>
                    <tr>
                      <td colspan="5" class="p-8 text-center text-theme-fdd">No audit logs found for this period.</td>
                    </tr>
                  <% } else { %>
                    <% logs.forEach(log => { 
                      let actionClass = 'action-update';
                      if (log.action === 'CREATE') actionClass = 'action-create';
                      if (log.action === 'DELETE') actionClass = 'action-delete';
                      if (log.action === 'REPOST') actionClass = 'action-repost';
                      if (log.action === 'BULK_UPDATE') actionClass = 'action-bulk';
                    %>
                      <tr class="hover:bg-theme-bgch transition-colors group">
                        <td class="p-4">
                          <div class="flex flex-col">
                            <span class="text-theme-fg"><%= new Date(log.createdAt).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) %></span>
                            <span class="text-xs text-theme-fdd font-mono"><%= new Date(log.createdAt).toLocaleTimeString('en-IN', {hour: '2-digit', minute:'2-digit'}) %></span>
                          </div>
                        </td>
                        <td class="p-4">
                          <span class="action-badge <%= actionClass %>"><%= log.action %></span>
                        </td>
                        <td class="p-4 text-theme-fg">
                          <div class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-theme-fdd" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                            <%= log.entityType %>
                          </div>
                        </td>
                        <td class="p-4 text-theme-fg max-w-md">
                          <%= log.details %>
                          <% if (log.entityId) { %>
                            <div class="text-[10px] text-theme-fdd font-mono mt-1">ID: <%= log.entityId %></div>
                          <% } %>
                        </td>
                        <td class="p-4 text-right">
                          <span class="text-xs text-theme-fdd bg-theme-bg2 border border-theme-bd px-2 py-1 rounded-full"><%= log.performedBy %></span>
                        </td>
                      </tr>
                    <% }) %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
</body>
</html>
