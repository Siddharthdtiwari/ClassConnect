<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bulk Import & Edit Students</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.3.2/papaparse.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: "Inter", sans-serif; }
    .bg-brand-background { background-image: linear-gradient(120deg, #f3e8ff 0%, #eef2f3 100%); }
    .text-brand-purple { color: #5d3a9b; }
    
    .btn-solid-purple { background-color: #5d3a9b; color: #fff; transition: all 0.3s; padding: 0.5rem 1rem; border-radius: 0.5rem; font-weight: 600; border: 1px solid #5d3a9b; }
    .btn-solid-purple:hover { background-color: #4b2d84; border-color: #4b2d84; }
    .btn-outline-purple { color: #5d3a9b; border: 1px solid #5d3a9b; padding: 0.5rem 1rem; border-radius: 0.5rem; font-weight: 600; transition: all 0.3s; }
    .btn-outline-purple:hover { background-color: #bde045; color: #333; border-color: #bde045; }
    
    .data-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .data-table thead tr { background: #5d3a9b; color: #fff; }
    .data-table th { padding: 0.75rem 1rem; text-align: left; font-weight: 600; border: 1px solid #4b2d84; white-space: nowrap; }
    .data-table td { padding: 0.4rem 0.5rem; border: 1px solid #d8b4e2; }
    .data-table tbody tr:nth-child(even) { background: #f9f5ff; }
    .data-table tbody tr:hover td { background: #ede9fe; }

    .editable-cell input, .editable-cell select {
      width: 100%; border: 1px solid transparent; padding: 0.25rem; border-radius: 0.25rem; background: transparent; font-size: 0.875rem;
    }
    .editable-cell input:focus, .editable-cell select:focus {
      border-color: #5d3a9b; outline: none; background: white;
    }
    .editable-cell input::placeholder { color: #a1a1aa; }
  </style>
</head>

<%- include('../partials/background') %>

<body class="text-gray-800">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
    <header class="mb-8">
      <a href="/teacher/manage_students" class="text-brand-purple hover:underline mb-4 block">&larr; Back to Manage Students</a>
      <h1 class="text-3xl font-bold text-gray-900">Bulk Import & Edit Students</h1>
      <p class="text-gray-600 mt-1">Upload a CSV file for new students, or mass-edit all your existing students right here.</p>
    </header>

    <!-- SECTION 1: CSV UPLOAD -->
    <div class="bg-white p-6 rounded-xl shadow border border-purple-100 mb-12">
      <h2 class="text-xl font-bold text-gray-800 mb-4">Option A: Upload CSV File</h2>
      <p class="text-sm text-gray-600 mb-4">Your CSV must have exactly these headers (case-sensitive). Passwords default to their mobile number.</p>
      
      <div class="bg-gray-50 rounded p-4 font-mono text-xs text-gray-700 overflow-x-auto mb-4 border border-gray-200">
        studentName,studentId,standard,mobileNo,monthlyFee<br>
        Aarav Shah,1001,10,9876543210,1200<br>
        Priya Patel,1002,10,8765432109,1200
      </div>
      
      <div class="flex flex-col sm:flex-row gap-4 mb-4">
        <a href="data:text/csv;charset=utf-8,studentName,studentId,standard,mobileNo,monthlyFee%0A" download="students_template.csv" class="btn-outline-purple text-sm text-center">
          &#8659; Download Empty Template
        </a>
        <input type="file" id="csv-file" accept=".csv" class="block flex-grow text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-purple-50 file:text-brand-purple hover:file:bg-purple-100 border border-gray-300 rounded-lg cursor-pointer focus:outline-none">
        <button id="preview-btn" class="btn-solid-purple whitespace-nowrap">Preview CSV Data</button>
      </div>

      <!-- Preview Section -->
      <div id="preview-section" class="hidden mt-6 border-t border-gray-200 pt-6">
        <h3 class="text-lg font-bold text-gray-900 mb-4">CSV Preview</h3>
        <div class="overflow-x-auto rounded-xl shadow border border-gray-200 mb-4 max-h-64">
          <table class="data-table">
            <thead>
              <tr>
                <th>Row</th>
                <th>Name</th>
                <th>Student ID</th>
                <th>Standard</th>
                <th>Mobile</th>
                <th>Monthly Fee</th>
              </tr>
            </thead>
            <tbody id="preview-body"></tbody>
          </table>
        </div>
        <div class="flex items-center gap-4">
          <button id="save-csv-btn" class="btn-solid-purple">Import CSV Students</button>
          <span id="csv-save-status" class="text-sm font-semibold hidden"></span>
        </div>
      </div>
    </div>

    <!-- SECTION 2: MASS EDIT GRID -->
    <div class="bg-white p-6 rounded-xl shadow border border-purple-100">
      <div class="flex justify-between items-center mb-4">
        <div>
          <h2 class="text-xl font-bold text-gray-800">Option B: Mass-Edit Existing Students</h2>
          <p class="text-sm text-gray-600 mt-1">Edit inline. If you enter a new password, it will override the old one. Leave blank to keep existing password.</p>
        </div>
        <div class="flex items-center gap-3">
          <button type="button" id="add-row-btn" class="btn-outline-purple text-sm">+ Add Row</button>
          <button type="button" id="save-grid-btn" class="btn-solid-purple">Save All Changes</button>
        </div>
      </div>

      <div class="overflow-x-auto rounded-xl shadow border border-gray-200 max-h-[600px] overflow-y-auto">
        <table class="data-table" id="mass-edit-table">
          <thead class="sticky top-0 z-10">
            <tr>
              <th>Profile Photo</th>
              <th>Standard</th>
              <th>Student ID</th>
              <th>Student Name</th>
              <th>Password</th>
              <th>Monthly Fee (₹)</th>
              <th>Mobile No</th>
            </tr>
          </thead>
          <tbody id="grid-body">
            <% students.forEach((s) => { %>
              <tr class="student-grid-row">
                <td class="text-center">
                  <% if(s.profilePhoto) { %>
                    <img src="<%= s.profilePhoto %>" alt="Profile" class="w-8 h-8 rounded-full mx-auto object-cover border border-purple-200">
                  <% } else { %>
                    <div class="w-8 h-8 rounded-full bg-purple-100 text-purple-600 mx-auto flex items-center justify-center text-xs font-bold border border-purple-200">
                      <%= s.studentName.charAt(0).toUpperCase() %>
                    </div>
                  <% } %>
                </td>
                <td class="editable-cell">
                  <select class="grid-standard">
                    <% for(let i=0; i<=10; i++) { %>
                      <option value="<%= i %>" <%= String(s.standard) === String(i) ? 'selected' : '' %>>Grade <%= i %></option>
                    <% } %>
                  </select>
                </td>
                <td class="editable-cell"><input type="text" class="grid-id font-mono text-gray-600" value="<%= s.studentId %>" readonly title="Note: Student ID cannot be changed here." style="background:#f3f4f6;cursor:not-allowed;"></td>
                <td class="editable-cell"><input type="text" class="grid-name font-semibold" value="<%= s.studentName %>"></td>
                <td class="editable-cell"><input type="text" class="grid-pass" placeholder="(Leave blank to keep)"></td>
                <td class="editable-cell"><input type="number" class="grid-fee" value="<%= s.monthlyFee || 0 %>"></td>
                <td class="editable-cell"><input type="text" class="grid-mobile" value="<%= s.mobileNo || '' %>"></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <div class="mt-4 flex items-center gap-3">
        <span id="grid-save-status" class="text-sm font-semibold hidden"></span>
      </div>
    </div>
  </div>

  <script>
    // OPTION A: CSV LOGIC
    let parsedData = [];

    document.getElementById('preview-btn').addEventListener('click', () => {
      const fileInput = document.getElementById('csv-file');
      if (!fileInput.files.length) return alert('Please select a CSV file first.');

      Papa.parse(fileInput.files[0], {
        header: true,
        skipEmptyLines: true,
        complete: function(results) {
          parsedData = results.data;
          const tbody = document.getElementById('preview-body');
          tbody.innerHTML = '';
          
          if(parsedData.length === 0) return alert('No valid rows found in CSV.');
          
          parsedData.forEach((row, index) => {
            tbody.innerHTML += `
              <tr>
                <td class="text-gray-400 text-xs">${index + 1}</td>
                <td class="font-semibold">${row.studentName || '<span class="text-red-500">Missing</span>'}</td>
                <td class="font-mono text-xs">${row.studentId || '<span class="text-red-500">Missing</span>'}</td>
                <td>${row.standard || '<span class="text-red-500">Missing</span>'}</td>
                <td class="text-xs">${row.mobileNo || '<span class="text-red-500">Missing</span>'}</td>
                <td class="text-gray-500">&#8377;${row.monthlyFee || '0'}</td>
              </tr>
            `;
          });
          document.getElementById('preview-section').classList.remove('hidden');
        },
        error: function(err) { alert('Error parsing CSV: ' + err.message); }
      });
    });

    document.getElementById('save-csv-btn').addEventListener('click', () => {
      if (!parsedData.length) return;
      saveToServer(parsedData, 'save-csv-btn', 'csv-save-status');
    });

    // OPTION B: MASS EDIT GRID LOGIC
    const gridBody = document.getElementById('grid-body');

    document.getElementById('add-row-btn').addEventListener('click', () => {
      let optionsHtml = '';
      for(let i=0; i<=10; i++) {
        optionsHtml += `<option value="${i}">Grade ${i}</option>`;
      }

      const tr = document.createElement('tr');
      tr.className = 'student-grid-row';
      tr.innerHTML = `
        <td class="text-center text-xs text-gray-400 italic">New Student</td>
        <td class="editable-cell"><select class="grid-standard">${optionsHtml}</select></td>
        <td class="editable-cell"><input type="text" class="grid-id font-mono text-brand-purple" placeholder="New ID" required></td>
        <td class="editable-cell"><input type="text" class="grid-name font-semibold" placeholder="Enter Name" required></td>
        <td class="editable-cell"><input type="text" class="grid-pass" placeholder="(Default: Mobile)"></td>
        <td class="editable-cell"><input type="number" class="grid-fee" placeholder="0"></td>
        <td class="editable-cell"><input type="text" class="grid-mobile" placeholder="Mobile No" required></td>
      `;
      gridBody.appendChild(tr);
      tr.scrollIntoView({ behavior: 'smooth', block: 'end' });
    });

    document.getElementById('save-grid-btn').addEventListener('click', () => {
      const rows = document.querySelectorAll('.student-grid-row');
      const dataToSave = [];
      let missingFields = false;

      rows.forEach(row => {
        const id = row.querySelector('.grid-id').value.trim();
        const name = row.querySelector('.grid-name').value.trim();
        const std = row.querySelector('.grid-standard').value;
        const pass = row.querySelector('.grid-pass').value.trim();
        const fee = row.querySelector('.grid-fee').value;
        const mobile = row.querySelector('.grid-mobile').value.trim();

        if (id && name && std && mobile) {
          dataToSave.push({
            studentId: id,
            studentName: name,
            standard: std,
            password: pass,
            monthlyFee: fee ? Number(fee) : 0,
            mobileNo: mobile
          });
        } else if (id || name || mobile) {
          missingFields = true;
        }
      });

      if (dataToSave.length === 0) {
        alert("No valid rows to save.");
        return;
      }
      if (missingFields) {
        if(!confirm("Some rows are missing required fields (ID, Name, Mobile). They will be skipped. Continue?")) {
          return;
        }
      }

      saveToServer(dataToSave, 'save-grid-btn', 'grid-save-status');
    });

    // GENERIC SERVER SAVE FUNCTION
    async function saveToServer(dataArray, btnId, statusId) {
      const btn = document.getElementById(btnId);
      const status = document.getElementById(statusId);
      
      const originalBtnText = btn.innerText;
      btn.disabled = true;
      btn.innerText = 'Saving...';
      status.className = 'text-sm font-semibold text-gray-500 ml-4';
      status.innerText = 'Sending data to server...';
      status.classList.remove('hidden');

      try {
        const res = await fetch('/teacher/bulk_save_students', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(dataArray)
        });
        
        const result = await res.json();
        
        if (result.success) {
          status.className = 'text-sm font-semibold text-green-600 block mt-4';
          let msg = `Successfully processed ${result.inserted} student(s)!`;
          if(result.errors && result.errors.length > 0) {
            msg += `<br><span class="text-red-600 mt-2 block">Found ${result.errors.length} skipped row(s):<br>${result.errors.join('<br>')}</span>`;
            status.innerHTML = msg;
            btn.innerText = 'Completed with errors';
          } else {
            status.innerHTML = msg;
            btn.innerText = 'Saved!';
            setTimeout(() => { window.location.reload(); }, 1500);
          }
        } else {
          status.className = 'text-sm font-semibold text-red-600 block mt-2';
          status.innerHTML = 'Error: ' + (result.error || 'Unknown error');
          btn.disabled = false;
          btn.innerText = originalBtnText;
        }
      } catch (e) {
        status.className = 'text-sm font-semibold text-red-600 block mt-2';
        status.innerHTML = 'Network Error: ' + e.message;
        btn.disabled = false;
        btn.innerText = originalBtnText;
      }
    }
  </script>
</body>
</html>
