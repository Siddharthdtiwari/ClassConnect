<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bulk Fee Entry | Tuition Hub</title>
  
  <%- include('../partials/background') %>
  
  <style>
    /* Premium Dashboard Styles */
    .dash-greeting {
      font-family: 'Unbounded', sans-serif;
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.03em;
    }
    .dash-sub {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--fdd);
      margin-top: 8px;
    }

    .glass-table-wrapper {
      background: var(--bgc);
      border: 1px solid var(--bd);
      border-radius: 16px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.04);
      overflow: hidden;
      position: relative;
      margin-bottom: 2rem;
    }
    
    .glass-table-wrapper::-webkit-scrollbar { width: 6px; height: 6px; }
    .glass-table-wrapper::-webkit-scrollbar-track { background: transparent; }
    .glass-table-wrapper::-webkit-scrollbar-thumb { background-color: rgba(124,58,237,0.25); border-radius: 10px; }
    .glass-table-wrapper::-webkit-scrollbar-thumb:hover { background-color: rgba(124,58,237,0.5); }

    .premium-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
    }
    .premium-table th {
      background: linear-gradient(135deg, var(--p) 0%, var(--pm) 100%) !important;
      position: sticky;
      top: 0;
      z-index: 20;
      padding: 12px 14px;
      font-family: 'Space Mono', monospace;
      text-transform: uppercase;
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      color: white;
      font-weight: 700;
      white-space: nowrap;
      border: none;
    }
    
    .premium-table td {
      padding: 4px 6px;
      border-bottom: 1px solid var(--bd);
      border-right: 1px solid var(--bd);
      transition: background 0.2s ease;
      vertical-align: middle;
      background: transparent;
    }
    .premium-table td:last-child {
      border-right: none;
    }
    .premium-table tbody tr:hover td { background: var(--bgch) !important; }
    
    .sticky-col-left {
      position: sticky;
      left: 0;
      background: var(--bgc) !important;
      z-index: 15;
      border-right: 2px solid var(--bd) !important;
      box-shadow: 2px 0 10px rgba(0,0,0,0.02);
    }
    .premium-table th.sticky-col-left {
      background: linear-gradient(135deg, var(--p) 0%, var(--pm) 100%) !important;
      z-index: 25;
    }

    /* HIGH DENSITY CELLS */
    .student-cell {
      display: flex;
      flex-direction: column;
      padding: 4px 8px;
      min-width: 180px;
      max-width: 220px;
    }
    .student-name {
      font-family: 'Unbounded', sans-serif;
      font-weight: 700;
      font-size: 0.75rem;
      color: var(--fg);
      margin-bottom: 2px;
      line-height: 1.2;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .student-id {
      font-size: 0.6rem;
      color: var(--pt);
      background: rgba(124,58,237,0.1);
      padding: 1px 6px;
      border-radius: 12px;
      display: inline-block;
      width: max-content;
      font-weight: 700;
      border: 1px solid rgba(124,58,237,0.2);
    }

    /* Cell wrapper design */
    .fee-cell {
      min-width: 150px;
      background: transparent;
      transition: all 0.2s;
    }
    .fee-cell-wrapper {
      padding: 6px;
      border-radius: 8px;
      border: 1px solid transparent;
      transition: all 0.2s ease;
      background: transparent;
    }
    .fee-cell-wrapper:hover, .fee-cell-wrapper:focus-within {
      border-color: var(--p);
      background: var(--bgc);
      box-shadow: 0 4px 12px var(--pg2);
    }

    .amount-input-wrapper {
      position: relative;
      margin-bottom: 2px;
    }
    .currency-symbol {
      position: absolute;
      left: 4px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--fdd);
      font-weight: 800;
      font-size: 0.75rem;
      transition: color 0.2s;
    }
    .amount-input {
      width: 100%;
      background: transparent !important;
      border: 1px solid transparent !important;
      border-radius: 4px !important;
      padding: 2px 4px 2px 14px !important;
      font-size: 0.82rem !important;
      font-weight: 700 !important;
      color: var(--fg) !important;
      outline: none !important;
      transition: all 0.2s;
      font-family: 'Inter', sans-serif !important;
    }
    .amount-input:focus {
      border-bottom: 2px solid var(--p) !important;
      background: var(--bgch) !important;
    }
    .amount-input::placeholder { color: var(--fdd) !important; opacity: 0.45; }

    .meta-inputs {
      display: flex;
      gap: 4px;
      opacity: 0.35;
      transition: all 0.2s ease;
    }
    .fee-cell-wrapper:hover .meta-inputs, 
    .fee-cell-wrapper:focus-within .meta-inputs,
    .paid-existing .meta-inputs {
      opacity: 1;
    }
    
    .meta-select, .meta-date {
      background: transparent !important;
      border: none !important;
      font-size: 0.62rem !important;
      padding: 0 !important;
      color: var(--fdd) !important;
      outline: none !important;
      cursor: pointer;
      font-family: 'Inter', sans-serif !important;
    }
    .meta-select { width: 40%; font-weight: 700; text-transform: uppercase; }
    .meta-date { width: 60%; }
    .meta-select:focus, .meta-date:focus {
      color: var(--pt) !important;
    }

    /* Paid States */
    .paid-existing .fee-cell-wrapper {
      background: rgba(52,211,153,0.03);
      border-color: rgba(52,211,153,0.15);
    }
    .paid-existing .amount-input {
      color: #34d399 !important;
    }
    .paid-existing .currency-symbol { color: #34d399; opacity: 1; }
    .paid-existing .meta-select, .paid-existing .meta-date {
      color: #34d399 !important;
    }
    
    /* Dirty Changes */
    .changed-cell .fee-cell-wrapper {
      border-color: #f59e0b;
      background: rgba(245,158,11,0.03);
    }

    .saved-cell .fee-cell-wrapper { animation: flashSuccess 1s ease-out; }
    @keyframes flashSuccess {
      0% { background: rgba(52,211,153,0.4); }
      100% { background: transparent; }
    }

    /* Floating Save Bar */
    .floating-save-bar {
      position: fixed;
      bottom: -100px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--bgc);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--bd);
      padding: 12px 24px;
      border-radius: 100px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.15), 0 0 0 1px var(--bd);
      display: flex;
      align-items: center;
      gap: 20px;
      z-index: 100;
      transition: bottom 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .floating-save-bar.visible { bottom: 32px; }
    
    .unsaved-count {
      background: #f59e0b;
      color: #fff;
      font-weight: 800;
      font-family: 'Space Mono', monospace;
      font-size: 0.75rem;
      padding: 4px 12px;
      border-radius: 20px;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .btn-save-glow {
      background: linear-gradient(135deg, var(--p) 0%, var(--pm) 100%) !important;
      color: white !important;
      border: none !important;
      padding: 8px 24px !important;
      border-radius: 100px !important;
      font-family: 'Unbounded', sans-serif !important;
      font-weight: 700 !important;
      font-size: 0.75rem !important;
      cursor: pointer;
      box-shadow: 0 4px 15px var(--pg) !important;
      transition: all 0.2s;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .btn-save-glow:hover {
      transform: translateY(-2px) !important;
      box-shadow: 0 6px 20px var(--pg) !important;
    }
    
    .ctrl-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.58rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--fdd);
      margin-bottom: 4px;
      display: block;
      font-weight: 700;
    }
    
    .ctrl-input {
      background: var(--bgc) !important;
      border: 1px solid var(--bd) !important;
      border-radius: 8px !important;
      padding: 6px 12px !important;
      font-family: 'Inter', sans-serif !important;
      font-size: 0.8rem !important;
      font-weight: 600 !important;
      color: var(--fg) !important;
      outline: none !important;
      transition: all 0.2s;
      cursor: pointer;
    }
    .ctrl-input:focus, .ctrl-input:hover {
      border-color: var(--p) !important;
    }

    @media (max-width: 768px) {
      .student-cell { min-width: 110px; max-width: 130px; padding: 4px; }
      .student-name { font-size: 0.65rem; }
      .student-id { display: none; }
      .fee-cell { min-width: 110px; }
      .amount-input { padding: 2px 4px 2px 14px !important; font-size: 0.75rem !important; }
      .currency-symbol { font-size: 0.65rem; left: 4px; }
      .premium-table th { padding: 8px; font-size: 0.6rem; }
      .premium-table td { padding: 4px; }
    }
  </style>
</head>

<body class="text-theme-fg m-0 p-0 overflow-hidden" style="background: var(--bg);">
  <div style="display: flex; height: 100vh; overflow: hidden;">
    <%- include('../partials/teacher_sidebar') %>
    
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
      <main style="flex: 1; overflow-y: auto; overflow-x: hidden; padding-bottom: 100px;">
        <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">

          <!-- Header (Dashboard matching style) -->
          <header class="mb-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
            <div>
              <h1 class="dash-greeting">Bulk Fee <span style="color: var(--pt);">Entry</span></h1>
              <p class="dash-sub">Faculty Command Center · Matrix Payments Ledger (<%= selectedYear %>)</p>
            </div>
            <div class="flex gap-3 flex-wrap items-center">
              <a href="/teacher/manage_fees" class="btn-outline-purple flex items-center gap-2 text-[10px] font-bold uppercase tracking-wider font-mono">
                <svg class="w-3.5 h-3.5 text-theme-pt" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Back
              </a>
              <div class="flex gap-3 flex-wrap items-center bg-theme-bgc/60 backdrop-blur-md p-3.5 rounded-xl border border-theme-bd">
                <div class="flex flex-col sm:flex-none">
                  <label class="ctrl-label">Default Date</label>
                  <input type="date" id="global-date" class="ctrl-input" value="<%= new Date().toISOString().split('T')[0] %>">
                </div>

                <div class="flex flex-col sm:flex-none">
                  <label class="ctrl-label">Default Method</label>
                  <select id="global-method" class="ctrl-input">
                    <option value="Cash">💵 Cash</option>
                    <option value="UPI" selected>📱 UPI</option>
                    <option value="Razorpay">🌐 Razorpay</option>
                  </select>
                </div>
              </div>
            </div>
          </header>

          <!-- Table Container -->
          <div class="glass-table-wrapper">
            <div class="overflow-x-auto" style="max-height: 70vh;">
              <table class="premium-table min-w-max">
                <thead>
                  <tr>
                    <th class="sticky-col-left">
                      <div class="flex items-center gap-2">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                        Student Roster
                      </div>
                    </th>
                    <% months.forEach(month => { %>
                    <th class="text-center">
                      <div class="flex items-center justify-center gap-1">
                        <svg class="w-3.5 h-3.5 opacity-60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        <%= month %>
                      </div>
                    </th>
                    <% }) %>
                  </tr>
                </thead>
                <tbody>
                  <% users.forEach((user, index) => { %>
                  <tr class="border-b border-theme-bd hover:bg-theme-bgch/40 transition-all">
                    <td class="sticky-col-left">
                      <div class="student-cell">
                        <div class="student-name" title="<%= user.studentName %>"><%= user.studentName %></div>
                        <div class="student-id">
                          <%= user.studentId %>
                        </div>
                      </div>
                    </td>

                    <% months.forEach(month => { 
                       const record = (feeMap[user.studentId] && feeMap[user.studentId][month]) ? feeMap[user.studentId][month] : null;
                       const isPaid = !!record;
                       const isNextYear = ["January", "February", "March", "April"].includes(month);
                       const cellYear = isNextYear ? selectedYear + 1 : selectedYear;
                    %>
                    <td id="cell-<%= user.studentId %>-<%= month %>" class="fee-cell <%= isPaid ? 'paid-existing' : '' %>">
                      <div class="fee-cell-wrapper">
                        <input type="hidden" class="data-student-id" value="<%= user.studentId %>">
                        <input type="hidden" class="data-student-name" value="<%= user.studentName %>">
                        <input type="hidden" class="data-standard" value="<%= user.standard %>">
                        <input type="hidden" class="data-month" value="<%= month %>">
                        <input type="hidden" class="data-year" value="<%= cellYear %>">

                        <div class="amount-input-wrapper">
                          <span class="currency-symbol">₹</span>
                          <input type="number" class="amount-input data-amount" placeholder="<%= user.monthlyFee %>" value="<%= isPaid ? record.amount : '' %>" oninput="markDirty(this)">
                        </div>

                        <div class="meta-inputs">
                          <select class="meta-select data-method" onchange="markDirty(this)">
                            <option value="" disabled <%= !isPaid ? 'selected' : '' %>>Method</option>
                            <option value="Cash" <%= (isPaid && record.method === 'Cash') ? 'selected' : '' %>>Cash</option>
                            <option value="UPI" <%= (isPaid && record.method === 'UPI') ? 'selected' : '' %>>UPI</option>
                            <option value="Razorpay" <%= (isPaid && record.method === 'Razorpay') ? 'selected' : '' %>>Net</option>
                          </select>
                          <input type="date" class="meta-date data-date" value="<%= isPaid && record.datePaid ? new Date(record.datePaid).toISOString().split('T')[0] : '' %>" onchange="markDirty(this)">
                        </div>
                      </div>
                    </td>
                    <% }) %>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
          
        </div>
      </main>
      
      <!-- FLOATING SAVE BAR -->
      <div id="floating-save-bar" class="floating-save-bar">
        <div class="text-theme-fg font-medium flex flex-col">
          <span class="text-theme-fdd text-[0.65rem] uppercase tracking-wider font-bold mb-0.5">Unsaved Changes</span>
          <div class="flex items-center gap-2">
            <span id="unsaved-badge" class="unsaved-count">
              <span id="unsaved-text">0 Modified</span>
            </span>
          </div>
        </div>
        <button onclick="saveAllChanges()" id="save-btn" class="btn-save-glow flex items-center gap-1.5 shadow-lg">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
          Commit ✓
        </button>
      </div>
      
    </div>
  </div>

  <div id="toast" class="fixed top-6 right-6 bg-gray-900 text-white px-4 py-3 rounded-xl shadow-2xl transform -translate-y-32 opacity-0 transition-all duration-300 z-[200] font-medium flex items-center gap-2 border border-gray-700 text-sm">
    <div id="toast-icon"></div>
    <span id="toast-msg">Saving...</span>
  </div>

  <script>
    let unsavedCount = 0;

    function markDirty(element) {
      const cell = element.closest('td');
      
      // Calculate dirty status and show visual modified warning
      if (!cell.classList.contains('changed-cell')) {
        cell.classList.add('changed-cell');
        unsavedCount++;
        updateFloatingBar();
      }
      cell.classList.remove('saved-cell');

      const amountInput = cell.querySelector('.data-amount');
      const dateInput = cell.querySelector('.data-date');
      const methodInput = cell.querySelector('.data-method');

      const globalDate = document.getElementById('global-date').value;
      const globalMethod = document.getElementById('global-method').value;

      // Automatically fill date/method defaults if amount is typed
      if (amountInput.value && !dateInput.value) {
        dateInput.value = globalDate;
      }
      if (amountInput.value && element === amountInput) {
        if (!methodInput.value || methodInput.value === "") {
          methodInput.value = globalMethod;
        }
      }

      // Reactive highlight classes based on amount length
      if (amountInput.value && amountInput.value.trim() !== "") {
        cell.classList.add('paid-existing');
      } else {
        cell.classList.remove('paid-existing');
      }
    }
    
    function updateFloatingBar() {
      const bar = document.getElementById('floating-save-bar');
      const text = document.getElementById('unsaved-text');
      if (unsavedCount > 0) {
        text.innerText = `${unsavedCount} Modified`;
        bar.classList.add('visible');
      } else {
        bar.classList.remove('visible');
      }
    }

    async function saveAllChanges() {
      const changedCells = document.querySelectorAll('.changed-cell');
      if (changedCells.length === 0) return;

      const saveBtn = document.getElementById('save-btn');
      const originalText = saveBtn.innerHTML;
      saveBtn.innerHTML = `Saving...`;
      saveBtn.disabled = true;

      const updates = [];

      changedCells.forEach(cell => {
        const amountInput = cell.querySelector('.data-amount');
        const amount = amountInput.value;
        const method = cell.querySelector('.data-method').value;
        const date = cell.querySelector('.data-date').value;

        // If it was already paid in DB but now it is empty, mark for deletion
        // (If cell didn't have data-originally-paid, it defaults to original check)
        const isDelete = cell.classList.contains('paid-existing') && amount === "";

        if (!isDelete && (!amount || !method || !date)) return;

        updates.push({
          studentId: cell.querySelector('.data-student-id').value,
          studentName: cell.querySelector('.data-student-name').value,
          standard: cell.querySelector('.data-standard').value,
          month: cell.querySelector('.data-month').value,
          year: cell.querySelector('.data-year').value,
          amount: isDelete ? null : parseInt(amount),
          method: method,
          datePaid: date,
          deleteAction: isDelete
        });
      });

      if (updates.length > 0) {
        try {
          const res = await fetch('/teacher/bulk_save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ updates })
          });

          const result = await res.json();

          if (result.success) {
            showToast("Saved Successfully!", "bg-[#10b981]");
            changedCells.forEach(cell => {
              cell.classList.remove('changed-cell');
              
              const isDelete = cell.querySelector('.data-amount').value === "";
              if (isDelete) {
                cell.classList.remove('paid-existing');
              } else {
                cell.classList.add('paid-existing'); 
              }
              
              cell.classList.add('saved-cell');
              setTimeout(() => cell.classList.remove('saved-cell'), 1000);
            });
            unsavedCount = 0;
            updateFloatingBar();
          } else {
            showToast("Error saving data.", "bg-red-600");
          }
        } catch (e) {
          console.error(e);
          showToast("Network Error", "bg-red-600");
        }
      }

      saveBtn.innerHTML = originalText;
      saveBtn.disabled = false;
    }

    function showToast(msg, bgClass) {
      const toast = document.getElementById('toast');
      document.getElementById('toast-msg').textContent = msg;
      toast.className = `fixed top-6 right-6 text-white px-5 py-3 rounded-xl shadow-lg transform transition-all duration-300 z-[200] font-medium flex items-center gap-2 border border-white/10 ${bgClass}`;
      requestAnimationFrame(() => {
        toast.classList.remove('-translate-y-32', 'opacity-0');
        toast.classList.add('translate-y-0', 'opacity-100');
      });
      setTimeout(() => {
        toast.classList.remove('translate-y-0', 'opacity-100');
        toast.classList.add('-translate-y-32', 'opacity-0');
      }, 3000);
    }
  </script>
</body>

</html>