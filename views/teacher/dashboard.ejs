<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Faculty Dashboard | Tuition Hub</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@300;400;700;900&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    /* Dashboard-specific styles */
    .dash-greeting {
      font-family: 'Unbounded', sans-serif;
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.03em;
    }
    .dash-sub {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--fdd);
      margin-top: 8px;
    }
    .stat-card {
      background: var(--bgc);
      backdrop-filter: blur(16px);
      border: 1px solid var(--bd);
      border-radius: 18px;
      padding: 28px;
      transition: all 0.35s cubic-bezier(.34,1.56,.64,1);
      position: relative;
      overflow: hidden;
    }
    .stat-card::before {
      content: '';
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 0.4s;
      background: radial-gradient(circle at 20% 30%, var(--pg2) 0%, transparent 60%);
      pointer-events: none;
    }
    .stat-card:hover::before { opacity: 1; }
    .stat-card:hover {
      border-color: rgba(124,58,237,0.25);
      transform: translateY(-4px);
      box-shadow: 0 12px 40px var(--pg2);
    }
    .stat-value {
      font-family: 'Unbounded', sans-serif;
      font-size: 2.2rem;
      font-weight: 900;
      line-height: 1;
      position: relative;
      z-index: 1;
    }
    .stat-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--fdd);
      margin-top: 6px;
      position: relative;
      z-index: 1;
    }
    .stat-icon {
      position: absolute;
      top: 20px;
      right: 20px;
      opacity: 0.15;
      z-index: 0;
    }
    .quick-link {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 16px 20px;
      border-radius: 14px;
      text-decoration: none;
      color: var(--fg);
      background: var(--bgc);
      border: 1px solid var(--bd);
      backdrop-filter: blur(12px);
      transition: all 0.3s cubic-bezier(.34,1.56,.64,1);
    }
    .quick-link:hover {
      border-color: var(--p);
      transform: translateX(6px);
      background: var(--bgch);
      box-shadow: 0 6px 20px var(--pg2);
    }
    .quick-link:hover .ql-arrow {
      opacity: 1;
      transform: translateX(0);
    }
    .ql-icon {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      background: rgba(124,58,237,0.08);
      border: 1px solid rgba(124,58,237,0.12);
      color: var(--pt);
    }
    .ql-title {
      font-family: 'Unbounded', sans-serif;
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }
    .ql-desc {
      font-size: 0.72rem;
      color: var(--fdd);
      margin-top: 2px;
    }
    .ql-arrow {
      margin-left: auto;
      opacity: 0;
      transform: translateX(-8px);
      transition: all 0.3s;
      color: var(--pt);
    }
  </style>
</head>

<%- include('../partials/background') %>

<body class="text-theme-fg m-0 p-0 overflow-hidden" style="background: var(--bg);">
  <div style="display: flex; height: 100vh; overflow: hidden;">
    <%- include('../partials/teacher_sidebar') %>
    
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
      <main class="flex-1 overflow-y-auto overflow-x-hidden p-4 sm:p-6 lg:p-8">

        <!-- Greeting -->
        <div style="margin-bottom: 40px;">
          <h1 class="dash-greeting">
            Welcome back, <span style="color: var(--pt);"><%= teacher.teacherName.split(' ')[0] %></span>
          </h1>
          <p class="dash-sub">Faculty Command Center · Tuition Hub Education Centre</p>
        </div>

        <!-- Stats Row -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
          <div class="stat-card">
            <div class="stat-icon">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
            </div>
            <div class="stat-value" style="color: var(--pt);"><%= typeof metrics !== 'undefined' ? metrics.totalStudents : 0 %></div>
            <div class="stat-label">Active Students</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="2" y="5" width="20" height="14" rx="2" ry="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
            </div>
            <div class="stat-value" style="color: var(--lt);">₹<%= typeof metrics !== 'undefined' ? metrics.totalRevenue.toLocaleString() : 0 %></div>
            <div class="stat-label">Total Revenue</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <div class="stat-value" style="color: var(--pt);"><%= typeof metrics !== 'undefined' ? metrics.upcomingTests : 0 %></div>
            <div class="stat-label">Upcoming Tests</div>
          </div>
        </div>

        <!-- Quick Actions -->
        <div style="margin-bottom: 16px;">
          <h2 style="font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--fdd); margin-bottom: 16px; display: flex; align-items: center; gap: 10px;">
            <span style="width: 20px; height: 1px; background: var(--pt);"></span>
            Quick Actions
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          
          <a href="/teacher/manage_students" class="quick-link">
            <div class="ql-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
            </div>
            <div>
              <div class="ql-title">Manage Students</div>
              <div class="ql-desc">View, edit, and organize profiles</div>
            </div>
            <span class="ql-arrow">→</span>
          </a>

          <a href="/teacher/manage_attendance" class="quick-link">
            <div class="ql-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div>
              <div class="ql-title">Attendance</div>
              <div class="ql-desc">Record & analyze daily presence</div>
            </div>
            <span class="ql-arrow">→</span>
          </a>

          <a href="/teacher/manage_tests" class="quick-link">
            <div class="ql-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <div>
              <div class="ql-title">Assessments</div>
              <div class="ql-desc">Create tests & assignments</div>
            </div>
            <span class="ql-arrow">→</span>
          </a>

          <a href="/teacher/manage_score" class="quick-link">
            <div class="ql-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <div>
              <div class="ql-title">Performance</div>
              <div class="ql-desc">Upload & analyze scores</div>
            </div>
            <span class="ql-arrow">→</span>
          </a>

          <a href="/teacher/manage_fees" class="quick-link">
            <div class="ql-icon" style="background: rgba(189,224,69,0.08); border-color: rgba(189,224,69,0.15); color: var(--lt);">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="5" width="20" height="14" rx="2" ry="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
            </div>
            <div>
              <div class="ql-title">Fee Tracking</div>
              <div class="ql-desc">Track balances & payments</div>
            </div>
            <span class="ql-arrow">→</span>
          </a>

          <a href="/teacher/revenue_report" class="quick-link">
            <div class="ql-icon" style="background: rgba(189,224,69,0.08); border-color: rgba(189,224,69,0.15); color: var(--lt);">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
            </div>
            <div>
              <div class="ql-title">Analytics</div>
              <div class="ql-desc">Revenue trends & reports</div>
            </div>
            <span class="ql-arrow">→</span>
          </a>

          <a href="/teacher/study_material" class="quick-link">
            <div class="ql-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            </div>
            <div>
              <div class="ql-title">Study Material</div>
              <div class="ql-desc">Upload resources & lessons</div>
            </div>
            <span class="ql-arrow">→</span>
          </a>

          <a href="/teacher/manage_batches" class="quick-link">
            <div class="ql-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div>
              <div class="ql-title">Manage Batches</div>
              <div class="ql-desc">Configure academic year batches</div>
            </div>
            <span class="ql-arrow">→</span>
          </a>

          <a href="/teacher/timetable" class="quick-link">
            <div class="ql-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <div class="ql-title">Exam Timetable</div>
              <div class="ql-desc">Schedule exam dates</div>
            </div>
            <span class="ql-arrow">→</span>
          </a>

          <a href="/teacher/manage_students?action=add" class="quick-link">
            <div class="ql-icon" style="background: rgba(52,211,153,0.08); border-color: rgba(52,211,153,0.15); color: #34d399;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </div>
            <div>
              <div class="ql-title">Add Student</div>
              <div class="ql-desc">Enroll a new student</div>
            </div>
            <span class="ql-arrow">→</span>
          </a>

        </div>

      </main>
    </div>
  </div>
</body>
</html>