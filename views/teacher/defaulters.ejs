<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <title>Attendance Defaulter List - <%= month %>/<%= year %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  
</head>

<%- include('../partials/background') %>


<body class="text-theme-fg m-0 p-0 overflow-hidden" style="background: var(--bg);">
  <div style="display: flex; height: 100vh; overflow: hidden;">
    <%- include('../partials/teacher_sidebar') %>
    
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
      <main style="flex: 1; overflow-y: auto; overflow-x: hidden;">
        <% const printMonthName = typeof month !== 'undefined' ? new Date(year, parseInt(month) - 1).toLocaleString('default', { month: 'long' }) : 'Unknown'; %>
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
    <header class="mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <div>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mt-1">
          Attendance Defaulters
        </h1>
        <p class="text-gray-600 mt-2">
          Students with attendance below 75% for <span class="font-bold text-brand-purple"><%= printMonthName %> <%= year %></span>.
        </p>
      </div>

      <div class="no-print">
        <% if (defaulters.length > 0) { %>
          <button onclick="triggerPrint()" class="btn-solid-purple flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
            Print Defaulters
          </button>
        <% } %>
      </div>
    </header>

    <% if (defaulters.length > 0) { %>
      <div class="glass-card p-6 rounded-xl shadow border border-purple-100 mb-8 printable-block">
        <span class="hidden" data-print-title="ATTENDANCE DEFAULTERS: <%= printMonthName %> <%= year %>"></span>
        <div class="overflow-x-auto rounded-xl shadow-sm border border-gray-200 print-table-wrapper">
          <table class="data-table">
            <thead>
              <tr>
                <th>Student Name</th>
                <th>Student ID</th>
                <th>Standard</th>
                <th>Phone No</th>
                <th class="text-center">Present</th>
                <th class="text-center">Absent</th>
                <th class="text-center">Attendance %</th>
              </tr>
            </thead>
            <tbody>
              <% defaulters.forEach(d => { 
                const percentage = d.total > 0 ? ((d.present / d.total) * 100).toFixed(2) : 0; 
                const danger = percentage < 50; 
              %>
                <tr>
                  <td class="font-bold text-gray-800"><%= d.studentName %></td>
                  <td class="font-mono text-gray-500"><%= d.studentId %></td>
                  <td class="text-gray-600"><%= d.standard %></td>
                  <td class="text-gray-600"><%= d.mobileNo %></td>
                  <td class="text-center text-green-700 font-semibold"><%= d.present %></td>
                  <td class="text-center text-red-600 font-semibold"><%= d.absent %></td>
                  <td class="text-center font-bold <%= danger ? 'text-red-600' : 'text-yellow-600' %>">
                    <%= percentage %>%
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } else { %>
      <div class="bg-purple-50 border border-purple-200 text-purple-800 px-6 py-8 rounded-xl shadow-sm text-center">
        <span class="text-4xl mb-3 block">🎉</span>
        <h3 class="text-xl font-bold mb-1">Excellent Attendance!</h3>
        <p class="text-gray-600">No students fell below the 75% attendance threshold for <%= month %> <%= year %>.</p>
      </div>
    <% } %>
  </div>

  <div id="print-container" class="hidden print:block absolute top-0 left-0 w-full glass-card z-50 p-8"></div>

  <script>
    const headerUrl = "<%= typeof headerUrl !== 'undefined' ? headerUrl : '' %>";

    function triggerPrint(titleText, contentHtml) {
      const printContainer = document.getElementById('print-container');
      const imgHtml = headerUrl ? `<img src="${headerUrl}" id="print-header-img" style="display: block; width: 100%; max-width: 700px; margin: 0 auto 15px auto; height: auto; object-fit: contain;" alt="Institution Header" />` : '';

      printContainer.innerHTML = `
        <div style="text-align: center; margin-bottom: 20px;">
          ${imgHtml}
          <p style="font-size: 14px; color: #333; font-weight: bold; margin: 10px 0;">Official Attendance Defaulters Report</p>
          <hr style="border: 1px solid #ccc;" />
        </div>
        <div style="text-align: center; font-size: 16pt; font-weight: bold; margin-bottom: 10px; color: #000; text-transform: uppercase;">${titleText}</div>
        <div style="margin-bottom: 10px; font-size: 12px; color: #555; text-align: right; font-style: italic;">Generated on: ${new Date().toLocaleString()}</div>
        ${contentHtml}
      `;

      setTimeout(() => { window.print(); }, 500);
    }

    function triggerPrintBtn() {
      const block = document.querySelector('.printable-block');
      const titleEl = block.querySelector('[data-print-title]');
      const titleText = titleEl ? titleEl.getAttribute('data-print-title') : 'ATTENDANCE DEFAULTERS';
      const tableHtml = block.querySelector('.print-table-wrapper').innerHTML;
      
      triggerPrint(titleText, tableHtml);
    }
    
    document.querySelector('.btn-solid-purple').onclick = triggerPrintBtn;
  </script>
      </main>
    </div>
  </div>
</body>

</html>