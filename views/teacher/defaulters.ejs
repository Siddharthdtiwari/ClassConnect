<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <title>Attendance Defaulters - <%= month %>/<%= year %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;600;900&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    .dash-greeting {
      font-family: 'Unbounded', sans-serif;
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.03em;
    }
    .dash-sub {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--fdd);
      margin-top: 8px;
    }
    .stat-card {
      background: var(--bgc);
      backdrop-filter: blur(16px);
      border: 1px solid var(--bd);
      border-radius: 18px;
      padding: 24px;
      transition: all 0.35s cubic-bezier(.34,1.56,.64,1);
    }
  </style>
</head>

<%- include('../partials/background') %>


<body class="text-theme-fg m-0 p-0 overflow-hidden" style="background: var(--bg);">
  <div style="display: flex; height: 100vh; overflow: hidden;">
    <%- include('../partials/teacher_sidebar') %>
    
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
      <main style="flex: 1; overflow-y: auto; overflow-x: hidden;">
        <% const printMonthName = typeof month !== 'undefined' ? new Date(year, parseInt(month) - 1).toLocaleString('default', { month: 'long' }) : 'Unknown'; %>
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
    <header class="mb-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
      <div>
        <h1 class="dash-greeting">Attendance <span style="color: var(--pt);">Defaulters</span></h1>
        <p class="dash-sub">
          Below 75% for <%= printMonthName %> <%= year %>
        </p>
      </div>

      <div class="flex gap-3 flex-wrap items-center">
        <a href="/teacher/manage_attendance" class="btn-outline-purple flex items-center gap-2 text-[10px] font-bold uppercase tracking-wider font-mono px-4 py-2 rounded-xl">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          Back
        </a>
        <% if (defaulters.length > 0) { %>
          <a href="/teacher/defaulters/download/<%= year %>/<%= month %>" class="btn-outline-purple flex items-center gap-2 text-[10px] font-bold uppercase tracking-wider font-mono px-4 py-2 rounded-xl">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
            Download PDF
          </a>
        <% } %>
      </div>
    </header>

    <% if (defaulters.length > 0) { %>
      <div class="stat-card p-6 sm:p-8 mb-8">
        <div class="overflow-x-auto rounded-xl shadow-sm border border-theme-bd print-table-wrapper">
          <table class="data-table">
            <thead>
              <tr>
                <th>Student Name</th>
                <th>Student ID</th>
                <th>Standard</th>
                <th>Phone No</th>
                <th class="text-center">Present</th>
                <th class="text-center">Absent</th>
                <th class="text-center">Attendance %</th>
              </tr>
            </thead>
            <tbody>
              <% defaulters.forEach(d => { 
                const percentage = d.total > 0 ? ((d.present / d.total) * 100).toFixed(2) : 0; 
                const danger = percentage < 50; 
              %>
                <tr class="hover:bg-theme-bgch/40 transition-all border-b border-theme-bd">
                  <td class="font-bold text-theme-fg"><%= d.studentName %></td>
                  <td class="font-mono text-theme-pt text-xs"><%= d.studentId %></td>
                  <td class="font-bold text-theme-fdd text-xs uppercase tracking-wider"><%= d.standard %></td>
                  <td class="text-theme-fd text-xs font-medium"><%= d.mobileNo %></td>
                  <td class="text-center text-green-500 font-black font-mono"><%= d.present %></td>
                  <td class="text-center text-red-500 font-black font-mono"><%= d.absent %></td>
                  <td class="text-center font-black font-mono <%= danger ? 'text-red-500' : 'text-orange-400' %>">
                    <%= percentage %>%
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } else { %>
      <div class="stat-card p-16 text-center text-theme-fdd">
        <span class="text-5xl mb-4 block">🎉</span>
        <h3 class="text-xl font-bold mb-1">Excellent Attendance!</h3>
        <p class="text-sm mt-1">No students fell below the 75% attendance threshold for <%= printMonthName %> <%= year %>.</p>
      </div>
    <% } %>
  </div>

  </div>
      </main>
    </div>
  </div>
</body>

</html>