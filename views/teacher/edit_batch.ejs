<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Batch</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  
</head>

<%- include('../partials/background') %>


<body class="text-theme-fg m-0 p-0 overflow-hidden" style="background: var(--bg);">
  <div style="display: flex; height: 100vh; overflow: hidden;">
    <%- include('../partials/teacher_sidebar') %>
    
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
      <main style="flex: 1; overflow-y: auto; overflow-x: hidden;">
        <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
    
    <header class="mb-8 max-w-md mx-auto">
      <h1 class="text-3xl font-bold text-gray-900">Edit Batch Details</h1>
      <p class="text-gray-600 mt-1">
        Update configuration or toggle active status.
      </p>
    </header>

    <div class="glass-card p-6 sm:p-8 max-w-md mx-auto mb-10 border border-purple-50">
      
      <!-- Error Message Banner -->
      <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm font-semibold shadow-sm">
        <%= error %>
      </div>
      <% } %>

      <form id="edit-batch-form" class="space-y-6" action="/teacher/edit_batch/<%= batch._id %>" method="POST">
        <!-- CSRF Token protection -->
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>" />

        <!-- Academic Year Display Badge (Locked) -->
        <div class="p-3 bg-purple-50 border border-purple-100 rounded-lg flex items-center justify-between">
          <span class="text-xs font-semibold text-purple-700 uppercase tracking-wider">Academic Session</span>
          <span class="text-sm font-bold text-brand-purple"><%= batch.academicYear %></span>
        </div>

        <div>
          <label for="name" class="block text-sm font-semibold text-gray-700 mb-1">Batch Name <span class="text-red-500">*</span></label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            value="<%= batch.name %>" 
            placeholder="e.g. 9th Grade Science, Math Advanced" 
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 shadow-sm focus:border-brand-purple focus:ring focus:ring-brand-purple focus:ring-opacity-50 transition duration-150" 
            required 
            autofocus
          />
        </div>

        <div>
          <label for="isActive" class="block text-sm font-semibold text-gray-700 mb-1">Status</label>
          <select 
            id="isActive" 
            name="isActive" 
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 shadow-sm focus:border-brand-purple focus:ring focus:ring-brand-purple focus:ring-opacity-50 transition duration-150 glass-card"
          >
            <option value="true" <%= batch.isActive ? 'selected' : '' %>>Active</option>
            <option value="false" <%= !batch.isActive ? 'selected' : '' %>>Inactive</option>
          </select>
          <p class="text-xs text-gray-500 mt-1">Inactive batches are hidden from new student/test creation dropdown lists.</p>
        </div>

        <div>
          <label for="description" class="block text-sm font-semibold text-gray-700 mb-1">Description</label>
          <textarea 
            id="description" 
            name="description" 
            rows="3" 
            placeholder="Optional batch details or schedule information..." 
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 shadow-sm focus:border-brand-purple focus:ring focus:ring-brand-purple focus:ring-opacity-50 transition duration-150"
          ><%= batch.description %></textarea>
        </div>

        <button type="submit" class="btn-solid-purple">
          Save Changes
        </button>
      </form>
    </div>

  </div>

  <script>
    const editForm = document.getElementById("edit-batch-form");
    if (editForm) {
      editForm.addEventListener("submit", function() {
        const btn = this.querySelector('button[type="submit"]');
        if (btn) {
          btn.disabled = true;
          btn.innerText = "Saving Changes...";
          btn.style.opacity = "0.7";
          btn.style.cursor = "not-allowed";
        }
      });
    }
  </script>
      </main>
    </div>
  </div>
</body>


</html>
