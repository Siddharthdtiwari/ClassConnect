<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Student Profile</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;600;900&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <%- include('../partials/background') %>

  <style>
    /* Premium Dashboard Styles */
    .dash-greeting {
      font-family: 'Unbounded', sans-serif;
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.03em;
    }
    .dash-sub {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--fdd);
      margin-top: 8px;
    }
    .stat-card {
      background: var(--bgc);
      backdrop-filter: blur(16px);
      border: 1px solid var(--bd);
      border-radius: 18px;
      padding: 24px;
      transition: all 0.35s cubic-bezier(.34,1.56,.64,1);
      position: relative;
      overflow: hidden;
    }
    .photo-upload-area {
      border: 2px dashed var(--b);
      background: var(--bgc);
      transition: all 0.3s;
    }
    .photo-upload-area:hover {
      border-color: var(--p);
      background: var(--bgch);
    }
  </style>
</head>
<body class="text-theme-fg m-0 p-0 overflow-hidden" style="background: var(--bg);">
  <div style="display: flex; height: 100vh; overflow: hidden;">
    <%- include('../partials/teacher_sidebar') %>
    
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
      <main style="flex: 1; overflow-y: auto; overflow-x: hidden;">
        <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
          <header class="mb-10 flex items-center justify-between">
            <div>
              <h1 class="dash-greeting">Edit <span style="color: var(--pt);">Profile</span></h1>
              <p class="dash-sub">Update <%= student.studentName %>'s information</p>
            </div>
            <a href="/teacher/view_profile/<%= student._id %>" class="btn-outline-purple flex items-center gap-2 py-2 px-4 rounded-xl text-xs font-bold uppercase tracking-wider font-mono">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
              Back to Profile
            </a>
          </header>
          
          <div class="stat-card p-6 sm:p-10 max-w-3xl mx-auto mb-10">
            <div class="mb-8 border-b border-theme-bd pb-6 flex items-center gap-4">
              <div class="p-1 rounded-full bg-theme-bg2 border border-theme-bd">
                <img id="current-photo" src="<%= student.profilePhoto || 'https://placehold.co/128x128/ffffff/5d3a9b?text=' + student.studentName.charAt(0) %>" alt="Current Profile Picture" class="w-16 h-16 rounded-full object-cover" />
              </div>
              <div>
                <h2 class="text-lg font-bold tracking-tight text-theme-fg" style="font-family: 'Unbounded', sans-serif;"><%= student.studentName %></h2>
                <p class="text-[10px] text-theme-fdd mt-1 font-mono uppercase tracking-wider font-bold"><%= student.studentId %></p>
              </div>
            </div>

          <form id="edit-profile-form" action="/teacher/edit_profile/<%= student._id %>?_csrf=<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" method="POST" enctype="multipart/form-data" class="space-y-6">
<input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
            
            <div class="photo-upload-area rounded-2xl p-6 text-center cursor-pointer relative group">
              <input type="file" id="profile-photo" name="profilePhoto" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-20" />
              <div class="flex flex-col items-center gap-2 z-10 relative pointer-events-none">
                <div class="w-12 h-12 rounded-full bg-purple-500/10 flex items-center justify-center text-theme-pt group-hover:scale-110 transition-transform">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                </div>
                <div>
                  <span class="text-sm font-bold text-theme-pt font-mono uppercase">Click to upload new photo</span>
                  <p class="text-[10px] text-theme-fdd mt-1 font-semibold">PNG, JPG up to 5MB</p>
                </div>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="student-id" class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Student ID</label>
                <input type="text" id="student-id" value="<%= student.studentId %>" disabled class="w-full bg-theme-bgc text-theme-fdd border border-theme-b rounded-xl focus:outline-none py-3 px-4 font-semibold text-sm cursor-not-allowed opacity-70" />
              </div>

              <div>
                <label for="student-name" class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Student Name</label>
                <input type="text" id="student-name" name="studentName" value="<%= student.studentName %>" class="w-full bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p focus:outline-none py-3 px-4 font-semibold text-sm" />
              </div>

              <div>
                <label for="email" class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Email Address</label>
                <input type="email" id="email" name="email" value="<%= student.email || '' %>" class="w-full bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p focus:outline-none py-3 px-4 font-semibold text-sm" />
              </div>

              <div>
                <label for="batchId" class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Batch</label>
                <select id="batchId" name="batchId" class="w-full bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p focus:outline-none py-3 px-4 font-semibold text-sm" required>
                  <% batches.forEach(b => { %>
                    <option value="<%= b._id %>" <%= String(student.batch) === String(b._id) ? 'selected' : '' %>><%= b.name %></option>
                  <% }) %>
                </select>
              </div>

              <div>
                <label for="mobile-no" class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Mobile No</label>
                <input type="tel" id="mobile-no" name="mobileNo" value="<%= student.mobileNo %>" class="w-full bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p focus:outline-none py-3 px-4 font-semibold text-sm" />
              </div>

              <div>
                <label for="monthlyFee" class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Monthly Fee (₹)</label>
                <input type="number" id="monthlyFee" name="monthlyFee" value="<%= student.monthlyFee || 0 %>" min="0" class="w-full bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p focus:outline-none py-3 px-4 font-semibold text-sm" required />
              </div>
            </div>

            <div class="pt-8 border-t border-theme-bd flex gap-4 mt-8">
              <a href="/teacher/view_profile/<%= student._id %>" class="w-full py-3 px-6 rounded-xl text-center font-bold text-theme-fdd hover:text-theme-fg hover:bg-theme-bg2 transition-colors border border-transparent">
                Cancel
              </a>
              <button type="submit" class="w-full py-3 px-8 btn-solid-purple text-lg shadow-md">
                Save Changes
              </button>
            </div>
          </form>

          <div id="message-box" class="mt-6 p-4 rounded-md text-center hidden"></div>
        </div>
      </div>
      </main>
    </div>
  </div>
</body>


</html>