<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Teacher</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;600;900&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <%- include('../partials/background') %>

  <style>
    /* Premium Dashboard Styles */
    .dash-greeting {
      font-family: 'Unbounded', sans-serif;
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.03em;
    }
    .dash-sub {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--fdd);
      margin-top: 8px;
    }
    .stat-card {
      background: var(--bgc);
      backdrop-filter: blur(16px);
      border: 1px solid var(--bd);
      border-radius: 18px;
      padding: 24px;
      transition: all 0.35s cubic-bezier(.34,1.56,.64,1);
      position: relative;
      overflow: hidden;
    }
  </style>
</head>
<body class="text-theme-fg m-0 p-0 overflow-hidden" style="background: var(--bg);">
  <div style="display: flex; height: 100vh; overflow: hidden;">
    <%- include('../partials/teacher_sidebar') %>
    
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
      <main style="flex: 1; overflow-y: auto; overflow-x: hidden;">
        <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
          <header class="mb-10 flex items-center justify-between">
            <div>
              <h1 class="dash-greeting">Edit <span style="color: var(--pt);">Teacher</span></h1>
              <p class="dash-sub">Update <%= teacher.teacherName %>'s credentials</p>
            </div>
            <a href="/teacher/dashboard" class="btn-outline-purple flex items-center gap-2 py-2 px-4 rounded-xl text-xs font-bold uppercase tracking-wider font-mono">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
              Back to Dashboard
            </a>
          </header>
          
          <div class="stat-card p-6 sm:p-10 max-w-3xl mx-auto mb-10">
            <div class="mb-8 border-b border-theme-bd pb-6 flex items-center gap-4">
              <div class="inline-flex items-center justify-center w-16 h-16 rounded-full text-2xl font-black object-cover" style="background: var(--bgch); color: var(--pt); border: 2px solid var(--p);">
                <%= teacher.teacherName.charAt(0).toUpperCase() %>
              </div>
              <div>
                <h2 class="text-lg font-bold tracking-tight text-theme-fg" style="font-family: 'Unbounded', sans-serif;"><%= teacher.teacherName %></h2>
                <p class="text-[10px] text-theme-fdd mt-1 font-mono uppercase tracking-wider font-bold"><%= teacher.teacherId %></p>
              </div>
            </div>

          <form id="edit-teacher-form" action="/teacher/edit_teacher/<%= teacher._id %>" method="POST" class="space-y-6">
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="teacherId" class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Teacher ID</label>
                <input type="text" id="teacherId" value="<%= teacher.teacherId %>" disabled class="w-full bg-theme-bgc text-theme-fdd border border-theme-b rounded-xl focus:outline-none py-3 px-4 font-semibold text-sm cursor-not-allowed opacity-70" />
              </div>

              <div>
                <label for="teacherName" class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Teacher Name</label>
                <input type="text" id="teacherName" name="teacherName" value="<%= teacher.teacherName %>" class="w-full bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p focus:outline-none py-3 px-4 font-semibold text-sm" required />
              </div>

              <div class="sm:col-span-2">
                <label for="email" class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Email Address</label>
                <input type="email" id="email" name="email" value="<%= teacher.email %>" class="w-full bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p focus:outline-none py-3 px-4 font-semibold text-sm" required />
              </div>

              <div class="sm:col-span-2">
                <label for="subjects" class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Subjects</label>
                <input type="text" id="subjects" name="subjects" value="<%= teacher.subjects %>" class="w-full bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p focus:outline-none py-3 px-4 font-semibold text-sm" />
              </div>

              <div class="sm:col-span-2">
                <label for="password" class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">New Password <span class="text-theme-fdd/60 normal-case font-normal">(leave blank to keep current)</span></label>
                <input type="password" id="password" name="password" placeholder="••••••••" class="w-full bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p focus:outline-none py-3 px-4 font-semibold text-sm" />
              </div>
            </div>

            <div class="pt-8 border-t border-theme-bd flex gap-4 mt-8">
              <a href="/teacher/dashboard" class="w-full py-3 px-6 rounded-xl text-center font-bold text-theme-fdd hover:text-theme-fg hover:bg-theme-bg2 transition-colors border border-transparent">
                Cancel
              </a>
              <button type="submit" class="w-full py-3 px-8 btn-solid-purple text-lg shadow-md">
                Save Changes
              </button>
            </div>
          </form>

          <div id="message-box" class="mt-6 p-4 rounded-md text-center hidden"></div>
        </div>
      </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const editForm = document.getElementById("edit-teacher-form");
      const messageBox = document.getElementById("message-box");

      function showMessage(message, type = "success") {
        messageBox.textContent = message;
        messageBox.classList.remove(
          "hidden",
          "bg-red-100",
          "text-red-700",
          "bg-green-100",
          "text-green-700"
        );
        if (type === "success") {
          messageBox.classList.add("bg-green-100", "text-green-700");
        } else if (type === "error") {
          messageBox.classList.add("bg-red-100", "text-red-700");
        }
        messageBox.classList.remove("hidden");
        setTimeout(() => {
          messageBox.classList.add("hidden");
        }, 3000);
      }

      editForm.addEventListener("submit", (e) => {
        showMessage("Teacher profile updated successfully!");
      });
    });
  </script>
      </main>
    </div>
  </div>
</body>


</html>