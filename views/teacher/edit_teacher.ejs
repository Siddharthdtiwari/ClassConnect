<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Teacher</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body {
      font-family: "Inter", sans-serif;
    }

    .bg-brand-background {
      background-color: #fafafa;
    }

    .premium-card {
      background: #ffffff;
      border: 1px solid rgba(0, 0, 0, 0.04);
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05),
                  0 10px 15px -3px rgba(0, 0, 0, 0.02),
                  0 25px 50px -12px rgba(93, 58, 155, 0.08);
      border-radius: 1.5rem;
    }

    .text-brand-purple {
      color: #5d3a9b;
    }

    .border-brand-purple {
      border-color: #5d3a9b;
    }

    .btn-solid-purple {
      background-color: #5d3a9b;
      color: #fff;
      font-weight: 600;
      transition: all 0.3s ease;
      border-radius: 0.75rem;
      border: 1px solid #5d3a9b;
      padding: 0.75rem 1.5rem;
      box-shadow: 0 4px 6px -1px rgba(93, 58, 155, 0.2);
    }

    .btn-solid-purple:hover {
      background-color: #4b2d84;
      border-color: #4b2d84;
      box-shadow: 0 10px 15px -3px rgba(93, 58, 155, 0.3);
      transform: translateY(-1px);
    }

    .soft-input {
      background-color: #f8f9fa;
      border: 1px solid #e5e7eb;
      transition: all 0.2s ease;
    }
    
    .soft-input:focus {
      background-color: #ffffff;
      border-color: #5d3a9b;
      box-shadow: 0 0 0 4px rgba(93, 58, 155, 0.1);
    }
  </style>
</head>

<%- include('../partials/background') %>

<body class="bg-brand-background text-gray-800">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-12 min-h-screen flex flex-col items-center justify-center">
    
    <div class="w-full max-w-2xl">
      <div class="premium-card overflow-hidden">
        
        <div class="h-40 bg-[#f8f9fa] border-b border-gray-100 relative overflow-hidden">
          <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(#5d3a9b 0.5px, transparent 0.5px); background-size: 16px 16px;"></div>
          
          <a href="/teacher/dashboard" class="absolute top-6 left-6 text-gray-600 hover:text-brand-purple font-semibold flex items-center gap-2 transition-colors z-10 bg-white px-4 py-2 rounded-full shadow-sm text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Back to Dashboard
          </a>
        </div>

        <div class="p-8 sm:p-12 pt-0">
          <div class="mb-10 -mt-20 relative z-10 flex flex-col sm:flex-row items-center sm:items-end gap-6 text-center sm:text-left">
            <div class="p-2 bg-white rounded-full shadow-md">
              <div class="inline-flex items-center justify-center w-32 h-32 bg-[#f8f9fa] rounded-full text-5xl text-brand-purple font-black border-4 border-white object-cover">
                <%= teacher.teacherName.charAt(0).toUpperCase() %>
              </div>
            </div>
            <div class="pb-2">
              <h1 class="text-3xl font-black text-gray-900 tracking-tight">Edit Teacher</h1>
              <p class="text-gray-500 font-medium mt-1">Update <%= teacher.teacherName %>'s credentials.</p>
            </div>
          </div>

          <form id="edit-teacher-form" action="/teacher/edit_teacher/<%= teacher._id %>" method="POST" class="space-y-6">
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="teacherId" class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Teacher ID</label>
                <input type="text" id="teacherId" value="<%= teacher.teacherId %>" disabled class="soft-input mt-1 block w-full rounded-xl py-3 px-4 text-gray-500 cursor-not-allowed" />
              </div>

              <div>
                <label for="teacherName" class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Teacher Name</label>
                <input type="text" id="teacherName" name="teacherName" value="<%= teacher.teacherName %>" class="soft-input mt-1 block w-full rounded-xl py-3 px-4 font-semibold text-gray-900 outline-none" required />
              </div>

              <div class="sm:col-span-2">
                <label for="email" class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Email Address</label>
                <input type="email" id="email" name="email" value="<%= teacher.email %>" class="soft-input mt-1 block w-full rounded-xl py-3 px-4 font-semibold text-gray-900 outline-none" required />
              </div>

              <div class="sm:col-span-2">
                <label for="subjects" class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Subjects</label>
                <input type="text" id="subjects" name="subjects" value="<%= teacher.subjects %>" class="soft-input mt-1 block w-full rounded-xl py-3 px-4 font-semibold text-gray-900 outline-none" />
              </div>

              <div class="sm:col-span-2">
                <label for="password" class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">New Password <span class="text-gray-400 normal-case font-normal">(leave blank to keep current)</span></label>
                <input type="password" id="password" name="password" placeholder="••••••••" class="soft-input mt-1 block w-full rounded-xl py-3 px-4 font-semibold text-gray-900 outline-none" />
              </div>
            </div>

            <div class="pt-6 border-t border-gray-100 flex gap-4 mt-8">
              <a href="/teacher/dashboard" class="w-full py-4 px-4 rounded-xl text-center font-bold text-gray-600 bg-gray-100 hover:bg-gray-200 transition-colors">
                Cancel
              </a>
              <button type="submit" class="w-full py-4 px-4 btn-solid-purple text-lg">
                Save Changes
              </button>
            </div>
          </form>

          <div id="message-box" class="mt-6 p-4 rounded-md text-center hidden"></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const editForm = document.getElementById("edit-teacher-form");
      const messageBox = document.getElementById("message-box");

      function showMessage(message, type = "success") {
        messageBox.textContent = message;
        messageBox.classList.remove(
          "hidden",
          "bg-red-100",
          "text-red-700",
          "bg-green-100",
          "text-green-700"
        );
        if (type === "success") {
          messageBox.classList.add("bg-green-100", "text-green-700");
        } else if (type === "error") {
          messageBox.classList.add("bg-red-100", "text-red-700");
        }
        messageBox.classList.remove("hidden");
        setTimeout(() => {
          messageBox.classList.add("hidden");
        }, 3000);
      }

      editForm.addEventListener("submit", (e) => {
        showMessage("Teacher profile updated successfully!");
      });
    });
  </script>
</body>

</html>