<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI Question Paper Generator | Tuition Hub</title>
  
  <%- include('../partials/background') %>
  
  <!-- TinyMCE and html2pdf for AI paper generation -->
  <script src="https://cdn.jsdelivr.net/npm/tinymce@6/tinymce.min.js" referrerpolicy="origin"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  <script src="/js/subjects.js"></script>

  <style>
    /* Premium Dashboard Styles */
    .dash-greeting {
      font-family: 'Unbounded', sans-serif;
      font-size: clamp(1.6rem, 3.5vw, 2.6rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.03em;
    }
    .dash-sub {
      font-family: 'Space Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--fdd);
      margin-top: 6px;
    }
    .workspace-container {
      height: calc(100vh - 160px);
      min-height: 520px;
    }
    .canvas-card {
      background: rgba(255, 255, 255, 0.45);
      backdrop-filter: blur(16px);
      border: 1px solid var(--bd);
      border-radius: 18px;
      padding: 16px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
    }
    /* TinyMCE wrapper styling */
    .editor-wrapper {
      height: calc(100% - 50px);
      background: #fff;
      border: 1px solid var(--bd);
      border-radius: 12px;
      overflow: hidden;
    }
    /* Scrollbar style */
    .custom-scrollbar::-webkit-scrollbar {
      width: 4px;
      height: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
      background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: var(--bd);
      border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
      background: var(--pt);
    }
    .tox-tinymce {
      border: none !important;
      height: 100% !important;
    }
  </style>
</head>

<body class="text-theme-fg m-0 p-0 overflow-hidden" style="background: var(--bg);">
  <div style="display: flex; height: 100vh; overflow: hidden;">
    <%- include('../partials/teacher_sidebar') %>
    
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
      <main style="flex: 1; overflow-y: auto; overflow-x: hidden;">
        <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 flex flex-col h-full justify-between">

          <!-- Header -->
          <header class="mb-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 shrink-0">
            <div>
              <h1 class="dash-greeting">AI Paper <span style="color: var(--pt);">Generator</span></h1>
              <p class="dash-sub">Faculty Command Center · Automated Assessment Builder</p>
            </div>
            <div class="flex gap-3 flex-wrap items-center">
              <a href="/teacher/manage_tests" class="btn-outline-purple flex items-center gap-2 text-[10px] font-bold uppercase tracking-wider font-mono">
                <svg class="w-3.5 h-3.5 text-theme-pt" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Back to Tests
              </a>
            </div>
          </header>

          <!-- Unified Workspace Panel (LHS editor, RHS controller) -->
          <div class="flex flex-col lg:flex-row gap-6 items-stretch workspace-container flex-grow mb-4">
            
            <!-- LHS: MS Editor Canvas (65% width) -->
            <div class="w-full lg:w-[65%] flex flex-col h-full canvas-card">
              <div class="flex justify-between items-center bg-theme-bgc/60 backdrop-blur-md p-3 rounded-xl border border-theme-bd mb-3 shrink-0">
                <div class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-full bg-emerald-400 animate-pulse"></span>
                  <h3 class="text-xs font-bold uppercase tracking-widest font-mono text-theme-pt">Document Editor Canvas</h3>
                </div>
                <div class="text-[9px] font-mono text-theme-fdd">Edit contents manually anytime</div>
              </div>
              
              <!-- Paper Canvas Wrapper -->
              <div class="editor-wrapper shadow-inner">
                <textarea id="tinymce-editor"></textarea>
              </div>
            </div>

            <!-- RHS: AI Bot & Controls Panel (35% width) -->
            <div class="w-full lg:w-[35%] flex flex-col h-full canvas-card">
              <!-- Tabs -->
              <div class="flex border-b border-theme-bd mb-4 shrink-0">
                <button type="button" id="tab-bot-btn" class="flex-1 pb-3 text-[11px] font-bold uppercase tracking-wider font-mono border-b-2 border-theme-pt text-theme-pt transition-all focus:outline-none">
                  AI Assistant
                </button>
                <button type="button" id="tab-save-btn" class="flex-1 pb-3 text-[11px] font-bold uppercase tracking-wider font-mono border-b-2 border-transparent text-theme-fdd hover:text-theme-fg transition-all focus:outline-none">
                  Save & Download
                </button>
              </div>

              <!-- Content Scroll Area -->
              <div class="flex-1 overflow-y-auto pr-1 custom-scrollbar flex flex-col justify-between h-full">
                
                <!-- Panel 1: AI Assistant Bot Chat -->
                <div id="panel-bot" class="flex-grow flex flex-col justify-between gap-4 h-full">
                  
                  <!-- Chat Message List -->
                  <div id="chat-messages" class="flex-grow overflow-y-auto space-y-4 pr-1 min-h-[200px] max-h-[360px] custom-scrollbar mb-2">
                    <!-- Initial Bot Message -->
                    <div class="flex items-start gap-2.5">
                      <div class="w-7 h-7 rounded-full bg-gradient-to-tr from-theme-p to-theme-pt flex items-center justify-center text-white text-xs font-bold shadow-md shrink-0">
                        </div>
                      <div class="flex flex-col w-full max-w-[280px] p-3 border border-theme-bd bg-theme-bgc/60 rounded-r-xl rounded-bl-xl shadow-sm">
                        <div class="flex items-center space-x-2">
                          <span class="text-[10px] font-bold text-theme-pt font-mono">Paper Bot</span>
                          <span class="text-[8px] font-medium text-theme-fdd font-mono">online</span>
                        </div>
                        <p class="text-xs font-normal py-1.5 text-theme-fg leading-relaxed">
                          Hello! Paste your textbook context below to generate a new question paper. Once generated, you can ask me to modify it anytime!
                        </p>
                      </div>
                    </div>
                  </div>

                  <!-- Typing Loader (shown inline in chat if generating/refining) -->
                  <div id="chat-bot-loader" class="hidden flex items-start gap-2.5 shrink-0">
                    <div class="w-7 h-7 rounded-full bg-gradient-to-tr from-theme-p to-theme-pt flex items-center justify-center text-white text-xs font-bold shadow-md shrink-0 animate-pulse">
                      </div>
                    <div class="flex flex-col w-full max-w-[280px] p-3 border border-theme-bd bg-theme-bgc/60 rounded-r-xl rounded-bl-xl shadow-sm">
                      <div class="flex items-center space-x-2">
                        <span class="text-[10px] font-bold text-theme-pt font-mono">Paper Bot</span>
                        <span class="text-[8px] font-medium text-theme-fdd font-mono animate-pulse">typing...</span>
                      </div>
                      <div class="py-2 flex items-center gap-1.5">
                        <div class="w-1.5 h-1.5 rounded-full bg-theme-pt animate-bounce" style="animation-delay: 0ms"></div>
                        <div class="w-1.5 h-1.5 rounded-full bg-theme-pt animate-bounce" style="animation-delay: 150ms"></div>
                        <div class="w-1.5 h-1.5 rounded-full bg-theme-pt animate-bounce" style="animation-delay: 300ms"></div>
                        <span class="text-[10px] text-theme-fdd ml-1 animate-pulse" id="loader-text">AI is thinking...</span>
                      </div>
                    </div>
                  </div>

                  <!-- Bot Action Setup (Initial Params) -->
                  <div id="bot-setup-area" class="border border-theme-bd rounded-xl p-4 bg-theme-bgc/50 shrink-0 relative overflow-hidden transition-all duration-300">
                    <h4 class="text-[9px] font-bold uppercase tracking-wider font-mono text-theme-pt mb-3 flex items-center gap-1">
                      <span></span> Setup Starting Parameters
                    </h4>
                    
                    <form id="ai-parameter-form" class="space-y-3">
                      <div>
                        <label for="ai-context" class="block text-[8px] font-bold text-theme-fdd mb-1 font-mono uppercase tracking-widest">Textbook Context / Question Dump</label>
                        <textarea id="ai-context" rows="4" class="w-full text-xs border border-theme-b rounded-lg p-2 bg-theme-bgc focus:outline-none focus:border-theme-p transition-all placeholder-theme-fdd custom-scrollbar" placeholder="Paste source chapters or sample questions here..." required></textarea>
                      </div>

                      <div class="grid grid-cols-2 gap-2">
                        <div>
                          <label for="ai-batch" class="block text-[8px] font-bold text-theme-fdd mb-1 font-mono uppercase tracking-widest">Batch</label>
                          <select id="ai-batch" class="w-full text-xs border border-theme-b rounded-lg p-2 bg-theme-bgc focus:outline-none focus:border-theme-p transition-all" required onchange="handleAiBatchChange(this)">
                            <option value="" disabled selected>Select Batch...</option>
                            <% batches.forEach(batch => { %>
                            <option value="<%= batch.name %>"><%= batch.name %></option>
                            <% }) %>
                          </select>
                        </div>
                        <div>
                          <label for="ai-subject" class="block text-[8px] font-bold text-theme-fdd mb-1 font-mono uppercase tracking-widest">Subject</label>
                          <select id="ai-subject" class="w-full text-xs border border-theme-b rounded-lg p-2 bg-theme-bgc focus:outline-none focus:border-theme-p transition-all" required>
                            <option value="" disabled selected>Select Subject...</option>
                          </select>
                        </div>
                      </div>

                      <div class="grid grid-cols-3 gap-2 mt-2">
                        <div>
                          <label for="ai-test-name" class="block text-[8px] font-bold text-theme-fdd mb-1 font-mono uppercase tracking-widest">Test Name / No.</label>
                          <input type="text" id="ai-test-name" class="w-full text-xs border border-theme-b rounded-lg p-2 bg-theme-bgc focus:outline-none focus:border-theme-p transition-all" placeholder="e.g. Class Test: 02" required />
                        </div>
                        <div>
                          <label for="ai-time" class="block text-[8px] font-bold text-theme-fdd mb-1 font-mono uppercase tracking-widest">Time (Optional)</label>
                          <input type="text" id="ai-time" class="w-full text-xs border border-theme-b rounded-lg p-2 bg-theme-bgc focus:outline-none focus:border-theme-p transition-all" placeholder="e.g. 1 Hours" />
                        </div>
                        <div>
                          <label for="ai-marks" class="block text-[8px] font-bold text-theme-fdd mb-1 font-mono uppercase tracking-widest">Marks (Optional)</label>
                          <input type="number" id="ai-marks" class="w-full text-xs border border-theme-b rounded-lg p-2 bg-theme-bgc focus:outline-none focus:border-theme-p transition-all" placeholder="50" min="1" />
                        </div>
                      </div>

                      <!-- Checkboxes -->
                      <div class="flex flex-col gap-2 mt-2 border border-theme-bd rounded p-2 bg-theme-bgc/30">
                        <label class="flex items-center gap-1.5 text-[10px] font-bold text-theme-fg cursor-pointer">
                          <input type="checkbox" id="ai-include-logo" class="form-checkbox text-theme-p rounded" checked />
                          Include Watermark Logo
                        </label>
                        <label class="flex items-center gap-1.5 text-[10px] font-bold text-theme-fg cursor-pointer">
                          <input type="checkbox" id="ai-include-slanting" class="form-checkbox text-theme-p rounded" checked />
                          Include Slanting "Tuition Hub Edu Center"
                        </label>
                      </div>

                      <div>
                        <label for="ai-instructions" class="block text-[8px] font-bold text-theme-fdd mb-1 font-mono uppercase tracking-widest">Instructions (Optional)</label>
                        <input type="text" id="ai-instructions" class="w-full text-xs border border-theme-b rounded-lg p-2 bg-theme-bgc focus:outline-none focus:border-theme-p transition-all placeholder-theme-fdd" placeholder="e.g. 5 MCQs, 3 short answer" />
                      </div>

                      <button type="submit" class="w-full py-2.5 btn-solid-purple flex justify-center items-center gap-1.5 shadow-md text-xs font-bold uppercase tracking-wider font-mono">
                        <span>Generate Question Paper</span>
                      </button>
                    </form>
                  </div>

                  <!-- Bot Refine area (chat prompt inputs, shown after generation) -->
                  <div id="bot-refine-area" class="hidden border border-theme-bd rounded-xl p-3 bg-theme-bgc/50 shrink-0">
                    <form id="ai-refinement-form" class="flex gap-2 items-end">
                      <div class="flex-1">
                        <label for="ai-refine-input" class="block text-[8px] font-bold text-theme-fdd mb-1 font-mono uppercase tracking-widest">Modify paper with AI bot</label>
                        <textarea id="ai-refine-input" rows="2" class="w-full text-xs border border-theme-b rounded-lg p-2 bg-theme-bgc focus:outline-none focus:border-theme-p transition-all placeholder-theme-fdd custom-scrollbar" placeholder="Describe edits (e.g. 'Add 3 MCQs', 'change marks to 30')" required></textarea>
                      </div>
                      <button type="submit" class="p-2.5 btn-solid-purple rounded-lg shadow-md shrink-0 flex items-center justify-center h-10 w-10">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                      </button>
                    </form>
                  </div>

                </div>

                <!-- Panel 2: Register & Save (Hidden by default) -->
                <div id="panel-save" class="hidden space-y-4 h-full flex flex-col justify-between">
                  <form id="create-test-form" class="space-y-3">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

                    <div>
                      <label for="record-test-name" class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Test Name</label>
                      <input type="text" id="record-test-name" name="testName" class="w-full px-3 py-2 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:outline-none focus:border-theme-p text-sm font-semibold" required />
                    </div>

                    <div>
                      <label for="record-batchId" class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Select Batch</label>
                      <select id="record-batchId" name="batchId" class="w-full px-3 py-2 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:outline-none focus:border-theme-p text-sm font-semibold" required onchange="handleBatchChange(this)">
                        <option value="" disabled selected>Select Batch...</option>
                        <% batches.forEach(batch => { %>
                        <option value="<%= batch._id %>"><%= batch.name %></option>
                        <% }) %>
                      </select>
                    </div>

                    <div>
                      <label for="record-subject" class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Subject</label>
                      <select id="record-subject" name="subject" class="w-full px-3 py-2 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:outline-none focus:border-theme-p text-sm font-semibold" required>
                        <option value="" disabled selected>Select Subject...</option>
                      </select>
                    </div>

                    <div>
                      <label for="record-test-date" class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Test Conduct Date</label>
                      <input type="date" id="record-test-date" name="testDate" class="w-full px-3 py-2 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:outline-none focus:border-theme-p text-sm font-semibold" required />
                    </div>

                    <!-- Hidden parameters pre-filled from Step 1 form -->
                    <input type="hidden" id="record-topic" name="topic" />
                    <input type="hidden" id="record-total-marks" name="totalMarks" />

                    <button type="submit" id="submit-record-btn" class="w-full py-3 btn-solid-purple flex justify-center items-center gap-2 shadow-md">
                      <span>Create Test Record ✓</span>
                    </button>
                  </form>

                  <div class="space-y-2 shrink-0">
                    <hr class="border-theme-bd" />
                    <div class="grid grid-cols-2 gap-2">
                      <button type="button" id="preview-pdf-btn" class="py-2.5 bg-theme-pt/10 text-theme-pt border border-theme-pt/20 rounded-xl hover:bg-theme-pt/20 text-[10px] font-bold uppercase tracking-wider font-mono flex items-center justify-center gap-1 transition-all">
                        <span> Preview PDF</span>
                      </button>
                      <button type="button" id="download-pdf-btn" class="py-2.5 bg-theme-lt/10 text-theme-lt border border-theme-lt/20 rounded-xl hover:bg-theme-lt/20 text-[10px] font-bold uppercase tracking-wider font-mono flex items-center justify-center gap-1 transition-all">
                        <span> Download</span>
                      </button>
                    </div>
                    <div id="record-message-box" class="p-3 rounded-lg text-center hidden text-xs font-semibold"></div>
                  </div>
                </div>

              </div>
            </div>

          </div>

        </div>
      </main>
    </div>
  </div>

  <script>
    function handleBatchChange(selectEl) {
      const option = selectEl.options[selectEl.selectedIndex];
      const batchName = option ? option.text : '';
      const subjectDropdown = document.getElementById('record-subject');
      if (typeof updateSubjectDropdowns !== 'undefined') {
        updateSubjectDropdowns([subjectDropdown], batchName);
      }
    }

    function handleAiBatchChange(selectEl) {
      const batchName = selectEl.value;
      const subjectDropdown = document.getElementById('ai-subject');
      if (typeof updateSubjectDropdowns !== 'undefined') {
        updateSubjectDropdowns([subjectDropdown], batchName);
      }
    }

    function showRecordMessage(message, type) {
      const box = document.getElementById('record-message-box');
      box.textContent = message;
      box.className = `p-3 rounded-lg text-center text-xs font-semibold ${
        type === 'success' 
          ? 'bg-[var(--gg)] text-brand-green border border-[var(--gt)]/20' 
          : 'bg-[var(--rg)] text-brand-red border border-[var(--rt)]/20'
      }`;
      box.classList.remove('hidden');
    }

    document.addEventListener("DOMContentLoaded", () => {
      // Set default testDate to today
      const today = new Date().toISOString().split('T')[0];
      document.getElementById('record-test-date').value = today;

      // Tab selectors
      const tabBotBtn = document.getElementById("tab-bot-btn");
      const tabSaveBtn = document.getElementById("tab-save-btn");
      const panelBot = document.getElementById("panel-bot");
      const panelSave = document.getElementById("panel-save");

      tabBotBtn.addEventListener("click", () => {
        tabBotBtn.className = "flex-1 pb-3 text-[11px] font-bold uppercase tracking-wider font-mono border-b-2 border-theme-pt text-theme-pt transition-all focus:outline-none";
        tabSaveBtn.className = "flex-1 pb-3 text-[11px] font-bold uppercase tracking-wider font-mono border-b-2 border-transparent text-theme-fdd hover:text-theme-fg transition-all focus:outline-none";
        panelBot.classList.remove("hidden");
        panelSave.classList.add("hidden");
      });

      tabSaveBtn.addEventListener("click", () => {
        tabSaveBtn.className = "flex-1 pb-3 text-[11px] font-bold uppercase tracking-wider font-mono border-b-2 border-theme-pt text-theme-pt transition-all focus:outline-none";
        tabBotBtn.className = "flex-1 pb-3 text-[11px] font-bold uppercase tracking-wider font-mono border-b-2 border-transparent text-theme-fdd hover:text-theme-fg transition-all focus:outline-none";
        panelSave.classList.remove("hidden");
        panelBot.classList.add("hidden");
      });

      // AI forms and chat refs
      const aiParameterForm = document.getElementById("ai-parameter-form");
      const aiContext = document.getElementById("ai-context");
      const aiSubject = document.getElementById("ai-subject");
      const aiTopic = document.getElementById("ai-topic");
      const aiMarks = document.getElementById("ai-marks");
      const aiInstructions = document.getElementById("ai-instructions");
      
      const botSetupArea = document.getElementById("bot-setup-area");
      const botRefineArea = document.getElementById("bot-refine-area");
      const chatMessages = document.getElementById("chat-messages");
      const chatLoader = document.getElementById("chat-bot-loader");
      const loaderText = document.getElementById("loader-text");

      const aiRefinementForm = document.getElementById("ai-refinement-form");
      const aiRefineInput = document.getElementById("ai-refine-input");
      const downloadPdfBtn = document.getElementById("download-pdf-btn");

      // Initialize TinyMCE right away
      tinymce.init({
        selector: '#tinymce-editor',
        height: '100%',
        plugins: 'table lists link image preview code',
        toolbar: 'undo redo | blocks | bold italic underline | alignleft aligncenter alignright alignjustify | bullist numlist | table image | removeformat | code',
        branding: false,
        promotion: false,
        valid_elements: '*[*]',
        valid_children: '+body[style]',
        content_style: `
          body {
            font-family: 'Inter', sans-serif;
            background-color: #f3f4f6;
            margin: 0;
            padding: 20px;
          }
          .paper-container {
             box-shadow: 0 4px 6px rgba(0,0,0,0.1);
             margin: 0 auto;
             max-width: 800px;
          }
        `
      });

      // Helper to append messages to the RHS chat log
      function appendChatMessage(sender, text) {
        const msgDiv = document.createElement("div");
        msgDiv.className = "flex items-start gap-2.5 animate-fade-in";
        
        const avatar = sender === 'user' ? '' : '';
        const senderName = sender === 'user' ? 'You' : 'Paper Bot';
        const senderClass = sender === 'user' ? 'text-theme-lt' : 'text-theme-pt';
        const bubbleBg = sender === 'user' ? 'bg-theme-bgc' : 'bg-theme-bgc/60';
        
        msgDiv.innerHTML = `
          <div class="w-7 h-7 rounded-full bg-gradient-to-tr ${sender === 'user' ? 'from-theme-lt to-purple-500' : 'from-theme-p to-theme-pt'} flex items-center justify-center text-white text-xs font-bold shadow-md shrink-0">
            ${avatar}
          </div>
          <div class="flex flex-col w-full max-w-[280px] p-3 border border-theme-bd ${bubbleBg} rounded-r-xl rounded-bl-xl shadow-sm">
            <div class="flex items-center space-x-2">
              <span class="text-[10px] font-bold ${senderClass} font-mono">${senderName}</span>
              <span class="text-[8px] font-medium text-theme-fdd font-mono">just now</span>
            </div>
            <p class="text-xs font-normal py-1.5 text-theme-fg leading-relaxed">${text}</p>
          </div>
        `;
        
        chatMessages.appendChild(msgDiv);
        chatMessages.scrollTop = chatMessages.scrollHeight;
      }

      // Initial generation form submit
      aiParameterForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        const contextText = aiContext.value.trim();
        if (!contextText) return;

        botSetupArea.classList.add("pointer-events-none");
        botSetupArea.style.opacity = "0.5";
        
        loaderText.textContent = "Generating question paper...";
        chatLoader.classList.remove("hidden");
        chatMessages.scrollTop = chatMessages.scrollHeight;

        const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';

        const batchName = document.getElementById("ai-batch").value;
        const testName = document.getElementById("ai-test-name").value;
        const time = document.getElementById("ai-time").value;
        const includeLogo = document.getElementById("ai-include-logo").checked;
        const includeSlanting = document.getElementById("ai-include-slanting").checked;

        try {
          const res = await fetch("/api/ai/generate_paper", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "x-csrf-token": csrfToken
            },
            body: JSON.stringify({
              contextText,
              batchName,
              subject: aiSubject.value,
              testName,
              time,
              totalMarks: aiMarks.value,
              instructions: aiInstructions.value,
              includeLogo,
              includeSlanting
            })
          });

          const data = await res.json();
          chatLoader.classList.add("hidden");

          if (data.success) {
            appendChatMessage('user', `Generate a ${aiMarks.value} marks question paper for ${aiSubject.value}.`);
            appendChatMessage('bot', `I've successfully generated your question paper! You can view and edit the text directly on the canvas to the left. If you need any adjustments, type them in the box below.`);

            botSetupArea.classList.add("hidden");
            botRefineArea.classList.remove("hidden");
            
            // Prefill side form parameters
            document.getElementById('record-test-name').value = testName;
            document.getElementById('record-total-marks').value = aiMarks.value;

            if (tinymce.get("tinymce-editor")) {
              tinymce.get("tinymce-editor").setContent(data.html);
            }
          } else {
            alert(data.message || "Failed to generate paper.");
            botSetupArea.classList.remove("pointer-events-none");
            botSetupArea.style.opacity = "1";
          }
        } catch (err) {
          console.error(err);
          alert("Error generating question paper.");
          chatLoader.classList.add("hidden");
          botSetupArea.classList.remove("pointer-events-none");
          botSetupArea.style.opacity = "1";
        }
      });

      // Follow-up chat refinement form submit
      aiRefinementForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        const refinePrompt = aiRefineInput.value.trim();
        if (!refinePrompt) return;

        let currentHtml = "";
        if (tinymce.get("tinymce-editor")) {
          currentHtml = tinymce.get("tinymce-editor").getContent();
        }

        aiRefineInput.disabled = true;
        const submitBtn = aiRefinementForm.querySelector("button[type='submit']");
        submitBtn.disabled = true;

        loaderText.textContent = "AI is modifying document...";
        chatLoader.classList.remove("hidden");
        chatMessages.scrollTop = chatMessages.scrollHeight;

        const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';

        try {
          const res = await fetch("/api/ai/generate_paper", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "x-csrf-token": csrfToken
            },
            body: JSON.stringify({
              currentHtml,
              refinePrompt,
              subject: aiSubject.value,
              topic: aiTopic.value,
              totalMarks: aiMarks.value
            })
          });

          const data = await res.json();
          chatLoader.classList.add("hidden");
          aiRefineInput.disabled = false;
          submitBtn.disabled = false;

          if (data.success) {
            appendChatMessage('user', refinePrompt);
            appendChatMessage('bot', `I've updated the question paper on the LHS editor based on your prompt: "${refinePrompt}".`);
            aiRefineInput.value = "";

            if (tinymce.get("tinymce-editor")) {
              tinymce.get("tinymce-editor").setContent(data.html);
            }
          } else {
            alert(data.message || "Failed to refine paper.");
          }
        } catch (err) {
          console.error(err);
          alert("Error refining question paper.");
          chatLoader.classList.add("hidden");
          aiRefineInput.disabled = false;
          submitBtn.disabled = false;
        }
      });

      // PDF options
      function getPdfOptions() {
        return {
          margin: 15,
          filename: 'question-paper.pdf',
          image: { type: 'jpeg', quality: 0.98 },
          html2canvas: { scale: 2, useCORS: true },
          jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
        };
      }

      // Download PDF
      downloadPdfBtn.addEventListener("click", () => {
        if (tinymce.get("tinymce-editor")) {
          const content = tinymce.get("tinymce-editor").getContent();
          const opt = getPdfOptions();
          html2pdf().from(content).set(opt).save();
        }
      });

      // Preview PDF
      const previewPdfBtn = document.getElementById("preview-pdf-btn");
      previewPdfBtn.addEventListener("click", async () => {
        if (tinymce.get("tinymce-editor")) {
          const content = tinymce.get("tinymce-editor").getContent();
          const opt = getPdfOptions();
          
          const originalText = previewPdfBtn.innerHTML;
          previewPdfBtn.disabled = true;
          previewPdfBtn.innerHTML = `<span>Loading...</span>`;
          
          try {
            const pdfBlob = await html2pdf().from(content).set(opt).output('blob');
            const blobUrl = URL.createObjectURL(pdfBlob);
            window.open(blobUrl, '_blank');
          } catch (err) {
            console.error(err);
            alert("Failed to preview PDF.");
          } finally {
            previewPdfBtn.disabled = false;
            previewPdfBtn.innerHTML = originalText;
          }
        }
      });

      // Create Test Record Form Submit
      document.getElementById("create-test-form").addEventListener("submit", async function(e) {
        e.preventDefault();

        if (!tinymce.get("tinymce-editor")) {
          alert("Editor error. Cannot save.");
          return;
        }

        const submitBtn = document.getElementById("submit-record-btn");
        const originalText = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = `<span>Processing PDF...</span>`;

        const content = tinymce.get("tinymce-editor").getContent();
        const opt = getPdfOptions();

        try {
          // Compile HTML into PDF Blob
          const pdfBlob = await html2pdf().from(content).set(opt).output('blob');
          const file = new File([pdfBlob], "ai-generated-paper.pdf", { type: "application/pdf" });
          
          const formData = new FormData(this);
          formData.append("questionPaperFile", file);

          submitBtn.innerHTML = `<span>Saving Record...</span>`;

          const res = await fetch("/teacher/add_test", {
            method: "POST",
            body: formData,
          });

          const result = await res.json();

          if (result.success) {
            showRecordMessage(result.message, "success");
            setTimeout(() => {
              window.location.href = "/teacher/manage_tests";
            }, 1200);
          } else {
            showRecordMessage(result.message, "error");
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
          }
        } catch (err) {
          console.error(err);
          showRecordMessage("Network Error: Failed to create test record.", "error");
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
        }
      });

    });
  </script>
</body>

</html>
