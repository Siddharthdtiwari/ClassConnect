<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tuition Hub - Login</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet" />
  
</head>

<body class="text-theme-fg wrap min-h-screen flex flex-col items-center justify-center relative overflow-hidden">
  <%- include('../partials/background') %>
  
  <a href="/" class="absolute top-6 left-6 inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-theme-fd hover:text-theme-pt transition-colors z-20 bg-theme-bgc border border-theme-b px-4 py-2 rounded-full backdrop-blur-md">
    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
    Home
  </a>

  <div class="content-container w-full max-w-md px-4 relative z-10">
    <div class="glass-card p-8 sm:p-12 flex flex-col items-center relative overflow-hidden text-center">
      <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-theme-p to-theme-lt"></div>
      
      <img src="/images/logo.png" alt="Tuition Hub Logo" class="h-16 w-auto mb-6 drop-shadow-md" />
      
      <h3 class="text-2xl font-unbounded font-extrabold text-theme-fg mb-2 leading-tight">
        Faculty <span class="text-theme-pt">Portal</span>
      </h3>
      <p class="text-sm font-mono text-theme-fd uppercase tracking-wide mb-8">
        Welcome back, Teacher
      </p>

      <form action="/teacher/login" method="POST" class="w-full flex flex-col gap-4">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
        
        <div class="flex flex-col gap-1 text-left">
          <label class="font-mono text-xs text-theme-fdd uppercase tracking-widest">ID Number</label>
          <input type="text" name="teacherId" placeholder="e.g. THEC001" required 
            class="bg-theme-bgc border border-theme-b rounded-lg px-4 py-3 text-sm text-theme-fg outline-none transition-colors focus:border-theme-p focus:bg-theme-bgch placeholder-theme-fdd" />
        </div>
        
        <div class="flex flex-col gap-1 text-left mb-4">
          <label class="font-mono text-xs text-theme-fdd uppercase tracking-widest">Password</label>
          <input type="password" name="password" placeholder="••••••••" required 
            class="bg-theme-bgc border border-theme-b rounded-lg px-4 py-3 text-sm text-theme-fg outline-none transition-colors focus:border-theme-p focus:bg-theme-bgch placeholder-theme-fdd" />
        </div>
        
        <button class="btn-primary w-full py-4 text-sm mt-2" type="submit">Access Dashboard</button>
      </form>

      <% if (typeof error !=='undefined' ) { %>
      <div class="mt-6 bg-[var(--rg)] border border-[var(--rt)]/30 text-brand-red text-xs font-mono p-3 rounded-lg w-full animate-shake">
        <%= error %>
      </div>
      <% } %>
    </div>
  </div>

  <script>
    const loginForm = document.querySelector('form');

    if (loginForm) {
      loginForm.addEventListener('submit', function(e) {
        const btn = this.querySelector('button[type="submit"]');
        btn.disabled = true;
        btn.innerText = "Logging in...";
        btn.style.opacity = "0.7";
        btn.style.cursor = "not-allowed";
      });
    }
  </script>
</body>

</html>