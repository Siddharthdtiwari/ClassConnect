<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Batch Manager | Tuition Hub</title>

  <%- include('../partials/background') %>

  <style>
    /* Premium Dashboard Theme */
    .dash-greeting {
      font-family: 'Unbounded', sans-serif;
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.03em;
    }
    .dash-sub {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--fdd);
      margin-top: 8px;
    }
    .stat-card {
      background: var(--bgc);
      backdrop-filter: blur(16px);
      border: 1px solid var(--bd);
      border-radius: 18px;
      padding: 24px;
      transition: all 0.35s cubic-bezier(.34,1.56,.64,1);
      position: relative;
      overflow: hidden;
    }
    .stat-card::before {
      content: '';
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 0.4s;
      background: radial-gradient(circle at 20% 30%, var(--pg2) 0%, transparent 60%);
      pointer-events: none;
    }
    .stat-card:hover::before { opacity: 1; }
    .stat-card:hover {
      border-color: rgba(124,58,237,0.25);
      transform: translateY(-4px);
      box-shadow: 0 12px 40px var(--pg2);
    }
    .stat-value {
      font-family: 'Unbounded', sans-serif;
      font-size: 2.2rem;
      font-weight: 900;
      line-height: 1;
      position: relative;
      z-index: 1;
    }
    .stat-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--fdd);
      margin-top: 6px;
      position: relative;
      z-index: 1;
    }
    .stat-icon {
      position: absolute;
      top: 20px;
      right: 20px;
      opacity: 0.15;
      z-index: 0;
    }

    /* Search bar */
    .search-wrap {
      position: relative;
      width: 100%;
      max-width: 480px;
    }
    .search-wrap svg {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--fdd);
      pointer-events: none;
    }
    .search-wrap input {
      width: 100%;
      padding: 12px 16px 12px 44px;
      border-radius: 14px;
      border: 1px solid var(--bd);
      background: var(--bgc);
      backdrop-filter: blur(12px);
      color: var(--fg);
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      transition: all 0.3s;
    }
    .search-wrap input::placeholder { color: var(--fdd); }
    .search-wrap input:focus {
      outline: none;
      border-color: var(--pt);
      box-shadow: 0 0 0 3px var(--pg2);
    }

    /* Batch cards grid */
    .batch-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 20px;
    }
    .batch-card {
      background: var(--bgc);
      backdrop-filter: blur(16px);
      border: 1px solid var(--bd);
      border-radius: 18px;
      padding: 24px;
      transition: all 0.35s cubic-bezier(.34,1.56,.64,1);
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .batch-card::before {
      content: '';
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 0.4s;
      background: radial-gradient(circle at 80% 20%, var(--pg2) 0%, transparent 60%);
      pointer-events: none;
    }
    .batch-card:hover::before { opacity: 1; }
    .batch-card:hover {
      border-color: rgba(124,58,237,0.25);
      transform: translateY(-4px);
      box-shadow: 0 12px 40px var(--pg2);
    }
    .batch-card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      position: relative;
      z-index: 1;
    }
    .batch-card-name {
      font-family: 'Unbounded', sans-serif;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--fg);
      line-height: 1.2;
    }
    .batch-status {
      padding: 4px 12px;
      border-radius: 20px;
      font-family: 'Space Mono', monospace;
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .batch-status.active {
      background: rgba(52,211,153,0.12);
      color: var(--gt);
      border: 1px solid rgba(52,211,153,0.25);
    }
    .batch-status.inactive {
      background: rgba(248,113,113,0.10);
      color: var(--rt);
      border: 1px solid rgba(248,113,113,0.20);
    }
    .batch-card-meta {
      display: flex;
      gap: 16px;
      position: relative;
      z-index: 1;
    }
    .batch-meta-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      color: var(--fdd);
      letter-spacing: 0.05em;
    }
    .batch-meta-item .meta-val {
      color: var(--fg);
      font-weight: 700;
      font-size: 0.75rem;
    }
    .batch-card-desc {
      font-size: 0.82rem;
      color: var(--fd);
      line-height: 1.5;
      position: relative;
      z-index: 1;
      flex: 1;
    }
    .batch-card-actions {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      position: relative;
      z-index: 1;
      margin-top: auto;
    }
    .batch-edit-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 18px;
      border-radius: 10px;
      font-family: 'Inter', sans-serif;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--pt);
      background: rgba(124,58,237,0.08);
      border: 1px solid rgba(124,58,237,0.15);
      text-decoration: none;
      transition: all 0.25s;
      cursor: pointer;
    }
    .batch-edit-btn:hover {
      background: rgba(124,58,237,0.15);
      border-color: rgba(124,58,237,0.3);
      transform: translateY(-1px);
    }

    /* Empty state */
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      background: var(--bgc);
      border: 1px dashed var(--bd);
      border-radius: 18px;
    }
    .empty-state-icon { font-size: 3.5rem; margin-bottom: 16px; opacity: 0.4; }
    .empty-state-title {
      font-family: 'Unbounded', sans-serif;
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--fg);
      margin-bottom: 6px;
    }
    .empty-state-sub {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      color: var(--fdd);
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    /* Filter tabs */
    .filter-tab {
      padding: 7px 18px;
      border-radius: 10px;
      border: 1px solid var(--bd);
      background: transparent;
      color: var(--fd);
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.25s;
    }
    .filter-tab:hover { background: var(--bgch); color: var(--fg); }
    .filter-tab.active {
      background: rgba(124,58,237,0.1);
      color: var(--pt);
      border-color: rgba(124,58,237,0.25);
    }

    /* Status toggle in modal */
    .status-toggle {
      display: flex;
      gap: 10px;
    }
    .status-opt {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      border-radius: 12px;
      border: 1px solid var(--bd);
      cursor: pointer;
      transition: all 0.25s;
      flex: 1;
      justify-content: center;
    }
    .status-opt:hover { background: var(--bgch); }
    .status-opt.selected.active-opt {
      border-color: rgba(52,211,153,0.4);
      background: rgba(52,211,153,0.08);
    }
    .status-opt.selected.inactive-opt {
      border-color: rgba(248,113,113,0.4);
      background: rgba(248,113,113,0.08);
    }
    .status-opt .sdot {
      width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
    }
    .status-opt .sdot.green { background: var(--gt); }
    .status-opt .sdot.red { background: var(--rt); }
    .status-opt .slabel {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--fd);
    }
    .status-opt.selected .slabel { color: var(--fg); }
  </style>
</head>

<body class="text-theme-fg m-0 p-0 overflow-hidden" style="background: var(--bg);">
  <div style="display: flex; height: 100vh; overflow: hidden;">
    <%- include('../partials/teacher_sidebar') %>
    
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
      <main style="flex: 1; overflow-y: auto; overflow-x: hidden;">
        <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">

          <!-- Header -->
          <header class="mb-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
            <div>
              <h1 class="dash-greeting">Batch <span style="color: var(--pt);">Manager</span></h1>
              <p class="dash-sub">Faculty Command Center · Academic Batch Configuration</p>
            </div>
            <div class="flex gap-3 flex-wrap items-center">
              <button onclick="openAddModal()" class="btn-solid-purple flex items-center gap-2 shadow-lg">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4"/></svg>
                Add Batch
              </button>
            </div>
          </header>

          <%
            const totalBatches = batches ? batches.length : 0;
            const activeBatches = batches ? batches.filter(b => b.isActive).length : 0;
            const totalStudents = batches ? batches.reduce((sum, b) => sum + (b.studentCount || 0), 0) : 0;
          %>

          <!-- Stats Row -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-10">
            <div class="stat-card">
              <div class="stat-value"><%= totalBatches %></div>
              <div class="stat-label">Total Batches</div>
              <div class="stat-icon">
                <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="var(--pt)" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
            </div>
            <div class="stat-card">
              <div class="stat-value" style="color: var(--gt);"><%= activeBatches %></div>
              <div class="stat-label">Active Batches</div>
              <div class="stat-icon">
                <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="var(--gt)" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
            </div>
            <div class="stat-card">
              <div class="stat-value" style="color: var(--pt);"><%= totalStudents %></div>
              <div class="stat-label">Total Students Enrolled</div>
              <div class="stat-icon">
                <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="var(--pt)" stroke-width="1.5"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
              </div>
            </div>
          </div>

          <!-- Search + Filter Bar -->
          <div class="flex flex-col sm:flex-row items-center gap-4 mb-8">
            <div class="search-wrap">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <input type="text" id="batch-search" placeholder="Search batches by name or description..." />
            </div>
            <div class="flex gap-2 ml-auto">
              <button class="filter-tab active" data-filter="all" onclick="filterBatches('all', this)">All</button>
              <button class="filter-tab" data-filter="active" onclick="filterBatches('active', this)">Active</button>
              <button class="filter-tab" data-filter="inactive" onclick="filterBatches('inactive', this)">Inactive</button>
            </div>
          </div>

          <!-- Batch Cards Grid -->
          <% if (!batches || batches.length === 0) { %>
          <div class="empty-state">
            <div class="empty-state-icon"></div>
            <div class="empty-state-title">No Batches Found</div>
            <div class="empty-state-sub">Create your first batch to get started</div>
          </div>
          <% } else { %>
          <div class="batch-grid" id="batch-grid">
            <% batches.forEach(batch => { %>
            <div class="batch-card" data-name="<%= batch.name.toLowerCase() %>" data-desc="<%= (batch.description || '').toLowerCase() %>" data-status="<%= batch.isActive ? 'active' : 'inactive' %>">
              <div class="batch-card-header">
                <div class="batch-card-name"><%= batch.name %></div>
                <span class="batch-status <%= batch.isActive ? 'active' : 'inactive' %>">
                  <%= batch.isActive ? 'Active' : 'Inactive' %>
                </span>
              </div>
              <div class="batch-card-meta">
                <div class="batch-meta-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
                  <span class="meta-val"><%= batch.studentCount %></span> students
                </div>
                <div class="batch-meta-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  <span class="meta-val"><%= batch.academicYear %></span>
                </div>
              </div>
              <% if (batch.description) { %>
              <div class="batch-card-desc"><%= batch.description %></div>
              <% } else { %>
              <div class="batch-card-desc" style="opacity:0.4; font-style: italic;">No description added</div>
              <% } %>
              <div class="batch-card-actions">
                <button class="batch-edit-btn"
                  data-id="<%= batch._id %>"
                  data-name="<%- batch.name.replace(/"/g, '&quot;') %>"
                  data-description="<%- (batch.description || '').replace(/"/g, '&quot;') %>"
                  data-active="<%= batch.isActive %>"
                  data-year="<%= batch.academicYear %>"
                  onclick="openEditModal(this)">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  Edit Details
                </button>
              </div>
            </div>
            <% }) %>
          </div>
          <% } %>

          <!-- No search results -->
          <div id="no-results-msg" class="empty-state" style="display: none; margin-top: 20px;">
            <div class="empty-state-icon"></div>
            <div class="empty-state-title">No Matches Found</div>
            <div class="empty-state-sub">Try refining your search terms</div>
          </div>

        </div>
      </main>
    </div>
  </div>

  <!-- =================== ADD BATCH MODAL =================== -->
  <div class="modal-overlay" id="add-modal">
    <div class="modal-box">
      <div class="modal-header">
        <div class="flex justify-between items-start">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-2xl"></span>
              <h2 class="text-xl font-extrabold tracking-tight">New Batch</h2>
            </div>
            <p class="text-purple-200 text-xs font-semibold">Create a new academic batch for the current session</p>
          </div>
          <button onclick="closeModal('add-modal')" class="text-white/60 hover:text-white text-3xl font-light leading-none">&times;</button>
        </div>
      </div>
      <div class="modal-body">
        <form id="add-batch-form" action="/teacher/add_batch" method="POST">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />

          <div class="mb-5">
            <label class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Academic Year</label>
            <div class="px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-xl font-semibold text-xs flex items-center justify-between">
              <span class="text-theme-fdd">Current Session</span>
              <span class="text-theme-pt font-bold"><%= typeof viewingYear !== 'undefined' ? viewingYear : 'Current' %></span>
            </div>
          </div>

          <div class="mb-5">
            <label class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Batch Name <span style="color: var(--rt);">*</span></label>
            <input type="text" name="name" placeholder="e.g. 9th Grade Science, Math Advanced" required class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p outline-none font-semibold text-xs" />
          </div>

          <div class="mb-5">
            <label class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Description</label>
            <textarea name="description" rows="3" placeholder="Optional batch details or schedule info..." class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p outline-none font-semibold text-xs resize-vertical"></textarea>
          </div>

          <button type="submit" class="btn-glow" id="add-submit-btn">Create Batch ✓</button>
        </form>
      </div>
    </div>
  </div>

  <!-- =================== EDIT BATCH MODAL =================== -->
  <div class="modal-overlay" id="edit-modal">
    <div class="modal-box">
      <div class="modal-header">
        <div class="flex justify-between items-start">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xl"></span>
              <h2 class="text-lg font-extrabold tracking-tight">Edit Batch</h2>
            </div>
            <p class="text-purple-200 text-xs font-semibold">Update configuration or toggle active status</p>
          </div>
          <button onclick="closeModal('edit-modal')" class="text-white/60 hover:text-white text-3xl font-light leading-none">&times;</button>
        </div>
      </div>
      <div class="modal-body">
        <form id="edit-batch-form" method="POST">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
          <input type="hidden" name="isActive" id="edit-isActive" value="true" />

          <div class="mb-5">
            <label class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Academic Session</label>
            <div class="px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-xl font-semibold text-xs flex items-center justify-between">
              <span class="text-theme-fdd">Locked Session</span>
              <span class="text-theme-pt font-bold" id="edit-year-display"></span>
            </div>
          </div>

          <div class="mb-5">
            <label class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Batch Name <span style="color: var(--rt);">*</span></label>
            <input type="text" name="name" id="edit-name" required class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p outline-none font-semibold text-xs" />
          </div>

          <div class="mb-5">
            <label class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Status</label>
            <div class="status-toggle">
              <div class="status-opt active-opt selected" onclick="setEditStatus(true)">
                <div class="sdot green"></div>
                <span class="slabel">Active</span>
              </div>
              <div class="status-opt inactive-opt" onclick="setEditStatus(false)">
                <div class="sdot red"></div>
                <span class="slabel">Inactive</span>
              </div>
            </div>
            <p class="text-[10px] text-theme-fdd mt-2 font-mono">Inactive batches are hidden from student/test creation lists.</p>
          </div>

          <div class="mb-5">
            <label class="block text-[10px] font-bold text-theme-fdd uppercase tracking-widest mb-2 font-mono">Description</label>
            <textarea name="description" id="edit-description" rows="3" class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p outline-none font-semibold text-xs resize-vertical"></textarea>
          </div>

          <button type="submit" class="btn-glow" id="edit-submit-btn">Save Changes ✓</button>
        </form>
      </div>
    </div>
  </div>

  <script>
    // Modal open/close
    function openAddModal() {
      document.getElementById('add-modal').classList.add('open');
    }
    function closeModal(id) {
      document.getElementById(id).classList.remove('open');
    }
    document.querySelectorAll('.modal-overlay').forEach(o => o.addEventListener('click', function(e) {
      if (e.target === this) closeModal(this.id);
    }));
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        closeModal('add-modal');
        closeModal('edit-modal');
      }
    });

    // Edit modal
    function openEditModal(btn) {
      const id          = btn.dataset.id;
      const name        = btn.dataset.name;
      const description = btn.dataset.description;
      const isActive    = btn.dataset.active === 'true';
      const year        = btn.dataset.year;
      const form = document.getElementById('edit-batch-form');
      form.action = '/teacher/edit_batch/' + id;
      document.getElementById('edit-name').value = name;
      document.getElementById('edit-description').value = description;
      document.getElementById('edit-year-display').textContent = year;
      setEditStatus(isActive);
      document.getElementById('edit-modal').classList.add('open');
    }

    function setEditStatus(isActive) {
      document.getElementById('edit-isActive').value = isActive;
      document.querySelectorAll('.status-opt').forEach(el => el.classList.remove('selected'));
      if (isActive) {
        document.querySelector('.active-opt').classList.add('selected');
      } else {
        document.querySelector('.inactive-opt').classList.add('selected');
      }
    }

    // Form submit handlers
    document.getElementById('add-batch-form').addEventListener('submit', function() {
      const btn = document.getElementById('add-submit-btn');
      if (btn) { btn.disabled = true; btn.innerText = 'Creating...'; btn.style.opacity = '0.7'; }
    });
    document.getElementById('edit-batch-form').addEventListener('submit', function() {
      const btn = document.getElementById('edit-submit-btn');
      if (btn) { btn.disabled = true; btn.innerText = 'Saving...'; btn.style.opacity = '0.7'; }
    });

    // Search + Filter
    let currentFilter = 'all';

    function filterBatches(filter, el) {
      currentFilter = filter;
      document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
      if (el) el.classList.add('active');
      applyFilters();
    }

    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('batch-search');
      if (searchInput) searchInput.addEventListener('input', applyFilters);
    });

    function applyFilters() {
      const query = (document.getElementById('batch-search')?.value || '').toLowerCase().trim();
      const cards = document.querySelectorAll('.batch-card');
      const grid = document.getElementById('batch-grid');
      const noResults = document.getElementById('no-results-msg');
      let visible = 0;

      cards.forEach(card => {
        const name = card.dataset.name || '';
        const desc = card.dataset.desc || '';
        const status = card.dataset.status || '';
        const matchesSearch = !query || name.includes(query) || desc.includes(query);
        const matchesFilter = currentFilter === 'all' || status === currentFilter;
        if (matchesSearch && matchesFilter) {
          card.style.display = '';
          visible++;
        } else {
          card.style.display = 'none';
        }
      });

      if (cards.length > 0) {
        if (visible === 0) {
          if (grid) grid.style.display = 'none';
          if (noResults) noResults.style.display = '';
        } else {
          if (grid) grid.style.display = '';
          if (noResults) noResults.style.display = 'none';
        }
      }
    }
  </script>
</body>
</html>
