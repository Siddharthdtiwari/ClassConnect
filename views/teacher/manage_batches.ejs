<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Batches</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  
</head>

<%- include('../partials/background') %>


<body class="text-theme-fg m-0 p-0 overflow-hidden" style="background: var(--bg);">
  <div style="display: flex; height: 100vh; overflow: hidden;">
    <%- include('../partials/teacher_sidebar') %>
    
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
      <main style="flex: 1; overflow-y: auto; overflow-x: hidden;">
        <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">

    <header class="mb-8">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900">Manage Batches</h1>
          <p class="text-gray-600 mt-1">Create, configure, and isolate academic year batches.</p>
        </div>
        <div class="flex gap-3 flex-wrap items-center">
          <button onclick="window.location.href='/teacher/add_batch'" class="btn-solid-purple">
            + Add New Batch
          </button>
        </div>
      </div>
    </header>

    <div class="glass-card p-6 mb-8">
      <!-- Search Bar -->
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <div class="flex-grow w-full relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
            </svg>
          </div>
          <input type="text" id="batch-search" placeholder="Search by batch name or description..." class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 shadow-sm focus:border-brand-purple focus:ring focus:ring-brand-purple focus:ring-opacity-50 transition duration-150" />
        </div>
        <div class="text-sm font-medium text-gray-500 whitespace-nowrap bg-purple-50 px-4 py-2 rounded-lg border border-purple-100">
          Academic Year: <span class="text-brand-purple font-bold text-lg"><%= typeof viewingYear !== 'undefined' ? viewingYear : 'Current' %></span>
        </div>
      </div>
    </div>

    <!-- Batches Tables Container -->
    <div class="overflow-x-auto rounded-xl shadow border border-gray-200 glass-card">
      <% if (!batches || batches.length === 0) { %>
      <div class="p-16 text-center text-gray-400">
        <p class="text-4xl mb-4">&#128193;</p>
        <p class="text-xl font-semibold">No batches found for this year</p>
        <p class="text-sm mt-1">Get started by creating your first academic year batch.</p>
      </div>
      <% } else { %>
      <table class="data-table">
        <thead>
          <tr>
            <th>Batch Name</th>
            <th class="w-40 text-center">Academic Year</th>
            <th class="w-32 text-center">Students Enrolled</th>
            <th class="w-32 text-center">Status</th>
            <th>Description</th>
            <th class="text-center w-28">Actions</th>
          </tr>
        </thead>
        <tbody id="batches-tbody">
          <% batches.forEach(batch => { %>
          <tr class="batch-row">
            <td class="font-semibold text-gray-800 search-name"><%= batch.name %></td>
            <td class="text-center font-medium text-gray-500"><%= batch.academicYear %></td>
            <td class="text-center font-bold text-gray-700"><%= batch.studentCount %></td>
            <td class="text-center">
              <% if (batch.isActive) { %>
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-800 border border-green-200">Active</span>
              <% } else { %>
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-800 border border-red-200">Inactive</span>
              <% } %>
            </td>
            <td class="text-gray-500 text-sm search-desc"><%= batch.description || '—' %></td>
            <td class="text-center">
              <a href="/teacher/edit_batch/<%= batch._id %>" class="text-brand-purple hover:underline text-sm font-semibold">Edit Details</a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>

    <!-- Empty state for search filtering -->
    <div id="no-results-msg" class="hidden p-16 text-center text-gray-400 glass-card border border-gray-200 rounded-xl mt-4 shadow">
      <p class="text-4xl mb-4">&#128269;</p>
      <p class="text-xl font-semibold">No matches found</p>
      <p class="text-sm mt-1">Try refining your search terms.</p>
    </div>

  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const searchInput = document.getElementById("batch-search");
      const rows = document.querySelectorAll(".batch-row");
      const table = document.querySelector(".data-table");
      const noResults = document.getElementById("no-results-msg");

      if (searchInput) {
        searchInput.addEventListener("input", () => {
          const query = searchInput.value.toLowerCase().trim();
          let visibleCount = 0;

          rows.forEach(row => {
            const name = row.querySelector(".search-name").textContent.toLowerCase();
            const desc = row.querySelector(".search-desc").textContent.toLowerCase();

            if (name.includes(query) || desc.includes(query)) {
              row.style.display = "";
              visibleCount++;
            } else {
              row.style.display = "none";
            }
          });

          if (visibleCount === 0 && rows.length > 0) {
            if (table) table.classList.add("hidden");
            if (noResults) noResults.classList.remove("hidden");
          } else {
            if (table) table.classList.remove("hidden");
            if (noResults) noResults.classList.add("hidden");
          }
        });
      }
    });
  </script>
      </main>
    </div>
  </div>
</body>


</html>
