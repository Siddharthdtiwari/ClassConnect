<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Fees Tracker</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body {
      font-family: "Inter", sans-serif;
    }

    .bg-brand-background {
      background-image: linear-gradient(120deg, #f3e8ff 0%, #eef2f3 100%);
    }

    .text-brand-purple {
      color: #5d3a9b;
    }

    .btn-solid-purple {
      background-color: #5d3a9b;
      color: #fff;
      font-weight: 600;
      transition: all 0.3s ease;
      border-radius: 0.5rem;
      border: 1px solid #5d3a9b;
    }

    .btn-solid-purple:hover {
      background-color: #4b2d84;
      border-color: #4b2d84;
    }

    .btn-outline-purple {
      color: #5d3a9b;
      border: 1px solid #5d3a9b;
      font-weight: 600;
      border-radius: 0.5rem;
      transition: all 0.3s ease;
    }

    .btn-outline-purple:hover {
      background-color: #bde045;
      color: #333;
      border-color: #bde045;
    }

    .data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.875rem;
    }

    .data-table thead tr {
      background: #5d3a9b;
      color: #fff;
    }

    .data-table th {
      padding: 0.75rem 1rem;
      text-align: left;
      font-weight: 600;
      border: 1px solid #4b2d84;
      white-space: nowrap;
    }

    .data-table td {
      padding: 0.65rem 1rem;
      border: 1px solid #d8b4e2;
      white-space: nowrap;
    }

    .data-table tbody tr:nth-child(even) {
      background: #f9f5ff;
    }

    .data-table tbody tr:hover td {
      background: #ede9fe;
    }

    .paid {
      color: #16a34a;
      font-weight: 700;
    }

    .unpaid {
      color: #ef4444;
      font-weight: 600;
    }
  </style>
</head>

<%- include('../partials/background') %>

<body class="text-gray-800">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
    <header class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <div>
        <a href="/teacher/dashboard" class="text-sm font-medium text-brand-purple hover:underline mb-2 inline-block">&larr; Back to Dashboard</a>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mt-1">Manage Fees</h1>
        <p class="text-gray-600 mt-2">Track and view student fee payments by month.</p>
      </div>

      <div class="flex flex-wrap gap-3">
        <button onclick="window.location.href='/teacher/fee_defaulters'" class="py-2 px-4 btn-outline-purple text-sm">
          Fee Defaulters
        </button>
        <button onclick="window.location.href='/teacher/detailed_fees'" class="py-2 px-4 btn-outline-purple text-sm">
          Detailed Report
        </button>
        <button onclick="window.location.href='/teacher/revenue_report'" class="py-2 px-4 btn-outline-purple text-sm">
          Revenue Report
        </button>
        <button onclick="window.location.href='/teacher/add_fees'" class="py-2 px-5 btn-solid-purple text-sm shadow">
          + Add Fee
        </button>
      </div>
    </header>

    <div class="bg-white p-6 rounded-xl shadow border border-purple-100 mb-8">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
        <h2 class="text-xl font-bold text-gray-800">Fee Status Grid</h2>
        <div class="relative w-full sm:w-64">
          <input type="text" id="student-search" placeholder="Search a student by name..." class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-brand-purple focus:border-brand-purple text-sm transition-shadow">
          <svg class="w-5 h-5 text-gray-400 absolute left-3 top-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
      </div>

      <div class="overflow-x-auto rounded-xl shadow-sm border border-gray-200">
        <table class="data-table">
          <thead>
            <tr>
              <th>Class</th>
              <th>Student ID</th>
              <th>Student Name</th>
              <% months.forEach(month => { %>
                <th class="text-center"><%= month %></th>
              <% }) %>
            </tr>
          </thead>
          <tbody>
            <% studentsWithFees.forEach(student => { %>
              <tr class="student-row">
                <td class="font-medium text-gray-600 search-standard"><%= student.standard %></td>
                <td class="font-mono text-gray-500 search-id"><%= student.studentId %></td>
                <td class="font-bold text-gray-800 search-name"><%= student.studentName %></td>
                <% months.forEach(month => { %> 
                  <td class="text-center">
                    <% if (student.fees[month]) { %>
                      <span class="paid" title="Paid on <%= student.fees[month] %>"><%= student.fees[month] %></span>
                    <% } else { %>
                      <span class="unpaid">-</span>
                    <% } %> 
                  </td>
                <% }) %>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div id="no-results-msg" class="hidden p-6 text-center text-gray-500 bg-gray-50 border border-t-0 border-gray-200 rounded-b-xl italic">
        No students found matching your search.
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('student-search');
      const rows = document.querySelectorAll('.student-row');
      const noResultsMsg = document.getElementById('no-results-msg');

      if(searchInput) {
        searchInput.addEventListener('input', () => {
          const query = searchInput.value.toLowerCase().trim();
          let anyVisible = false;

          rows.forEach(row => {
            const name = row.querySelector('.search-name').textContent.toLowerCase();
            const id = row.querySelector('.search-id').textContent.toLowerCase();
            
            if (name.includes(query) || id.includes(query)) {
              row.style.display = '';
              anyVisible = true;
            } else {
              row.style.display = 'none';
            }
          });

          if (!anyVisible && query !== '') {
            noResultsMsg.classList.remove('hidden');
          } else {
            noResultsMsg.classList.add('hidden');
          }
        });
      }
    });
  </script>
</body>
</html>