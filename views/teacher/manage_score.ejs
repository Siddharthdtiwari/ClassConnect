<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Scores</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  
</head>

<%- include('../partials/background') %>


<body class="text-theme-fg m-0 p-0 overflow-hidden" style="background: var(--bg);">
  <div style="display: flex; height: 100vh; overflow: hidden;">
    <%- include('../partials/teacher_sidebar') %>
    
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
      <main style="flex: 1; overflow-y: auto; overflow-x: hidden;">
        <div class="content-container container mx-auto p-6 min-h-screen">
    <header class="mb-8 flex flex-col sm:flex-row sm:justify-between items-start sm:items-end gap-4">
      <div>
        <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tight">
          Manage Scores
        </h1>
        <p class="text-gray-500 mt-2 text-lg">
          Add and manage student scores by test and batch.
        </p>
      </div>
    </header>

    <div class="glass-card p-6 sm:p-10 rounded-2xl shadow-xl border border-gray-100">
      <div class="mb-10">
        <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
          <svg class="w-6 h-6 text-brand-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
          Add/Edit Test Scores
        </h3>
        <div class="flex flex-col sm:flex-row gap-4 mb-8 bg-gray-50 p-4 rounded-xl border border-gray-100">
          <div class="flex-grow sm:flex-grow-0 sm:w-1/3">
            <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Batch</label>
            <select id="standard-filter" class="w-full px-4 py-3 rounded-lg border border-gray-300 text-gray-700 glass-card shadow-sm focus:border-brand-purple focus:ring focus:ring-brand-purple focus:ring-opacity-50 appearance-none font-medium">
              <option value="">-- Select Batch --</option>
              <% if (typeof batches !== 'undefined' && batches.length > 0) { %>
                <% batches.forEach(batch => { %>
                  <option value="<%= batch._id %>"><%= batch.name %> (<%= batch.academicYear %>)</option>
                <% }) %>
              <% } %>
            </select>
          </div>
          <div class="flex-grow sm:flex-grow-0 sm:w-2/3">
            <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Test Name</label>
            <select id="test-filter" class="w-full px-4 py-3 rounded-lg border border-gray-300 text-gray-700 glass-card shadow-sm focus:border-brand-purple focus:ring focus:ring-brand-purple focus:ring-opacity-50 appearance-none font-medium disabled:bg-gray-100 disabled:text-gray-400" disabled>
              <option value="">-- Select Test --</option>
            </select>
          </div>
        </div>

        <div id="student-list-container" class="hidden">
          <div class="report-table-wrapper mb-8">
            <div class="overflow-x-auto">
              <table class="table-auto">
                <thead>
                  <tr>
                    <th>Student Name</th>
                    <th>Student ID</th>
                    <th class="w-32">Score</th>
                  </tr>
                </thead>
                <tbody id="student-score-list"></tbody>
              </table>
            </div>
          </div>
          
          <div class="flex justify-end">
            <button id="save-scores-btn" class="btn-solid-purple w-full sm:w-auto text-lg flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Save Scores
            </button>
          </div>
        </div>

        <div id="message-box" class="mt-6 p-4 rounded-xl text-center hidden font-medium"></div>
      </div>

      <div id="all-scores-container" class="mt-12">
        <h3 class="text-2xl font-bold text-gray-900 mb-4">
          Consolidated Test Scores
        </h3>
        <div id="classwise-tables" class="space-y-12 overflow-x-auto"></div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const standardFilter = document.getElementById("standard-filter");
      const testFilter = document.getElementById("test-filter");
      const studentListContainer = document.getElementById(
        "student-list-container"
      );
      const studentScoreList = document.getElementById("student-score-list");
      const saveScoresBtn = document.getElementById("save-scores-btn");
      const classwiseTables = document.getElementById("classwise-tables");

      standardFilter.addEventListener("change", async () => {
        const standard = standardFilter.value;
        testFilter.innerHTML = '<option value="">-- Select Test --</option>';
        testFilter.disabled = true;
        studentListContainer.classList.add("hidden");

        if (!standard) return;

        const res = await fetch(`/api/tests/${standard}`);
        const tests = await res.json();

        tests.forEach((t) => {
          const option = document.createElement("option");
          option.value = t._id;
          option.textContent = `${t.testName} — ${t.subject} — ${t.topic}`;
          testFilter.appendChild(option);
        });

        testFilter.disabled = false;
      });

      testFilter.addEventListener("change", async () => {
        const testId = testFilter.value;
        const standard = standardFilter.value;
        if (!testId || !standard) return;

        const res = await fetch(`/api/scores/${standard}/${testId}`);
        const studentScores = await res.json();

        studentScoreList.innerHTML = "";
        studentScores.forEach((s) => {
          const row = document.createElement("tr");
          row.dataset.studentId = s.studentId;
          row.innerHTML = `
                        <td>${s.studentName}</td>
                        <td>${s.studentId}</td>
                        <td>
                            <input type="number" value="${s.score || ""}" 
                                placeholder="Enter score" 
                                class="score-input p-2 rounded-md border-gray-300 shadow-sm focus:border-brand-purple focus:ring focus:ring-brand-purple focus:ring-opacity-50">
                        </td>
                    `;
          studentScoreList.appendChild(row);
        });

        studentListContainer.classList.remove("hidden");
      });

      saveScoresBtn.addEventListener("click", async () => {
        const testId = testFilter.value;
        const standard = standardFilter.value;
        if (!testId || !standard) return alert("Select standard and test.");

        const rows = studentScoreList.querySelectorAll("tr");
        const scores = Array.from(rows).map((row) => {
          const val = parseFloat(row.querySelector("input").value);
          return {
            studentId: row.dataset.studentId,
            score: isNaN(val) ? null : val,
          };
        });

        const res = await fetch("/api/scores/save", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            testId,
            scores
          }),
        });
        const data = await res.json();
        alert(data.message);

        renderConsolidatedClasswise();
      });

      async function renderConsolidatedClasswise() {
        const res = await fetch("/api/scores/consolidated_classwise");
        const data = await res.json();
        classwiseTables.innerHTML = "";

        for (let cls in data) {
          const { tests, students } = data[cls];
          if (!tests.length || !students.length) continue;

          const title = document.createElement("h4");
          title.className = "text-xl font-bold text-gray-900 mb-3 mt-4 flex items-center gap-2";
          title.innerHTML = `<span class="inline-block px-3 py-1 rounded-full text-white text-sm" style="background:#5d3a9b">Batch: ${cls}</span>`;
          classwiseTables.appendChild(title);

          const wrapper = document.createElement("div");
          wrapper.className = "overflow-x-auto rounded-xl shadow-md mb-10 border border-gray-200";

          const table = document.createElement("table");
          table.className = "w-full border-collapse text-sm";

          let header = `
            <thead>
              <tr style="background:#5d3a9b; color:#fff;">
                <th class="px-4 py-3 text-left font-semibold whitespace-nowrap" rowspan="2">ID</th>
                <th class="px-4 py-3 text-left font-semibold whitespace-nowrap" rowspan="2">Student Name</th>`;
          tests.forEach(t => {
            header += `<th class="px-4 py-3 text-center font-semibold whitespace-nowrap">${t.testName}</th>`;
          });
          header += `<th class="px-4 py-3 text-center font-semibold whitespace-nowrap" rowspan="2" style="background:#4b2d84">Avg %</th></tr>`;

          header += `<tr style="background:#7c4dc0; color:#e9d8fd;">`;
          tests.forEach(t => {
            header += `<th class="px-3 py-1 text-center text-xs font-medium">${t.subject} &mdash; ${t.topic}</th>`;
          });
          header += `</tr></thead>`;

          let body = "<tbody>";
          students.forEach((st, idx) => {
            const rowBg = idx % 2 === 0 ? "background:#fff" : "background:#f9f5ff";
            body += `<tr style="${rowBg}" class="hover:bg-purple-50 transition-colors">`;
            body += `<td class="px-4 py-3 font-mono text-gray-500 text-xs whitespace-nowrap border-b border-gray-100">${st.studentId}</td>`;
            body += `<td class="px-4 py-3 font-semibold text-gray-800 whitespace-nowrap border-b border-gray-100">${st.studentName}</td>`;

            let totalPct = 0, scoredCount = 0;
            tests.forEach(t => {
              const raw = st.scores[t._id];
              if (raw !== undefined) {
                const pct = parseFloat(raw);
                totalPct += pct;
                scoredCount++;
                const color = pct >= 75 ? "color:#166534;background:#dcfce7"
                            : pct >= 50 ? "color:#92400e;background:#fef3c7"
                            : "color:#991b1b;background:#fee2e2";
                body += `<td class="px-4 py-3 text-center font-bold border-b border-gray-100" style="${color}">${pct.toFixed(1)}%</td>`;
              } else {
                body += `<td class="px-4 py-3 text-center border-b border-gray-100" style="color:#9ca3af">&mdash;</td>`;
              }
            });

            if (scoredCount > 0) {
              const avg = (totalPct / scoredCount).toFixed(1);
              const avgColor = avg >= 75 ? "color:#166534;background:#dcfce7"
                             : avg >= 50 ? "color:#92400e;background:#fef3c7"
                             : "color:#991b1b;background:#fee2e2";
              body += `<td class="px-4 py-3 text-center font-extrabold border-b border-gray-100" style="${avgColor}">${avg}%</td>`;
            } else {
              body += `<td class="px-4 py-3 text-center border-b border-gray-100 text-gray-400">&mdash;</td>`;
            }

            body += `</tr>`;
          });
          body += "</tbody>";

          table.innerHTML = header + body;
          wrapper.appendChild(table);
          classwiseTables.appendChild(wrapper);
        }
      }

      renderConsolidatedClasswise();
    });
  </script>
      </main>
    </div>
  </div>
</body>


</html>