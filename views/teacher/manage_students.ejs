<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Students</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: "Inter", sans-serif; }
    .text-brand-purple { color: #5d3a9b; }
    .btn-outline-purple {
      color: #5d3a9b; border: 1px solid #5d3a9b; font-weight: 600;
      transition: all 0.3s ease; border-radius: 0.5rem; padding: 0.5rem 1rem;
    }
    .btn-outline-purple:hover { background-color: #bde045; color: #333; border-color: #bde045; }
    
    .btn-solid-purple {
      background-color: #5d3a9b; color: #fff; font-weight: 600;
      transition: all 0.3s ease; border-radius: 0.5rem; padding: 0.5rem 1rem; border: 1px solid #5d3a9b;
    }
    .btn-solid-purple:hover { background-color: #4b2d84; border-color: #4b2d84; }

    .data-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .data-table thead tr { background: #5d3a9b; color: #fff; }
    .data-table thead th { padding: 0.75rem 1rem; text-align: left; font-weight: 600; border: 1px solid #4b2d84; }
    .data-table tbody tr:nth-child(even) { background: #f9f5ff; }
    .data-table tbody tr:nth-child(odd)  { background: #fff; }
    .data-table tbody tr:hover td { background: #ede9fe; }
    .data-table td { padding: 0.65rem 1rem; border: 1px solid #d8b4e2; }

    .class-header { background: #5d3a9b; color: #fff; padding: 0.25rem 1rem; border-radius: 9999px; font-weight: bold; }
  </style>
</head>

<%- include('../partials/background') %>

<body class="text-gray-800">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
    
    <header class="mb-8">
      <a href="/teacher/dashboard" class="text-brand-purple hover:underline mb-4 block">&larr; Back to Dashboard</a>
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900">Manage Students</h1>
          <p class="text-gray-600 mt-1">View, search, and manage all enrolled students.</p>
        </div>
        <div class="flex flex-wrap gap-3">
          <button onclick="window.location.href='/teacher/bulk_student_reports'" class="btn-outline-purple flex items-center gap-2">
            📥 Download All Reports
          </button>
          <button onclick="window.location.href='/teacher/bulk_add_students'" class="btn-outline-purple flex items-center gap-2">
            &#8645; Bulk Import
          </button>
          <button onclick="window.location.href='/teacher/add_student'" class="btn-solid-purple flex items-center gap-2">
            + Add New Student
          </button>
        </div>
      </div>
    </header>

    <% 
      // Group students by class
      const byClass = {};
      students.forEach(s => {
        if (!byClass[s.standard]) byClass[s.standard] = [];
        byClass[s.standard].push(s);
      });
      const sortedClasses = Object.keys(byClass).sort((a,b) => Number(a) - Number(b));
      
      const totalStudents = students.length;
    %>

    <div class="bg-white p-6 rounded-xl shadow-lg mb-8">
      <!-- Search Bar -->
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <div class="flex-grow w-full relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
            </svg>
          </div>
          <input type="text" id="student-search" placeholder="Search by student name or ID across all classes..." 
                 class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 shadow-sm focus:border-brand-purple focus:ring focus:ring-brand-purple focus:ring-opacity-50 transition duration-150" />
        </div>
        <div class="text-sm font-medium text-gray-500 whitespace-nowrap bg-purple-50 px-4 py-2 rounded-lg border border-purple-100">
          Total: <span class="text-brand-purple font-bold text-lg"><%= totalStudents %></span> students
        </div>
      </div>
    </div>

    <!-- Student Tables Grouped By Class -->
    <div id="students-container">
      <% if (students.length === 0) { %>
        <div class="bg-white rounded-xl shadow p-16 text-center text-gray-400">
          <p class="text-4xl mb-4">&#128100;</p>
          <p class="text-xl font-semibold">No students found</p>
          <p class="text-sm mt-1">Add a new student or use bulk import to get started.</p>
        </div>
      <% } else { %>
        
        <% sortedClasses.forEach(cls => { %>
          <div class="class-section mb-12" data-class="<%= cls %>">
            <div class="flex items-center gap-3 mb-4">
              <span class="class-header">Class <%= cls %></span>
              <span class="text-sm text-gray-500 font-medium class-count"><%= byClass[cls].length %> student<%= byClass[cls].length !== 1 ? 's' : '' %></span>
              <div class="flex-1 h-px bg-purple-200"></div>
            </div>

            <div class="overflow-x-auto rounded-xl shadow border border-gray-200">
              <table class="data-table">
                <thead>
                  <tr>
                    <th class="w-24">ID</th>
                    <th>Student Name</th>
                    <th>Mobile</th>
                    <th class="text-center w-32">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% byClass[cls].forEach(student => { %>
                    <tr class="student-row">
                      <td class="font-mono text-gray-500 text-xs search-id"><%= student.studentId %></td>
                      <td class="font-semibold text-gray-800 search-name"><%= student.studentName %></td>
                      <td class="text-gray-600 text-sm"><%= student.mobileNo || '—' %></td>
                      <td class="text-center">
                        <a href="/teacher/view_profile/<%= student._id %>" class="text-brand-purple hover:underline text-sm font-medium">View Profile</a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            
            <!-- Empty state for search filtering per class -->
            <div class="no-results-msg hidden p-6 text-center text-gray-400 bg-white border border-t-0 border-gray-200 rounded-b-xl">
              No students match your search in Class <%= cls %>.
            </div>
          </div>
        <% }) %>
        
      <% } %>
    </div>

  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const searchInput = document.getElementById("student-search");
      const classSections = document.querySelectorAll(".class-section");

      searchInput.addEventListener("input", () => {
        const query = searchInput.value.toLowerCase().trim();

        classSections.forEach(section => {
          let visibleCount = 0;
          const rows = section.querySelectorAll(".student-row");
          const msg = section.querySelector(".no-results-msg");
          const tableWrap = section.querySelector(".overflow-x-auto");

          rows.forEach(row => {
            const name = row.querySelector(".search-name").textContent.toLowerCase();
            const id = row.querySelector(".search-id").textContent.toLowerCase();
            
            if (name.includes(query) || id.includes(query)) {
              row.style.display = "";
              visibleCount++;
            } else {
              row.style.display = "none";
            }
          });

          if (visibleCount === 0) {
            if(tableWrap) tableWrap.classList.add("hidden");
            if(msg) msg.classList.remove("hidden");
          } else {
            if(tableWrap) tableWrap.classList.remove("hidden");
            if(msg) msg.classList.add("hidden");
          }
          
          const countSpan = section.querySelector(".class-count");
          if(countSpan) {
            countSpan.textContent = visibleCount + (visibleCount === 1 ? ' match' : ' matches');
          }
          
        });
      });
    });
  </script>
</body>
</html>