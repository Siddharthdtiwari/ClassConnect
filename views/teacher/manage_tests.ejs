<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Tests</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: "Inter", sans-serif; }
    .text-brand-purple { color: #5d3a9b; }
    
    .btn-solid-purple {
      background-color: #5d3a9b; color: #fff; font-weight: 600;
      transition: all 0.3s ease; border-radius: 0.5rem; padding: 0.5rem 1rem; border: 1px solid #5d3a9b;
    }
    .btn-solid-purple:hover { background-color: #4b2d84; border-color: #4b2d84; }
    
    .btn-outline-purple {
      color: #5d3a9b; border: 1px solid #5d3a9b; font-weight: 600;
      transition: all 0.3s ease; border-radius: 0.5rem; padding: 0.5rem 1rem;
    }
    .btn-outline-purple:hover { background-color: #bde045; color: #333; border-color: #bde045; }

    .data-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .data-table thead tr { background: #5d3a9b; color: #fff; }
    .data-table thead th { padding: 0.75rem 1rem; text-align: left; font-weight: 600; border: 1px solid #4b2d84; }
    .data-table tbody tr:nth-child(even) { background: #f9f5ff; }
    .data-table tbody tr:nth-child(odd)  { background: #fff; }
    .data-table tbody tr:hover td { background: #ede9fe; }
    .data-table td { padding: 0.65rem 1rem; border: 1px solid #d8b4e2; }

    .class-header { background: #5d3a9b; color: #fff; padding: 0.25rem 1rem; border-radius: 9999px; font-weight: bold; }
    
    .modal { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 50; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
    .modal.active { display: flex; }
  </style>
</head>

<%- include('../partials/background') %>

<body class="text-gray-800">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
    
    <header class="mb-8">
      <a href="/teacher/dashboard" class="text-brand-purple hover:underline mb-4 block">&larr; Back to Dashboard</a>
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900">Manage Tests</h1>
          <p class="text-gray-600 mt-1">View, search, edit, and manage all class tests.</p>
        </div>
        <button onclick="window.location.href='/teacher/add_test'" class="btn-solid-purple w-full sm:w-auto">
          + Add New Test
        </button>
      </div>
    </header>

    <% 
      // Group tests by class
      const byClass = {};
      tests.forEach(t => {
        if (!byClass[t.standard]) byClass[t.standard] = [];
        byClass[t.standard].push(t);
      });
      const sortedClasses = Object.keys(byClass).sort((a,b) => Number(a) - Number(b));
    %>

    <div class="bg-white p-6 rounded-xl shadow-lg mb-8">
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <div class="flex-grow w-full relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
          </div>
          <input type="text" id="test-search" placeholder="Search across all classes by test name, subject, or topic..." 
                 class="w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 shadow-sm focus:border-brand-purple focus:ring focus:ring-brand-purple focus:ring-opacity-50 transition duration-150" />
        </div>
        <div class="text-sm font-medium text-gray-500 whitespace-nowrap bg-purple-50 px-4 py-2 rounded-lg border border-purple-100">
          Total: <span class="text-brand-purple font-bold text-lg"><%= tests.length %></span> tests
        </div>
      </div>
    </div>

    <!-- Test Tables Grouped by Class -->
    <div id="tests-container">
      <% if (tests.length === 0) { %>
        <div class="bg-white rounded-xl shadow p-16 text-center text-gray-400">
          <p class="text-4xl mb-4">&#128221;</p>
          <p class="text-xl font-semibold">No tests created yet</p>
          <p class="text-sm mt-1">Click "Add New Test" to get started.</p>
        </div>
      <% } else { %>
        
        <% sortedClasses.forEach(cls => { %>
          <div class="class-section mb-12" data-class="<%= cls %>">
            <div class="flex items-center gap-3 mb-4">
              <span class="class-header">Class <%= cls %></span>
              <span class="text-sm text-gray-500 font-medium class-count"><%= byClass[cls].length %> test<%= byClass[cls].length !== 1 ? 's' : '' %></span>
              <div class="flex-1 h-px bg-purple-200"></div>
            </div>

            <div class="overflow-x-auto rounded-xl shadow border border-gray-200">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>Test Name</th>
                    <th>Subject</th>
                    <th>Topic</th>
                    <th>Total Marks</th>
                    <th>Test Date</th>
                    <th>Question Paper</th>
                    <th class="text-center w-48">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% byClass[cls].forEach(test => { %>
                    <tr class="test-row">
                      <td class="font-semibold text-gray-800 search-name"><%= test.testName %></td>
                      <td class="text-gray-600 search-sub"><%= test.subject %></td>
                      <td class="text-gray-600 text-sm search-topic"><%= test.topic %></td>
                      <td class="text-gray-800 font-bold"><%= test.totalMarks %></td>
                      <td class="text-gray-600 text-sm">
                        <% if (test.testDate) { %>
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-purple-50 text-brand-purple border border-purple-200 text-xs font-semibold">
                            📅 <%= new Date(test.testDate).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) %>
                          </span>
                        <% } else { %>
                          <span class="text-gray-400 italic text-xs">Not set</span>
                        <% } %>
                      </td>
                      <td>
                        <% if (test.questionPaper) { %>
                          <a href="<%= test.questionPaper %>" target="_blank" class="text-green-600 hover:text-green-800 hover:underline font-medium text-sm flex items-center gap-1">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                            Download QP
                          </a>
                        <% } else { %>
                          <span class="text-gray-400 text-sm italic">Not Uploaded</span>
                        <% } %>
                      </td>
                      <td class="text-center">
                        <div class="flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-3">
                          <button type="button" 
                                  onclick="openEditModal('<%= test._id %>', `<%= test.testName %>`, `<%= test.subject %>`, `<%= test.topic %>`, `<%= test.totalMarks %>`, `<%= test.questionPaper || '' %>`, `<%= test.testDate ? new Date(test.testDate).toISOString().split('T')[0] : '' %>`)" 
                                  class="text-brand-purple hover:underline text-sm font-medium">Edit</button>
                          
                          <span class="hidden sm:inline text-gray-300">|</span>

                          <form action="/teacher/delete_test/<%= test._id %>" method="POST" class="inline m-0" onsubmit="return confirm('WARNING: Are you sure you want to delete this test? This cannot be undone.');">
                            <button type="submit" class="text-red-500 hover:text-red-700 hover:underline text-sm font-medium">Delete</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            
            <div class="no-results-msg hidden p-6 text-center text-gray-400 bg-white border border-t-0 border-gray-200 rounded-b-xl">
              No tests match your search in Class <%= cls %>.
            </div>
          </div>
        <% }) %>
        
      <% } %>
    </div>
  </div>

  <!-- Edit Test Modal -->
  <div id="editModal" class="modal">
    <div class="bg-white rounded-xl shadow-2xl p-6 w-full max-w-md mx-4 transform transition-all">
      <div class="flex justify-between items-center mb-5">
        <h3 class="text-xl font-bold text-gray-900">Edit Test</h3>
        <button type="button" onclick="closeEditModal()" class="text-gray-400 hover:text-gray-600 p-1">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>

      <form id="editForm" method="POST" action="" enctype="multipart/form-data">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Test Name <span class="text-red-500">*</span></label>
            <input type="text" id="editTestName" name="testName" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-brand-purple focus:border-brand-purple">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Subject <span class="text-red-500">*</span></label>
            <select id="editSubject" name="subject" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-brand-purple focus:border-brand-purple">
              <option value="English">English</option>
              <option value="Maths I">Maths I</option>
              <option value="Maths II">Maths II</option>
              <option value="Science I">Science I</option>
              <option value="Science II">Science II</option>
              <option value="History-Civics">History-Civics</option>
              <option value="Geography">Geography</option>
              <option value="Hindi">Hindi</option>
              <option value="Marathi"> Marathi</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Topic <span class="text-red-500">*</span></label>
            <input type="text" id="editTopic" name="topic" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-brand-purple focus:border-brand-purple">
          </div>
          <div class="flex gap-4">
            <div class="flex-1">
              <label class="block text-sm font-medium text-gray-700 mb-1">Total Marks <span class="text-red-500">*</span></label>
              <input type="number" id="editTotalMarks" name="totalMarks" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-brand-purple focus:border-brand-purple" min="1">
            </div>
            <div class="flex-1">
              <label class="block text-sm font-medium text-gray-700 mb-1">Test Date</label>
              <input type="date" id="editTestDate" name="testDate" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-brand-purple focus:border-brand-purple">
            </div>
          </div>
          
          <hr class="my-4 border-gray-200">
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1 flex items-center justify-between">
              Question Paper (File or Link)
              <span id="current-qp-link"></span>
            </label>

            <div class="mt-2">
              <input type="url" id="editQuestionPaperLink" name="questionPaperLink" placeholder="Paste external link to file (optional)" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-brand-purple focus:border-brand-purple text-sm mb-3">
            </div>

            <p class="text-xs text-gray-500 my-1 font-semibold text-center italic">OR</p>

            <div class="mt-2">
              <input type="file" name="questionPaperFile" class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-purple-50 file:text-brand-purple hover:file:bg-purple-100 border border-gray-300 rounded-lg cursor-pointer focus:outline-none">
            </div>
          </div>
        </div>

        <div class="mt-6 flex justify-end gap-3 pt-2">
          <button type="button" onclick="closeEditModal()" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 font-medium transition-colors">Cancel</button>
          <button type="submit" class="btn-solid-purple px-6">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // Search functionality
    document.addEventListener("DOMContentLoaded", () => {
      const searchInput = document.getElementById("test-search");
      const classSections = document.querySelectorAll(".class-section");

      if(searchInput) {
        searchInput.addEventListener("input", () => {
          const query = searchInput.value.toLowerCase().trim();

          classSections.forEach(section => {
            let visibleCount = 0;
            const rows = section.querySelectorAll(".test-row");
            const msg = section.querySelector(".no-results-msg");
            const tableWrap = section.querySelector(".overflow-x-auto");

            rows.forEach(row => {
              const name = row.querySelector(".search-name").textContent.toLowerCase();
              const sub = row.querySelector(".search-sub").textContent.toLowerCase();
              const topic = row.querySelector(".search-topic").textContent.toLowerCase();
              
              if (name.includes(query) || sub.includes(query) || topic.includes(query)) {
                row.style.display = "";
                visibleCount++;
              } else {
                row.style.display = "none";
              }
            });

            if (visibleCount === 0) {
              if(tableWrap) tableWrap.classList.add("hidden");
              if(msg) msg.classList.remove("hidden");
            } else {
              if(tableWrap) tableWrap.classList.remove("hidden");
              if(msg) msg.classList.add("hidden");
            }
            
            const countSpan = section.querySelector(".class-count");
            if(countSpan) countSpan.textContent = visibleCount + (visibleCount === 1 ? ' test' : ' tests');
          });
        });
      }
    });

    // Modal functionality
    const modal = document.getElementById('editModal');
    const form = document.getElementById('editForm');

    function openEditModal(id, name, subject, topic, marks, qpUrl, testDate) {
      document.getElementById('editTestName').value = name;
      document.getElementById('editSubject').value = subject;
      document.getElementById('editTopic').value = topic;
      document.getElementById('editTotalMarks').value = marks;
      document.getElementById('editTestDate').value = testDate || '';
      
      const isLink = qpUrl && !qpUrl.includes('cloudinary');
      document.getElementById('editQuestionPaperLink').value = isLink ? qpUrl : '';

      const qpLinkContainer = document.getElementById('current-qp-link');
      if (qpUrl && qpUrl.trim() !== '') {
        qpLinkContainer.innerHTML = `<a href="${qpUrl}" target="_blank" class="text-xs font-semibold text-green-600 hover:text-green-800 underline">View Current File &rarr;</a>`;
      } else {
        qpLinkContainer.innerHTML = `<span class="text-xs italic text-gray-400">No file uploaded</span>`;
      }

      form.action = `/teacher/edit_test/${id}`;
      modal.classList.add('active');
    }

    function closeEditModal() {
      modal.classList.remove('active');
    }

    // Close modal on outside click
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeEditModal();
    });
  </script>
</body>
</html>