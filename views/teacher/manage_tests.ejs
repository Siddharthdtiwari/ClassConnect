<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Tests | Tuition Hub</title>
  
  <%- include('../partials/background') %>
  <script src="/js/subjects.js"></script>


  <style>
    /* Premium Dashboard Styles */
    .dash-greeting {
      font-family: 'Unbounded', sans-serif;
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.03em;
    }
    .dash-sub {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--fdd);
      margin-top: 8px;
    }
    .stat-card {
      background: var(--bgc);
      backdrop-filter: blur(16px);
      border: 1px solid var(--bd);
      border-radius: 18px;
      padding: 24px;
      transition: all 0.35s cubic-bezier(.34,1.56,.64,1);
      position: relative;
      overflow: hidden;
    }
    .stat-card::before {
      content: '';
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 0.4s;
      background: radial-gradient(circle at 20% 30%, var(--pg2) 0%, transparent 60%);
      pointer-events: none;
    }
    .stat-card:hover::before { opacity: 1; }
    .stat-card:hover {
      border-color: rgba(124,58,237,0.25);
      transform: translateY(-4px);
      box-shadow: 0 12px 40px var(--pg2);
    }
    .stat-value {
      font-family: 'Unbounded', sans-serif;
      font-size: 2.2rem;
      font-weight: 900;
      line-height: 1;
      position: relative;
      z-index: 1;
    }
    .stat-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--fdd);
      margin-top: 6px;
      position: relative;
      z-index: 1;
    }
    .stat-icon {
      position: absolute;
      top: 20px;
      right: 20px;
      opacity: 0.15;
      z-index: 0;
    }

    /* Modal stacking context to prevent TinyMCE overlays behind backdrop */
    #ai-modal {
      z-index: 1100 !important;
    }
    #edit-test-modal, #add-test-modal {
      z-index: 1050 !important;
    }
    
    .tox-tinymce-aux {
      z-index: 1200 !important;
    }
  </style>
</head>

<body class="text-theme-fg m-0 p-0 overflow-hidden" style="background: var(--bg);">
  <div style="display: flex; height: 100vh; overflow: hidden;">
    <%- include('../partials/teacher_sidebar') %>
    
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
      <main style="flex: 1; overflow-y: auto; overflow-x: hidden;">
        <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">

          <!-- Greeting Header -->
          <header class="mb-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
            <div>
              <h1 class="dash-greeting">Manage <span style="color: var(--pt);">Tests</span></h1>
              <p class="dash-sub">Faculty Command Center · Academic Assessment Records</p>
            </div>
            <div class="flex gap-3 flex-wrap items-center">
              <a href="/teacher/generate_paper" class="btn-outline-purple flex items-center gap-2 text-[10px] font-bold uppercase tracking-wider font-mono">
                <svg class="w-3.5 h-3.5 text-theme-pt" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 21l5.096-.813 6.601-6.602-4.283-4.283-6.601 6.602zM21 3h-6l-2.25 2.25 4.5 4.5L21 7.5V3z"/></svg>
                ✨ AI Generator
              </a>
              <button onclick="openAddModal()" class="btn-solid-purple flex items-center gap-2 shadow-lg">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4"/></svg>
                Add Test
              </button>
            </div>
          </header>


          <% 
            let totalTests = tests.length;
            let batchCount = Object.keys(byClass).length;
            let avgTests = batchCount ? Math.round(totalTests / batchCount) : 0;
            
            const getBatchOrderValue = (name) => {
              if (!name) return 999;
              const lowerName = name.toLowerCase();
              if (lowerName.includes("pre") || lowerName.includes("kg")) return 0;
              const match = lowerName.match(/^(\d+)/);
              if (match) return parseInt(match[1]);
              return 100;
            };
            const sortedClasses = Object.keys(byClass).sort((a, b) => getBatchOrderValue(a) - getBatchOrderValue(b));
          %>

          <!-- Metrics Row -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-10">
            <div class="stat-card">
              <div class="stat-icon">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="color: var(--pt);"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
              </div>
              <div class="stat-value" style="color: var(--pt);"><%= totalTests %></div>
              <div class="stat-label">Total Tests</div>
            </div>

            <div class="stat-card">
              <div class="stat-icon">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="color: var(--pt);"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
              </div>
              <div class="stat-value" style="color: var(--pt);"><%= batchCount %></div>
              <div class="stat-label">Active Batches</div>
            </div>

            <div class="stat-card">
              <div class="stat-icon">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="color: var(--pt);"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
              </div>
              <div class="stat-value" style="color: var(--lt);"><%= avgTests %></div>
              <div class="stat-label">Avg Tests / Batch</div>
            </div>
          </div>

          <!-- Filters Section -->
          <div class="stat-card p-6 mb-10 flex flex-col gap-6">
            <!-- Search Bar -->
            <div class="relative w-full">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-theme-fdd" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                </svg>
              </div>
              <input type="text" id="test-search" placeholder="Search by test name, subject, or topic..." class="w-full pl-12 pr-4 py-3 bg-theme-bgc text-theme-fg border border-theme-b rounded-xl focus:border-theme-p focus:ring-2 focus:ring-theme-pm/20 transition-all font-medium text-sm placeholder-theme-fdd" />
            </div>

            <!-- Batch Tabs Filter -->
            <% if (sortedClasses.length > 0) { %>
            <div class="flex items-center gap-2 overflow-x-auto pb-1.5 custom-scrollbar">
              <span class="text-[0.62rem] font-bold text-theme-fdd uppercase tracking-widest mr-3 font-mono">Filter by Batch:</span>
              <button onclick="filterBatch('All')" 
                class="batch-tab-filter py-1.5 px-4 rounded-full text-[0.68rem] font-bold uppercase tracking-wider border transition-all bg-purple-700 text-white border-purple-700 font-mono"
                data-class="All">🗓 All</button>
              <% sortedClasses.forEach((cls) => { %>
              <button onclick="filterBatch('<%= cls %>')" 
                class="batch-tab-filter py-1.5 px-4 rounded-full text-[0.68rem] font-bold uppercase tracking-wider border transition-all text-theme-pt border-theme-bd hover:bg-theme-bgch font-mono"
                data-class="<%= cls %>">🏫 <%= cls %></button>
              <% }) %>
            </div>
            <% } %>
          </div>

          <!-- Tables Grouped by Class -->
          <div id="tests-container">
            <% if (tests.length === 0) { %>
            <div class="stat-card p-16 text-center text-theme-fdd">
              <p class="text-5xl mb-4">📝</p>
              <p class="text-xl font-bold">No tests recorded</p>
              <p class="text-sm mt-1">Create tests and attach papers to build the records ledger.</p>
            </div>
            <% } else { %>

            <% sortedClasses.forEach(cls => { %>
            <% if (byClass[cls] && byClass[cls].length > 0) { %>
            <div class="class-section mb-10" data-class="<%= cls %>">
              
              <!-- Batch Grouping Header -->
              <div class="flex items-center justify-between mb-4 pl-1">
                <div class="flex items-center gap-3">
                  <div class="w-2.5 h-6 bg-[var(--p)] rounded-full shadow-sm"></div>
                  <h3 class="text-xl font-bold tracking-tight text-theme-fg" style="font-family: 'Unbounded', sans-serif;">Batch: <span style="color: var(--pt);"><%= cls %></span></h3>
                  <span class="text-xs font-semibold bg-purple-500/10 text-theme-pt border border-purple-500/20 px-2.5 py-1 rounded-full class-count"><%= byClass[cls].length %> test<%= byClass[cls].length !== 1 ? 's' : '' %></span>
                </div>
                <div class="flex-grow h-px bg-theme-bd ml-4 hidden sm:block"></div>
              </div>

              <!-- Glass Card Table Container -->
              <div class="overflow-x-auto rounded-xl border border-theme-b bg-theme-bgc">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th class="text-left">Test Name</th>
                      <th class="text-left">Subject</th>
                      <th class="text-left">Topic</th>
                      <th class="text-left">Total Marks</th>
                      <th class="text-left">Test Date</th>
                      <th class="text-left">Question Paper</th>
                      <th class="text-center w-48">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% byClass[cls].forEach(test => { %>
                    <tr class="test-row hover:bg-theme-bgch/50 transition-all">
                      <td>
                        <div class="font-bold text-theme-fg search-name leading-snug"><%= test.testName %></div>
                      </td>
                      <td>
                        <span class="inline-block bg-theme-pt/10 text-theme-pt border border-theme-pt/20 px-2 py-0.5 rounded text-xs font-mono font-bold search-sub">
                          <%= test.subject %>
                        </span>
                      </td>
                      <td>
                        <div class="text-theme-fd search-topic text-xs font-medium"><%= test.topic %></div>
                      </td>
                      <td>
                        <span class="font-mono font-extrabold text-theme-fg text-sm"><%= test.totalMarks %></span>
                      </td>
                      <td>
                        <% if (test.testDate) { %>
                        <span class="inline-flex items-center gap-1 font-mono text-xs font-bold text-theme-pt">
                          📅 <%= new Date(test.testDate).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) %>
                        </span>
                        <% } else { %>
                        <span class="text-theme-fdd italic text-xs">Not set</span>
                        <% } %>
                      </td>
                      <td>
                        <% if (test.questionPaper) { %>
                        <a href="<%= test.questionPaper %>" target="_blank" class="text-emerald-400 hover:text-emerald-300 font-semibold text-xs flex items-center gap-1 leading-none">
                          <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                          </svg>
                          Download QP
                        </a>
                        <% } else { %>
                        <span class="text-theme-fdd text-xs italic">Not Uploaded</span>
                        <% } %>
                      </td>
                      <td class="text-center">
                        <div class="flex items-center justify-center gap-3">
                          <button type="button" onclick="openEditModal('<%= test._id %>', `<%= test.testName %>`, `<%= test.subject %>`, `<%= test.topic %>`, `<%= test.totalMarks %>`, `<%= test.questionPaper || '' %>`, `<%= test.testDate ? new Date(test.testDate).toISOString().split('T')[0] : '' %>`, `<%= cls %>`, `<%= test.batch ? test.batch._id : '' %>`)" class="text-theme-pt hover:text-theme-p text-xs font-bold uppercase tracking-wider font-mono">Edit</button>
                          <span class="text-theme-bd">|</span>
                          <form action="/teacher/delete_test/<%= test._id %>" method="POST" class="inline m-0" onsubmit="return confirm('WARNING: Are you sure you want to delete this test? This cannot be undone.');">
                            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                            <button type="submit" class="text-red-400 hover:text-red-500 text-xs font-bold uppercase tracking-wider font-mono">Delete</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>

              <!-- Empty state for search filtering per class -->
              <div class="no-results-msg hidden p-10 text-center text-theme-fdd stat-card border border-t-0 rounded-b-xl animate-fade-in">
                <p class="text-3xl mb-2">🔍</p>
                <p class="font-semibold text-sm">No tests match your search in <%= cls %>.</p>
              </div>
            </div>
            <% } %>
            <% }) %>

            <% } %>
          </div>

        </div>

        <!-- =================== ADD TEST MODAL =================== -->
        <div class="modal-overlay" id="add-test-modal">
          <div class="modal-box max-w-md" style="background: var(--bgc); border: 1px solid var(--bd); border-radius: 18px; padding: 24px;">
            
            <!-- Header -->
            <div class="flex justify-between items-start mb-6 border-b border-theme-bd pb-4">
              <div>
                <h2 class="text-xl font-black uppercase tracking-tight" style="font-family: 'Unbounded', sans-serif; color: var(--pt) !important;">Add <span style="color: var(--fg) !important;">Test</span></h2>
                <p class="dash-sub mt-1">Create a new test record</p>
              </div>
              <button onclick="closeModal('add-test-modal')" class="text-theme-fdd hover:text-theme-fg text-2xl font-bold leading-none">&times;</button>
            </div>

            <!-- Body -->
            <div>
              <form id="add-test-form" enctype="multipart/form-data" class="space-y-4">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                
                <div>
                  <label for="add-test-name" class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Test Name</label>
                  <input type="text" id="add-test-name" name="testName" placeholder="e.g., Class Test 1" class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:border-theme-p focus:ring-2 focus:ring-theme-pm/20 transition-all font-medium text-sm" required />
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label for="add-batchId" class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Batch</label>
                    <select id="add-batchId" name="batchId" class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:border-theme-p focus:ring-2 focus:ring-theme-pm/20 transition-all font-medium text-sm" required onchange="handleBatchChange(this, 'add-subject')">
                      <option value="" disabled selected>Select Batch...</option>
                      <% batches.forEach(batch => { %>
                      <option value="<%= batch._id %>"><%= batch.name %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div>
                    <label for="add-subject" class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Subject</label>
                    <select id="add-subject" name="subject" class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:border-theme-p focus:ring-2 focus:ring-theme-pm/20 transition-all font-medium text-sm" required>
                      <option value="" disabled selected>Select Subject...</option>
                    </select>
                  </div>
                </div>

                <div>
                  <label for="add-topic" class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Topic</label>
                  <input type="text" id="add-topic" name="topic" placeholder="e.g., Chemical Reactions" class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:border-theme-p focus:ring-2 focus:ring-theme-pm/20 transition-all font-medium text-sm" required />
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label for="add-total-marks" class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Total Marks</label>
                    <input type="number" id="add-total-marks" name="totalMarks" placeholder="e.g., 25" class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:border-theme-p focus:ring-2 focus:ring-theme-pm/20 transition-all font-medium text-sm" required min="1" />
                  </div>
                  <div>
                    <label for="add-test-date" class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Test Date</label>
                    <input type="date" id="add-test-date" name="testDate" class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:border-theme-p focus:ring-2 focus:ring-theme-pm/20 transition-all font-medium text-sm" required />
                  </div>
                </div>

                <div>
                  <label class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Question Paper (File or Link)</label>
                  <input type="url" id="add-question-paper-link" name="questionPaperLink" placeholder="Paste link to question paper (optional)" class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:border-theme-p focus:ring-2 focus:ring-theme-pm/20 transition-all font-medium text-sm mb-3" />
                  
                  <div class="text-center text-[9px] font-mono font-bold text-theme-fdd uppercase tracking-wider mb-2">— OR —</div>
                  
                  <input type="file" id="add-question-paper-file" name="questionPaperFile" class="w-full text-xs text-theme-fdd file:mr-4 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-theme-pt/10 file:text-theme-pt hover:file:bg-theme-pt/20 border border-theme-b rounded-lg cursor-pointer focus:outline-none bg-theme-bgc/50" />
                  
                  <div class="mt-4">
                    <a href="/teacher/generate_paper" class="w-full py-2 bg-theme-lt/10 text-theme-lt border border-theme-lt/20 rounded-xl hover:bg-theme-lt/20 text-xs font-bold uppercase tracking-wider font-mono flex items-center justify-center gap-1.5 transition-all">
                      <span>✨ Generate Paper with AI Workspace &rarr;</span>
                    </a>
                  </div>

                </div>

                <button type="submit" class="w-full py-3.5 mt-5 btn-solid-purple flex items-center justify-center gap-2 shadow-lg">Submit Test ✓</button>
              </form>
            </div>
            
            <div id="add-message-box" class="mt-4 p-3 rounded-lg text-center hidden text-xs font-semibold"></div>
          </div>
        </div>

        <!-- =================== EDIT TEST MODAL =================== -->
        <div class="modal-overlay" id="edit-test-modal">
          <div class="modal-box max-w-md" style="background: var(--bgc); border: 1px solid var(--bd); border-radius: 18px; padding: 24px;">
            
            <!-- Header -->
            <div class="flex justify-between items-start mb-6 border-b border-theme-bd pb-4">
              <div>
                <h2 class="text-xl font-black uppercase tracking-tight" style="font-family: 'Unbounded', sans-serif; color: var(--pt) !important;">Edit <span style="color: var(--fg) !important;">Test</span></h2>
                <p class="dash-sub mt-1">Update test configuration</p>
              </div>
              <button onclick="closeModal('edit-test-modal')" class="text-theme-fdd hover:text-theme-fg text-2xl font-bold leading-none">&times;</button>
            </div>

            <!-- Body -->
            <div>
              <form id="edit-test-form" enctype="multipart/form-data" class="space-y-4">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                
                <div>
                  <label for="edit-test-name" class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Test Name</label>
                  <input type="text" id="edit-test-name" name="testName" placeholder="e.g., Class Test 1" class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:border-theme-p focus:ring-2 focus:ring-theme-pm/20 transition-all font-medium text-sm" required />
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label for="edit-batchId" class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Batch</label>
                    <select id="edit-batchId" name="batchId" class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:border-theme-p focus:ring-2 focus:ring-theme-pm/20 transition-all font-medium text-sm" required onchange="handleBatchChange(this, 'edit-subject')">
                      <option value="" disabled>Select Batch...</option>
                      <% batches.forEach(batch => { %>
                      <option value="<%= batch._id %>"><%= batch.name %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div>
                    <label for="edit-subject" class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Subject</label>
                    <select id="edit-subject" name="subject" class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:border-theme-p focus:ring-2 focus:ring-theme-pm/20 transition-all font-medium text-sm" required>
                      <option value="" disabled selected>Select Subject...</option>
                    </select>
                  </div>
                </div>

                <div>
                  <label for="edit-topic" class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Topic</label>
                  <input type="text" id="edit-topic" name="topic" placeholder="e.g., Chemical Reactions" class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:border-theme-p focus:ring-2 focus:ring-theme-pm/20 transition-all font-medium text-sm" required />
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label for="edit-total-marks" class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Total Marks</label>
                    <input type="number" id="edit-total-marks" name="totalMarks" placeholder="e.g., 25" class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:border-theme-p focus:ring-2 focus:ring-theme-pm/20 transition-all font-medium text-sm" required min="1" />
                  </div>
                  <div>
                    <label for="edit-test-date" class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest">Test Date</label>
                    <input type="date" id="edit-test-date" name="testDate" class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:border-theme-p focus:ring-2 focus:ring-theme-pm/20 transition-all font-medium text-sm" required />
                  </div>
                </div>

                <div>
                  <label class="block text-[0.62rem] font-bold text-theme-fdd mb-1.5 font-mono uppercase tracking-widest flex items-center justify-between">
                    Question Paper (File or Link)
                    <span id="edit-current-qp-link"></span>
                  </label>
                  <input type="url" id="edit-question-paper-link" name="questionPaperLink" placeholder="Paste link to question paper (optional)" class="w-full px-4 py-2.5 bg-theme-bgc text-theme-fg border border-theme-b rounded-lg focus:border-theme-p focus:ring-2 focus:ring-theme-pm/20 transition-all font-medium text-sm mb-3" />
                  
                  <div class="text-center text-[9px] font-mono font-bold text-theme-fdd uppercase tracking-wider mb-2">— OR —</div>
                  
                  <input type="file" id="edit-question-paper-file" name="questionPaperFile" class="w-full text-xs text-theme-fdd file:mr-4 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-theme-pt/10 file:text-theme-pt hover:file:bg-theme-pt/20 border border-theme-b rounded-lg cursor-pointer focus:outline-none bg-theme-bgc/50" />
                </div>

                <button type="submit" class="w-full py-3.5 mt-5 btn-solid-purple flex items-center justify-center gap-2 shadow-lg">Save Changes ✓</button>
              </form>
            </div>
            
            <div id="edit-message-box" class="mt-4 p-3 rounded-lg text-center hidden text-xs font-semibold"></div>
          </div>
        </div>



      </main>
    </div>
  </div>

  <script>
    function handleBatchChange(selectEl, subjectSelectId) {
      const option = selectEl.options[selectEl.selectedIndex];
      const batchName = option ? option.text : '';
      const subjectDropdown = document.getElementById(subjectSelectId);
      if (typeof updateSubjectDropdowns !== 'undefined') {
        updateSubjectDropdowns([subjectDropdown], batchName);
      }
    }

    function showFormMessage(boxId, message, type) {
      const box = document.getElementById(boxId);
      box.textContent = message;
      box.className = `mt-4 p-3 rounded-lg text-center text-xs font-semibold ${
        type === 'success' 
          ? 'bg-green-500/10 text-green-400 border border-green-500/20' 
          : 'bg-red-500/10 text-red-400 border border-red-500/20'
      }`;
      box.classList.remove('hidden');
    }

    function openAddModal() {
      const today = new Date().toISOString().split('T')[0];
      document.getElementById('add-test-date').value = today;
      document.getElementById('add-test-modal').classList.add('open');
    }

    function openEditModal(id, name, subject, topic, marks, qpUrl, testDate, batchName, batchId) {
      document.getElementById('edit-test-name').value = name;
      
      const batchSelect = document.getElementById('edit-batchId');
      batchSelect.value = batchId;
      
      const subjectSelect = document.getElementById('edit-subject');
      if (typeof updateSubjectDropdowns !== 'undefined') {
        updateSubjectDropdowns([subjectSelect], batchName);
      }
      subjectSelect.value = subject;
      
      document.getElementById('edit-topic').value = topic;
      document.getElementById('edit-total-marks').value = marks;
      document.getElementById('edit-test-date').value = testDate || '';

      const isLink = qpUrl && !qpUrl.includes('cloudinary');
      document.getElementById('edit-question-paper-link').value = isLink ? qpUrl : '';

      const qpLinkContainer = document.getElementById('edit-current-qp-link');
      if (qpUrl && qpUrl.trim() !== '') {
        qpLinkContainer.innerHTML = `<a href="${qpUrl}" target="_blank" class="text-[10px] font-mono font-bold text-emerald-400 hover:text-emerald-300 underline">View current QP &rarr;</a>`;
      } else {
        qpLinkContainer.innerHTML = `<span class="text-[10px] font-mono italic text-theme-fdd">No QP attached</span>`;
      }

      const form = document.getElementById('edit-test-form');
      form.action = `/teacher/edit_test/${id}`;
      document.getElementById('edit-test-modal').classList.add('open');
    }

    function closeModal(id) {
      document.getElementById(id).classList.remove('open');
    }

    function openAiModal() {
      // Pre-fill parameters using main add form
      document.getElementById('ai-subject').value = document.getElementById('add-subject').value || '';
      document.getElementById('ai-topic').value = document.getElementById('add-topic').value || '';
      document.getElementById('ai-marks').value = document.getElementById('add-total-marks').value || '';
      
      document.getElementById('ai-input-step').classList.remove('hidden');
      document.getElementById('ai-editor-step').classList.add('hidden');
      document.getElementById('ai-loading').classList.add('hidden');
      document.getElementById('ai-modal').classList.add('open');
    }

    document.addEventListener("DOMContentLoaded", () => {
      const searchInput = document.getElementById("test-search");
      const classSections = document.querySelectorAll(".class-section");

      // Search functionality
      if (searchInput) {
        searchInput.addEventListener("input", () => {
          const query = searchInput.value.toLowerCase().trim();

          classSections.forEach(section => {
            let visibleCount = 0;
            const rows = section.querySelectorAll(".test-row");
            const msg = section.querySelector(".no-results-msg");
            const tableWrap = section.querySelector(".overflow-x-auto");

            rows.forEach(row => {
              const name = row.querySelector(".search-name").textContent.toLowerCase();
              const sub = row.querySelector(".search-sub").textContent.toLowerCase();
              const topic = row.querySelector(".search-topic").textContent.toLowerCase();

              if (name.includes(query) || sub.includes(query) || topic.includes(query)) {
                row.style.display = "";
                visibleCount++;
              } else {
                row.style.display = "none";
              }
            });

            if (visibleCount === 0) {
              if (tableWrap) tableWrap.classList.add("hidden");
              if (msg) msg.classList.remove("hidden");
            } else {
              if (tableWrap) tableWrap.classList.remove("hidden");
              if (msg) msg.classList.add("hidden");
            }

            const countSpan = section.querySelector(".class-count");
            if (countSpan) countSpan.textContent = visibleCount + (visibleCount === 1 ? ' test' : ' tests');
          });
        });
      }

      // Add Test AJAX submission
      document.getElementById("add-test-form").addEventListener("submit", async function(e) {
        e.preventDefault();
        
        const fileInput = document.getElementById("add-question-paper-file");
        const linkInput = document.getElementById("add-question-paper-link");

        if (fileInput.files.length === 0 && linkInput.value.trim() === "") {
          showFormMessage('add-message-box', 'Please upload a question paper file or provide a link.', 'error');
          return;
        }

        const formData = new FormData(this);
        const msgBox = document.getElementById("add-message-box");
        msgBox.classList.add("hidden");

        try {
          const res = await fetch("/teacher/add_test", {
            method: "POST",
            body: formData,
          });

          const result = await res.json();

          if (result.success) {
            showFormMessage('add-message-box', result.message, 'success');
            this.reset();
            document.getElementById("add-ai-paper-status").classList.add("hidden");
            setTimeout(() => { window.location.reload(); }, 1200);
          } else {
            showFormMessage('add-message-box', result.message, 'error');
          }
        } catch (err) {
          console.error(err);
          showFormMessage('add-message-box', 'Network Error: Failed to submit test', 'error');
        }
      });

      // Edit Test AJAX submission
      document.getElementById("edit-test-form").addEventListener("submit", async function(e) {
        e.preventDefault();
        
        const formData = new FormData(this);
        const msgBox = document.getElementById("edit-message-box");
        msgBox.classList.add("hidden");

        try {
          const res = await fetch(this.action, {
            method: "POST",
            body: formData,
          });

          const result = await res.json();

          if (result.success) {
            showFormMessage('edit-message-box', result.message, 'success');
            this.reset();
            setTimeout(() => { window.location.reload(); }, 1200);
          } else {
            showFormMessage('edit-message-box', result.message, 'error');
          }
        } catch (err) {
          console.error(err);
          showFormMessage('edit-message-box', 'Network Error: Failed to update test', 'error');
        }
      });

      // Close modals when clicking backdrop
      ['add-test-modal', 'edit-test-modal'].forEach(id => {
        const overlay = document.getElementById(id);
        if (overlay) {
          overlay.addEventListener('click', function(e) {
            if (e.target === this) closeModal(id);
          });
        }
      });

      // Check query params for action=add to auto-open modal
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('action') === 'add') {
        openAddModal();
        window.history.replaceState({}, document.title, window.location.pathname);
      }
    });


    function filterBatch(cls) {
      document.querySelectorAll('.batch-tab-filter').forEach(btn => {
        const isActive = btn.dataset.class === cls;
        if (isActive) {
          btn.className = 'batch-tab-filter py-1.5 px-4 rounded-full text-[0.68rem] font-bold uppercase tracking-wider border transition-all bg-purple-700 text-white border-purple-700 font-mono';
        } else {
          btn.className = 'batch-tab-filter py-1.5 px-4 rounded-full text-[0.68rem] font-bold uppercase tracking-wider border transition-all text-theme-pt border-theme-bd hover:bg-theme-bgch font-mono';
        }
      });
      document.querySelectorAll('.class-section').forEach(section => {
        section.style.display = (cls === 'All' || section.dataset.class === cls) ? '' : 'none';
      });
    }
  </script>
</body>

</html>