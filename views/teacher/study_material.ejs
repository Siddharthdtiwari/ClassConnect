<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Upload Study Material</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body {
      font-family: "Inter", sans-serif;
    }

    .bg-brand-background {
      background-color: #fafafa;
    }
    .text-brand-purple { color: #5d3a9b; }
    .bg-brand-purple { background-color: #5d3a9b; }
    .border-brand-purple { border-color: #5d3a9b; }
    
    .btn-solid-purple {
      background-color: #5d3a9b;
      color: #fff;
      font-weight: 600;
      transition: all 0.3s ease;
      border-radius: 0.75rem;
      border: 1px solid #5d3a9b;
      padding: 0.75rem 1.5rem;
      box-shadow: 0 4px 6px -1px rgba(93, 58, 155, 0.2);
    }
    .btn-solid-purple:hover {
      background-color: #4b2d84;
      border-color: #4b2d84;
      box-shadow: 0 10px 15px -3px rgba(93, 58, 155, 0.3);
      transform: translateY(-1px);
    }

    .btn-outline-purple {
      color: #5d3a9b;
      border: 1px solid #5d3a9b;
      font-weight: 600;
      transition: all 0.3s ease;
      border-radius: 0.5rem;
    }
    .btn-outline-purple:hover { background-color: #bde045; color: #333; border-color: #bde045; }

    .premium-card {
      background: #ffffff;
      border: 1px solid rgba(0, 0, 0, 0.04);
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05),
                  0 10px 15px -3px rgba(0, 0, 0, 0.02),
                  0 25px 50px -12px rgba(93, 58, 155, 0.08);
      border-radius: 1.5rem;
    }

    .soft-input {
      background-color: #f8f9fa;
      border: 1px solid #e5e7eb;
      transition: all 0.2s ease;
    }
    .soft-input:focus {
      background-color: #ffffff;
      outline: none;
      border-color: #5d3a9b;
      box-shadow: 0 0 0 4px rgba(93, 58, 155, 0.1);
    }

    .photo-upload-area {
      border: 2px dashed #e5e7eb;
      background-color: #f8f9fa;
      transition: all 0.2s ease;
    }
    .photo-upload-area:hover {
      border-color: #5d3a9b;
      background-color: #f3e8ff;
    }
    .btn-outline-purple:hover { background-color: #bde045; color: #333; border-color: #bde045; }

    .class-badge      { background: #5d3a9b; color: #fff; }
    .badge-textbook   { background: #dbeafe; color: #1e40af; }
    .badge-questionpaper { background: #fce7f3; color: #9d174d; }
    .badge-notes      { background: #d1fae5; color: #065f46; }
    .badge-default    { background: #f3f4f6; color: #374151; }

    .download-btn {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.375rem 0.75rem;
      border-radius: 0.5rem;
      font-size: 0.75rem;
      font-weight: 600;
      text-decoration: none;
      background: #5d3a9b;
      color: #fff;
      transition: background 0.2s;
    }
    .download-btn:hover { background: #4b2d84; }
  </style>
</head>

<%- include('../partials/background') %>

<body class="bg-brand-background text-gray-800">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">
    <header class="mb-10 text-center sm:text-left">
      <a href="/teacher/dashboard" class="text-brand-purple hover:underline mb-4 block">&larr; Back to Dashboard</a>
      <h1 class="text-3xl md:text-5xl font-black text-gray-900 tracking-tight">
        Study Material
      </h1>
      <p class="text-gray-500 mt-3 text-lg font-medium">
        Add curriculum notes, presentations, and resources.
      </p>
    </header>

    <div class="premium-card p-6 sm:p-10 mb-12">
      <div class="mb-8 border-b border-gray-100 pb-6 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-purple-50 flex items-center justify-center text-brand-purple">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
          </div>
          <h2 id="form-title" class="text-2xl font-bold text-gray-900">Upload New Resource</h2>
        </div>
        <button type="button" id="cancel-edit-btn" class="hidden text-sm font-semibold text-gray-500 hover:text-gray-800 transition-colors">Cancel Edit</button>
      </div>

      <form id="upload-form" class="space-y-8">
        <input type="hidden" id="edit-id" name="editId" value="">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <div>
            <label for="standard-select" class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Standard</label>
            <select id="standard-select" name="standard" class="soft-input w-full px-4 py-3 rounded-xl text-gray-700 font-medium appearance-none">
              <option value="">Select Standard</option>
              <% for(let i=0;i<=10;i++){ %>
              <option value="<%=i%>">Grade <%= i %></option>
              <% } %>
            </select>
          </div>

          <div>
            <label for="subject-select" class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Subject</label>
            <select id="subject-select" name="subject" class="soft-input w-full px-4 py-3 rounded-xl text-gray-700 font-medium appearance-none">
              <option value="">-- Choose a Subject --</option>
              <option value="English">English</option>
              <option value="Maths I">Maths I</option>
              <option value="Maths II">Maths II</option>
              <option value="Science I">Science I</option>
              <option value="Science II">Science II</option>
              <option value="History-Civics">History-Civics</option>
              <option value="Geography">Geography</option>
              <option value="Hindi">Hindi</option>
              <option value="Marathi">Marathi</option>
            </select>
          </div>

          <div class="sm:col-span-2 lg:col-span-1">
            <label for="material-type" class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Material Type</label>
            <select id="material-type" name="materialType" class="soft-input w-full px-4 py-3 rounded-xl text-gray-700 font-medium appearance-none">
              <option value="">-- Select Material Type --</option>
              <option value="textbook">Textbook</option>
              <option value="questionPaper">Question Paper</option>
              <option value="notes">Study Material</option>
            </select>
          </div>
        </div>

        <div>
          <label for="material-description" class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Description <span class="text-gray-400 font-normal normal-case">(Optional)</span></label>
          <textarea id="material-description" name="description" rows="2" placeholder="Briefly describe the content of the material..." class="soft-input mt-1 block w-full rounded-xl py-3 px-4 text-gray-700 font-medium"></textarea>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
          <div class="photo-upload-area rounded-2xl p-8 text-center cursor-pointer relative group h-48 flex flex-col justify-center items-center">
            <input type="file" id="file-upload" name="file" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-20" />
            <div class="w-12 h-12 rounded-full bg-purple-100 flex items-center justify-center text-brand-purple mb-3 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
            </div>
            <span class="text-base font-bold text-brand-purple">Click or drag file to upload</span>
            <p class="text-xs text-gray-500 mt-1">PDF, DOCX, or Images up to 10MB</p>
          </div>

          <div class="h-48 flex flex-col justify-center relative">
            <div class="absolute left-[-15px] md:left-[-1.5rem] top-1/2 -translate-y-1/2 bg-white px-2 text-xs font-bold text-gray-400 z-10 hidden md:block w-8 text-center bg-transparent">OR</div>
            <div class="absolute bottom-[100%] left-1/2 -translate-x-1/2 bg-white px-2 text-xs font-bold text-gray-400 z-10 md:hidden pb-2 bg-transparent text-center h-4">OR</div>
            
            <div class="p-6 bg-[#f8f9fa] border border-[#e5e7eb] rounded-2xl h-full flex flex-col justify-center">
              <label for="link-input" class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-3 flex items-center gap-2">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                External Link
              </label>
              <input type="url" id="link-input" name="link" placeholder="https://example.com/resource.pdf" class="soft-input w-full rounded-xl py-3 px-4 font-medium" />
              <p class="text-xs text-gray-400 mt-2">Paste a direct link to a Google Drive or external file.</p>
            </div>
          </div>
        </div>

        <div class="pt-4 flex justify-end">
          <button type="submit" id="submit-btn" class="btn-solid-purple w-full sm:w-auto text-lg px-8 flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
            Publish Material
          </button>
        </div>
      </form>

      <div id="message-box" class="mt-6 p-4 rounded-xl text-center hidden font-medium"></div>
    </div>

    <!-- Previous Uploads Section Header -->
    <div class="mb-8 pl-2">
      <h2 class="text-2xl font-bold text-gray-900">Previous Uploads</h2>
      <p class="text-gray-500 mt-1">Review and manage currently uploaded study materials.</p>
    </div>

    <%
        // Group materials by standard
        const grouped = {};
        materials.forEach(mat => {
          const key = mat.standard || 'Other';
          if (!grouped[key]) grouped[key] = [];
          grouped[key].push(mat);
        });
        const sortedStandards = Object.keys(grouped).sort((a, b) => Number(a) - Number(b));
      %>

      <% if (sortedStandards.length === 0) { %>
        <div class="text-center py-12 text-gray-400">
          <p class="text-lg font-medium">No materials uploaded yet.</p>
          <p class="text-sm mt-1">Use the form above to add your first resource.</p>
        </div>
      <% } %>

      <% sortedStandards.forEach(std => { %>
        <div class="mb-8" data-standard-section="<%= std %>">
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold class-badge">Class <%= std %></span>
            <span class="text-xs text-gray-400 font-medium"><%= grouped[std].length %> material<%= grouped[std].length !== 1 ? 's' : '' %></span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <% grouped[std].forEach(mat => {
              const typeLabels = {
                textbook: 'Textbook',
                questionPaper: 'Question Paper',
                notes: 'Study Material'
              };
              const typeClass = {
                textbook: 'badge-textbook',
                questionPaper: 'badge-questionpaper',
                notes: 'badge-notes'
              }[mat.materialType] || 'badge-default';
              const typeLabel = typeLabels[mat.materialType] || mat.materialType;
            %>
            <div class="bg-white p-4 rounded-xl border border-gray-100 shadow-sm flex items-start sm:items-center justify-between gap-4 group hover:shadow-md transition-shadow">
                <div class="flex-1 min-w-0 pr-4">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider <%= typeClass %>">
                      <%= typeLabels[mat.materialType] || mat.materialType %>
                    </span>
                    <span class="text-sm font-bold text-gray-800 truncate" title="<%= mat.subject %>"><%= mat.subject %></span>
                  </div>
                  <p class="text-sm text-gray-500 line-clamp-2 mt-1">
                    <%= mat.description || 'No description provided.' %>
                  </p>
                  <p class="text-xs text-gray-400 mt-2">
                    Uploaded: <%= (mat.uploadDate || new Date()).toLocaleDateString() %>
                  </p>
                </div>
                
                <div class="flex flex-col sm:flex-row gap-2">
                  <% if(mat.filePath) { %>
                  <a href="<%= mat.filePath %>" target="_blank" class="download-btn">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                    View
                  </a>
                  <% } else if(mat.link) { %>
                  <a href="<%= mat.link %>" target="_blank" class="download-btn">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                    Link
                  </a>
                  <% } %>
                  
                  <!-- Edit Action -->
                  <button type="button" 
                    data-action="edit"
                    data-id="<%= mat._id %>"
                    data-standard="<%= mat.standard %>"
                    data-subject="<%= mat.subject %>"
                    data-type="<%= mat.materialType %>"
                    data-description="<%= mat.description || '' %>"
                    data-link="<%= mat.filePath || mat.link || '' %>"
                    class="flex-shrink-0 inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-semibold text-brand-purple bg-purple-50 hover:bg-purple-100 transition-colors border border-purple-100">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                    Edit
                  </button>

                  <!-- Delete Action -->
                  <button type="button" onclick="deleteMaterial('<%= mat._id %>')" class="flex-shrink-0 inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-semibold text-red-600 bg-red-50 hover:bg-red-100 transition-colors border border-red-100">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    Delete
                  </button>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const uploadForm = document.getElementById("upload-form");
      const messageBox = document.getElementById("message-box");
      const materialsContainer = document.querySelector(".space-y-4");
      const cancelEditBtn = document.getElementById("cancel-edit-btn");
      const formTitle = document.getElementById("form-title");
      const submitBtn = document.getElementById("submit-btn");
      const editIdInput = document.getElementById("edit-id");

      function showMessage(message, type = "success") {
        messageBox.textContent = message;
        messageBox.className = `mt-6 p-4 rounded-xl text-center font-medium block ${
          type === "success"
            ? "bg-green-100 text-green-800 border border-green-200"
            : "bg-red-100 text-red-800 border border-red-200"
        }`;
      }

      function resetForm() {
        uploadForm.reset();
        editIdInput.value = "";
        formTitle.textContent = "Upload New Resource";
        submitBtn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg> Publish Material';
        cancelEditBtn.classList.add("hidden");
      }

      cancelEditBtn.addEventListener("click", resetForm);

      uploadForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        
        const fileInput = document.getElementById("file-upload");
        const linkInput = document.getElementById("link-input");
        const isEditing = !!editIdInput.value;

        if (!isEditing && !fileInput.files[0] && !linkInput.value.trim()) {
          showMessage("Please upload a file or provide an external link.", "error");
          return;
        }

        const formData = new FormData(uploadForm);
        
        try {
          const url = isEditing ? `/api/materials/${editIdInput.value}` : "/teacher/study_material";
          const method = isEditing ? "PUT" : "POST";

          submitBtn.disabled = true;
          submitBtn.innerHTML = '<svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Saving...';

          const res = await fetch(url, {
            method: method,
            body: formData,
          });

          const data = await res.json();
          submitBtn.disabled = false;

          if (data.success) {
            showMessage(data.message, "success");
            setTimeout(() => window.location.reload(), 1500);
          } else {
            showMessage(data.message || data.error, "error");
            submitBtn.innerHTML = isEditing ? '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg> Update Material' : '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg> Publish Material';
          }
        } catch (error) {
          showMessage(error.message, "error");
          submitBtn.disabled = false;
          submitBtn.innerHTML = isEditing ? 'Update Material' : 'Publish Material';
        }
      });
    });

    function editMaterial(id, standard, subject, type, description, existingLink) {
      document.getElementById("edit-id").value = id;
      document.getElementById("standard-select").value = standard;
      document.getElementById("subject-select").value = subject;
      document.getElementById("material-type").value = type;
      document.getElementById("material-description").value = description;
      
      if (existingLink && existingLink.startsWith('http')) {
        document.getElementById("link-input").value = existingLink;
      } else {
        document.getElementById("link-input").value = "";
      }

      document.getElementById("form-title").textContent = "Edit Resource";
      document.getElementById("submit-btn").innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg> Update Material';
      document.getElementById("cancel-edit-btn").classList.remove("hidden");
      
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    document.addEventListener('click', (e) => {
      const editBtn = e.target.closest('button[data-action="edit"]');
      if (editBtn) {
        editMaterial(
          editBtn.dataset.id,
          editBtn.dataset.standard,
          editBtn.dataset.subject,
          editBtn.dataset.type,
          editBtn.dataset.description,
          editBtn.dataset.link
        );
      }
    });

    async function deleteMaterial(id) {
      if (!confirm("Are you sure you want to delete this study material?")) return;
      
      try {
        const res = await fetch(`/api/materials/${id}`, {
          method: 'DELETE'
        });
        
        const data = await res.json();
        
        if (res.ok) {
          const btn = document.querySelector(`button[onclick="deleteMaterial('${id}')"]`);
          if (btn) {
            const card = btn.closest('.bg-white.p-4.rounded-xl');
            if (card) {
              card.style.opacity = '0';
              setTimeout(() => card.remove(), 300);
            }
          }
        } else {
          alert('Failed to delete: ' + (data.error || 'Unknown error'));
        }
      } catch (err) {
        console.error('Delete error:', err);
        alert('An error occurred trying to delete the material.');
      }
    }
  </script>
</body>

</html>