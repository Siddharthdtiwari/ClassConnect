<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Exam Timetable | Teacher</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: "Inter", sans-serif; }
    .bg-brand-background { background-image: linear-gradient(120deg, #f3e8ff 0%, #eef2f3 100%); }
    .text-brand-purple { color: #5d3a9b; }
    .btn-solid-purple {
      background-color: #5d3a9b; color: #fff; font-weight: 600; transition: all 0.3s ease;
      border-radius: 0.5rem; border: 1px solid #5d3a9b;
    }
    .btn-solid-purple:hover { background-color: #4b2d84; border-color: #4b2d84; }
    .btn-outline-purple {
      color: #5d3a9b; border: 1px solid #5d3a9b; font-weight: 600;
      border-radius: 0.5rem; transition: all 0.3s ease;
    }
    .btn-outline-purple:hover { background-color: #bde045; color: #333; border-color: #bde045; }
    .data-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .data-table thead tr { background: #5d3a9b; color: #fff; }
    .data-table th { padding: 0.75rem 1rem; text-align: left; font-weight: 600; border: 1px solid #4b2d84; white-space: nowrap; }
    .data-table td { padding: 0.65rem 1rem; border: 1px solid #d8b4e2; }
    .data-table tbody tr:nth-child(even) { background: #f9f5ff; }
    .data-table tbody tr:hover td { background: #ede9fe; }
    .badge { display: inline-flex; align-items: center; padding: 2px 10px; border-radius: 9999px; font-size: 0.72rem; font-weight: 700; }
    .badge-ut1  { background:#dbeafe; color:#1e40af; }
    .badge-ut2  { background:#fce7f3; color:#9d174d; }
    .badge-sem1 { background:#d1fae5; color:#065f46; }
    .badge-sem2 { background:#fef3c7; color:#92400e; }
    .badge-ct   { background:#ede9fe; color:#5b21b6; }
    /* ===== PREMIUM MODAL ===== */
    .modal-overlay { position:fixed; inset:0; background:rgba(17,7,35,0.6); backdrop-filter:blur(8px); z-index:50; display:none; align-items:center; justify-content:center; padding:1rem; }
    .modal-overlay.open { display:flex; }
    .modal-box { background:white; border-radius:1.5rem; overflow:hidden; width:100%; max-width:600px; box-shadow:0 32px 64px -12px rgba(75,45,132,0.45); animation:pop 0.25s cubic-bezier(.34,1.56,.64,1); max-height:92vh; display:flex; flex-direction:column; }
    .modal-header { background:linear-gradient(135deg,#3b1f72 0%,#6d3fc4 100%); padding:1.75rem 2rem; color:white; flex-shrink:0; }
    .modal-body { padding:1.75rem 2rem; overflow-y:auto; flex:1; }
    @keyframes pop { from{transform:scale(0.88) translateY(16px);opacity:0} to{transform:scale(1) translateY(0);opacity:1} }
    .etype-pill { cursor:pointer; padding:0.45rem 1rem; border-radius:9999px; font-size:0.82rem; font-weight:700; border:2px solid #e5e7eb; color:#6b7280; background:white; transition:all 0.2s; }
    .etype-pill:hover { border-color:#7c52ca; color:#5d3a9b; background:#f5f3ff; }
    .etype-pill.selected { background:linear-gradient(135deg,#5d3a9b,#7c52ca); color:white; border-color:transparent; box-shadow:0 4px 12px rgba(93,58,155,0.4); transform:translateY(-1px); }
    .subject-row-premium { background:#faf8ff; border:1px solid #ede9fe; border-radius:0.875rem; padding:0.75rem 1rem; display:grid; grid-template-columns:1.5rem 1fr 1fr 1fr auto; gap:0.6rem; align-items:center; transition:border 0.2s; }
    .subject-row-premium:focus-within { border-color:#7c52ca; box-shadow:0 0 0 3px rgba(124,82,202,0.12); }
    @media(max-width:540px) {
      .subject-row-premium { grid-template-columns:1fr 1fr auto; grid-template-rows:auto auto; padding-top:0.65rem; }
      .subject-row-premium .row-num { display:none; }
      .subject-row-premium input:nth-child(2) { grid-column:1/3; grid-row:1; }
      .subject-row-premium button:last-child { grid-column:3; grid-row:1; }
      .subject-row-premium input:nth-child(3) { grid-column:1; grid-row:2; }
      .subject-row-premium input:nth-child(4) { grid-column:2/4; grid-row:2; }
    }
    .row-num { width:1.5rem; height:1.5rem; border-radius:9999px; background:linear-gradient(135deg,#5d3a9b,#a855f7); color:white; display:flex; align-items:center; justify-content:center; font-size:0.7rem; font-weight:800; flex-shrink:0; }
    .srow-input { border:none; background:transparent; padding:0.35rem 0.5rem; font-size:0.85rem; font-weight:500; border-bottom:1.5px solid #e5e7eb; border-radius:0; width:100%; transition:border-color 0.2s; }
    .srow-input:focus { outline:none; border-bottom-color:#7c52ca; }
    .add-row-btn { border:2px dashed #d8b4fe; border-radius:0.875rem; padding:0.65rem; text-align:center; color:#7c52ca; font-size:0.82rem; font-weight:700; cursor:pointer; transition:all 0.2s; margin-top:0.5rem; }
    .add-row-btn:hover { background:#f5f3ff; border-color:#7c52ca; }
    .btn-glow { background:linear-gradient(135deg,#5d3a9b 0%,#7c52ca 100%); color:white; font-weight:800; font-size:0.95rem; padding:0.9rem; border-radius:0.875rem; width:100%; transition:all 0.25s; box-shadow:0 4px 20px rgba(93,58,155,0.45); letter-spacing:0.01em; display:block; text-align:center; }
    .btn-glow:hover { box-shadow:0 8px 32px rgba(93,58,155,0.6); transform:translateY(-2px); }
    input, select, textarea { border-radius:0.5rem; border:1px solid #e5e7eb; padding:0.5rem 0.75rem; font-size:0.875rem; transition:border 0.2s, box-shadow 0.2s; }
    input:focus, select:focus, textarea:focus { outline:none; border-color:#5d3a9b; box-shadow:0 0 0 3px rgba(93,58,155,0.15); }
    label { font-size:0.8rem; font-weight:700; color:#374151; display:block; margin-bottom:0.3rem; }
  </style>
</head>

<%- include('../partials/background') %>

<body class="text-gray-800">
  <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">

    <!-- Header — Manage Fees style -->
    <header class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <div>
        <a href="/teacher/dashboard" class="text-sm font-medium text-brand-purple hover:underline mb-2 inline-block">
          &larr; Back to Dashboard
        </a>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mt-1">📅 Exam Timetable</h1>
        <p class="text-gray-600 mt-2">Schedule and manage exam dates, subjects and portions for each class.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <!-- Class filter -->
        <form method="GET" action="/teacher/timetable" class="flex items-center gap-2">
          <select name="standard" onchange="this.form.submit()" class="py-2 px-3 btn-outline-purple text-sm" style="width:auto;border-radius:0.5rem">
            <option value="">All Classes</option>
            <% allStandards.forEach(std => { %>
            <option value="<%= std %>" <%= selectedStandard === std ? 'selected' : '' %>><%= std %></option>
            <% }) %>
          </select>
        </form>
        <button onclick="openAddModal()" class="py-2 px-5 btn-solid-purple text-sm shadow">
          ➕ Add Exams
        </button>
      </div>
    </header>

    <!-- Toast Notifications -->
    <% if (success) { %>
    <div id="toast-success" class="mb-4 flex items-center gap-3 bg-green-50 border border-green-200 text-green-800 rounded-xl px-5 py-3 shadow-sm">
      <span>✅</span><span class="font-semibold text-sm"><%= success %></span>
    </div>
    <% } %>
    <% if (error) { %>
    <div id="toast-error" class="mb-4 flex items-center gap-3 bg-red-50 border border-red-200 text-red-800 rounded-xl px-5 py-3 shadow-sm">
      <span>❌</span><span class="font-semibold text-sm"><%= error %></span>
    </div>
    <% } %>

    <!-- Exam Type Tabs -->
    <div class="bg-white p-4 rounded-xl border border-purple-100 shadow-sm mb-4 flex flex-wrap gap-2">
      <% ['All','Unit Test 1','Unit Test 2','Semester 1','Semester 2','Class Test'].forEach((t,i) => { %>
      <button onclick="filterExams('<%= t %>')" 
        class="tab-filter py-1.5 px-4 rounded-full text-sm font-semibold border transition-all <%= i===0 ? 'bg-purple-700 text-white border-purple-700' : 'bg-white text-brand-purple border-purple-200 hover:bg-purple-50' %>"
        data-type="<%= t %>"><%= t === 'All' ? '🗓 All' : t %></button>
      <% }) %>
    </div>

    <!-- Table Card -->
    <div class="bg-white p-6 rounded-xl shadow border border-purple-100 mb-8">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
        <h2 class="text-xl font-bold text-gray-800">Exam Schedule</h2>
        <div class="relative w-full sm:w-64">
          <input type="text" id="exam-search" placeholder="Search subject or class..." class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-purple-300 focus:border-purple-400">
          <svg class="w-5 h-5 text-gray-400 absolute left-3 top-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
      </div>

      <% if (entries.length === 0) { %>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <div class="text-5xl mb-4">📋</div>
        <p class="text-lg font-bold text-gray-700 mb-2">No Exam Entries Yet</p>
        <p class="text-gray-400 text-sm">Click <strong>"+ Add Exams"</strong> to schedule.</p>
      </div>
      <% } else { %>
      <div class="overflow-x-auto rounded-xl shadow-sm border border-gray-200">
        <table class="data-table" id="timetable-table">
          <thead>
            <tr>
              <th>Class</th>
              <th>Subject</th>
              <th>Exam Type</th>
              <th>Date</th>
              <th>Chapters / Portions</th>
              <th>Added By</th>
              <th class="text-center">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% entries.forEach(entry => {
              const typeMap = { 'Unit Test 1':'badge-ut1','Unit Test 2':'badge-ut2','Semester 1':'badge-sem1','Semester 2':'badge-sem2','Class Test':'badge-ct' };
              const badgeClass = typeMap[entry.examType] || 'badge-ct';
              const formattedDate = new Date(entry.examDate).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'});
              const inputDate = new Date(entry.examDate).toISOString().split('T')[0];
              const isPast = new Date(entry.examDate) < new Date();
            %>
            <tr class="exam-row <%= isPast ? 'opacity-60' : '' %>" data-type="<%= entry.examType %>">
              <td><span class="font-medium text-gray-600"><%= entry.standard %></span></td>
              <td class="font-bold text-gray-900 search-subject"><%= entry.subject %></td>
              <td><span class="badge <%= badgeClass %>"><%= entry.examType %></span></td>
              <td class="font-semibold <%= isPast ? 'text-gray-400' : 'text-brand-purple' %>">
                <%= formattedDate %><% if (isPast) { %> <span class="text-xs text-gray-400">(Past)</span><% } %>
              </td>
              <td class="text-gray-600"><%= entry.chapters %></td>
              <td>
                <span class="text-xs font-semibold <%= entry.addedBy === 'teacher' ? 'text-purple-700' : 'text-blue-700' %>">
                  <%= entry.addedBy === 'teacher' ? '👩‍🏫' : '🎓' %> <%= entry.addedByName %>
                </span>
              </td>
              <td class="text-center">
                <div class="flex items-center justify-center gap-2">
                  <button onclick="openEditModal(this)"
                    data-id="<%= entry._id %>"
                    data-standard="<%= entry.standard %>"
                    data-examtype="<%= entry.examType %>"
                    data-subject="<%= entry.subject %>"
                    data-date="<%= inputDate %>"
                    data-chapters="<%= entry.chapters %>"
                    class="py-1 px-3 text-xs font-bold rounded-md btn-outline-purple">✏️ Edit</button>
                  <form method="POST" action="/teacher/timetable/delete/<%= entry._id %>" onsubmit="return confirm('Delete this entry?')">
                    <button type="submit" class="py-1 px-3 text-xs font-bold rounded-md bg-red-50 text-red-600 border border-red-200 hover:bg-red-600 hover:text-white transition-all">🗑️</button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <div id="no-results-msg" class="hidden p-6 text-center text-gray-500 bg-gray-50 border border-t-0 border-gray-200 rounded-b-xl italic">No entries found.</div>
      <% } %>
    </div>
  </div>

  <!-- =================== ADD MODAL PREMIUM =================== -->
  <div class="modal-overlay" id="add-modal">
    <div class="modal-box">
      <!-- Gradient Header -->
      <div class="modal-header">
        <div class="flex justify-between items-start">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-2xl">📅</span>
              <h2 class="text-2xl font-extrabold tracking-tight">Schedule Exams</h2>
            </div>
            <p class="text-purple-200 text-sm">Add multiple subjects at once for any class &amp; exam type</p>
          </div>
          <button onclick="closeModal('add-modal')" class="text-white/60 hover:text-white text-3xl font-light leading-none mt-1">&times;</button>
        </div>
      </div>
      <!-- Body -->
      <div class="modal-body">
        <form method="POST" action="/teacher/timetable/bulk" id="add-form-teacher" onsubmit="return validateTeacherForm()">
          <!-- Class field -->
          <div class="mb-5">
            <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-2">① Class / Standard</p>
            <input name="standard" type="text" placeholder="e.g. 10th, 9A, Class 8…" required style="width:100%" />
          </div>
          <!-- Exam Type pills -->
          <div class="mb-6">
            <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3">② Exam Type</p>
            <div class="flex flex-wrap gap-2" id="etype-pills">
              <% [['Unit Test 1','🧪'],['Unit Test 2','🧫'],['Semester 1','📘'],['Semester 2','📗'],['Class Test','✍️']].forEach(([t,icon]) => { %>
              <button type="button" class="etype-pill" data-val="<%= t %>" onclick="selectEtype(this)"><%= icon %> <%= t %></button>
              <% }) %>
            <input type="hidden" name="examType" id="hidden-examType" />
          </div>
          <!-- Subjects -->
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3">③ Subjects &amp; Dates</p>
            <div id="subject-rows" class="space-y-2.5"></div>
            <div class="add-row-btn mt-3" onclick="addSubjectRow()">＋ Add another subject</div>
          </div>
          <button type="submit" class="btn-glow mt-7">Save All Exams ✓</button>
        </form>
      </div>
    </div>
  </div>

  <!-- =================== EDIT MODAL =================== -->
  <div class="modal-overlay" id="edit-modal">
    <div class="modal-box">
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-xl font-extrabold text-brand-purple">✏️ Edit Exam Entry</h2>
        <button onclick="closeModal('edit-modal')" class="text-gray-400 hover:text-gray-700 text-2xl font-bold">&times;</button>
      </div>
      <form method="POST" id="edit-form" class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div><label>Class / Standard</label><input id="edit-standard" name="standard" type="text" required /></div>
          <div>
            <label>Exam Type</label>
            <select id="edit-examType" name="examType" required>
              <option>Unit Test 1</option><option>Unit Test 2</option>
              <option>Semester 1</option><option>Semester 2</option><option>Class Test</option>
            </select>
          </div>
        </div>
        <div><label>Subject</label><input id="edit-subject" name="subject" type="text" required /></div>
        <div><label>Exam Date</label><input id="edit-examDate" name="examDate" type="date" required /></div>
        <div><label>Chapters / Portions</label><textarea id="edit-chapters" name="chapters" rows="2" required></textarea></div>
        <button type="submit" class="w-full py-3 btn-solid-purple rounded-xl font-bold">Update Exam ✓</button>
      </form>
    </div>
  </div>

  <script>
    function openAddModal() {
      document.getElementById('subject-rows').innerHTML = '';
      document.querySelectorAll('.etype-pill').forEach(p => p.classList.remove('selected'));
      document.getElementById('hidden-examType').value = '';
      addSubjectRow();
      document.getElementById('add-modal').classList.add('open');
    }
    function selectEtype(pill) {
      document.querySelectorAll('.etype-pill').forEach(p => p.classList.remove('selected'));
      pill.classList.add('selected');
      document.getElementById('hidden-examType').value = pill.dataset.val;
    }
    function addSubjectRow() {
      const rows = document.getElementById('subject-rows');
      const num = rows.children.length + 1;
      const div = document.createElement('div');
      div.className = 'subject-row-premium';
      div.innerHTML = `
        <span class="row-num">${num}</span>
        <select name="subjects[]" required class="srow-input cursor-pointer bg-transparent">
          <option value="" disabled selected>Select Subject...</option>
          <option value="English">English</option>
          <option value="Maths I">Maths I</option>
          <option value="Maths II">Maths II</option>
          <option value="Science I">Science I</option>
          <option value="Science II">Science II</option>
          <option value="History-Civics">History-Civics</option>
          <option value="Geography">Geography</option>
          <option value="Hindi">Hindi</option>
          <option value="Marathi">Marathi</option>
        </select>
        <input name="dates[]" type="date" required class="srow-input" />
        <input name="chapters[]" type="text" placeholder="Ch. 1, 2…" class="srow-input" />
        <button type="button" onclick="removeRow(this)" class="text-red-300 hover:text-red-500 text-xl font-bold leading-none">&times;</button>`;
      rows.appendChild(div);
      renumberRows();
    }
    function removeRow(btn) { btn.closest('.subject-row-premium').remove(); renumberRows(); }
    function renumberRows() { document.querySelectorAll('#subject-rows .row-num').forEach((el,i) => el.textContent = i+1); }
    function validateTeacherForm() {
      if (!document.getElementById('hidden-examType').value) {
        alert("Please select an Exam Type (e.g. Unit Test 1) before saving.");
        return false;
      }
      return true;
    }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }
    function openEditModal(btn) {
      const form = document.getElementById('edit-form');
      form.action = '/teacher/timetable/edit/' + btn.dataset.id;
      document.getElementById('edit-standard').value = btn.dataset.standard;
      document.getElementById('edit-examType').value = btn.dataset.examtype;
      document.getElementById('edit-subject').value = btn.dataset.subject;
      document.getElementById('edit-examDate').value = btn.dataset.date;
      document.getElementById('edit-chapters').value = btn.dataset.chapters;
      document.getElementById('edit-modal').classList.add('open');
    }
    document.querySelectorAll('.modal-overlay').forEach(o => o.addEventListener('click', function(e){ if(e.target===this) closeModal(this.id); }));

    function filterExams(type) {
      document.querySelectorAll('.tab-filter').forEach(btn => {
        const isActive = btn.dataset.type === type;
        btn.className = 'tab-filter py-1.5 px-4 rounded-full text-sm font-semibold border transition-all ' +
          (isActive ? 'bg-purple-700 text-white border-purple-700' : 'bg-white text-brand-purple border-purple-200 hover:bg-purple-50');
      });
      document.querySelectorAll('.exam-row').forEach(row => {
        row.style.display = (type === 'All' || row.dataset.type === type) ? '' : 'none';
      });
    }

    // Search
    const searchInput = document.getElementById('exam-search');
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        const q = searchInput.value.toLowerCase();
        let any = false;
        document.querySelectorAll('.exam-row').forEach(row => {
          const subj = row.querySelector('.search-subject')?.textContent.toLowerCase() || '';
          const match = subj.includes(q);
          row.style.display = match ? '' : 'none';
          if (match) any = true;
        });
        const noRes = document.getElementById('no-results-msg');
        if (noRes) noRes.classList.toggle('hidden', any || !q);
      });
    }

    // Auto-dismiss toasts
    setTimeout(() => {
      ['toast-success','toast-error'].forEach(id => { const el=document.getElementById(id); if(el) el.style.display='none'; });
    }, 4000);
  </script>
</body>
</html>
