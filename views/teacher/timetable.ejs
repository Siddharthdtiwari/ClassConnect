<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Exam Timetable | Teacher</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  
</head>

<%- include('../partials/background') %>


<body class="text-theme-fg m-0 p-0 overflow-hidden" style="background: var(--bg);">
  <div style="display: flex; height: 100vh; overflow: hidden;">
    <%- include('../partials/teacher_sidebar') %>
    
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative;">
      <main style="flex: 1; overflow-y: auto; overflow-x: hidden;">
        <div class="content-container container mx-auto p-4 sm:p-6 lg:p-8 min-h-screen">

    <!-- Header — Manage Fees style -->
    <header class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <div>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mt-1">📅 Exam Timetable</h1>
        <p class="text-gray-600 mt-2">Schedule and manage exam dates, subjects and portions for each class.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <!-- Class filter -->
        <form method="GET" action="/teacher/timetable" class="flex items-center gap-2">
          
          <select name="batchId" onchange="this.form.submit()" class="py-2 px-3 btn-outline-purple text-sm" style="width:auto;border-radius:0.5rem">
            <option value="" disabled selected>Select Batch</option>
            <% if (typeof batches !== 'undefined' && batches.length > 0) { %>
              <% batches.forEach(batch => { %>
                <option value="<%= batch._id %>" <%= typeof selectedBatch !== 'undefined' && selectedBatch == batch._id.toString() ? 'selected' : '' %>><%= batch.name %> (<%= batch.academicYear %>)</option>
              <% }) %>
            <% } %>
          </select>

        </form>
        <button onclick="openAddModal()" class="py-2 px-5 btn-solid-purple text-sm shadow">
          ➕ Add Exams
        </button>
      </div>
    </header>

    <!-- Toast Notifications -->
    <% if (success) { %>
    <div id="toast-success" class="mb-4 flex items-center gap-3 bg-green-50 border border-green-200 text-green-800 rounded-xl px-5 py-3 shadow-sm">
      <span>✅</span><span class="font-semibold text-sm"><%= success %></span>    </div>
    <% } %>
    <% if (error) { %>
    <div id="toast-error" class="mb-4 flex items-center gap-3 bg-red-50 border border-red-200 text-red-800 rounded-xl px-5 py-3 shadow-sm">
      <span>❌</span><span class="font-semibold text-sm"><%= error %></span>
    </div>
    <% } %>

    <!-- Exam Type Tabs -->
    <div class="glass-card p-4 rounded-xl border border-purple-100 shadow-sm mb-4 flex flex-wrap gap-2">
      <% ['All','Unit Test 1','Unit Test 2','Semester 1','Semester 2','Class Test'].forEach((t,i) => { %>
      <button onclick="filterExams('<%= t %>')" 
        class="tab-filter py-1.5 px-4 rounded-full text-sm font-semibold border transition-all <%= i===0 ? 'bg-purple-700 text-white border-purple-700' : 'glass-card text-brand-purple border-purple-200 hover:bg-purple-50' %>"
        data-type="<%= t %>"><%= t === 'All' ? '🗓 All' : t %></button>
      <% }) %>
    </div>
    <!-- Table Card -->
    <div class="glass-card p-6 rounded-xl shadow border border-purple-100 mb-8">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
        <h2 class="text-xl font-bold text-gray-800">Exam Schedule</h2>
        <div class="relative w-full sm:w-64">
          <input type="text" id="exam-search" placeholder="Search subject or batch..." class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-purple-300 focus:border-purple-400">
          <svg class="w-5 h-5 text-gray-400 absolute left-3 top-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
      </div>

      <% const standards = Object.keys(groupedEntriesByStandard).sort(); %>
      <% if (standards.length === 0) { %>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <div class="text-5xl mb-4">📋</div>
        <p class="text-lg font-bold text-gray-700 mb-2">No Exam Entries Yet</p>
        <p class="text-gray-400 text-sm">Click <strong>"+ Add Exams"</strong> to schedule.</p>
      </div>
      <% } else { %>
      <% standards.forEach(std => { %>
        <div class="mb-10 last:mb-0">
          <div class="flex items-center gap-3 mb-4 pl-1">
            <span class="text-xl">🏫</span>
            <h3 class="text-xl font-bold text-gray-800">Batch: <span class="text-brand-purple"><%= std %></span></h3>
            <div class="flex-grow h-px bg-gray-200 ml-4"></div>
          </div>
          <div class="overflow-x-auto rounded-xl shadow-sm border border-gray-200">
            <table class="data-table" id="timetable-table-<%= std.replace(/\s+/g, '-') %>">
              <thead>
                <tr>
                  <th>Subject</th>
                  <th>Exam Type</th>
                  <th>Date</th>
                  <th>Chapters / Portions</th>
                  <th>Added By</th>
                  <th class="text-center">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% groupedEntriesByStandard[std].forEach(group => {
                  const typeMap = { 'Unit Test 1':'badge-ut1','Unit Test 2':'badge-ut2','Semester 1':'badge-sem1','Semester 2':'badge-sem2','Class Test':'badge-ct' };
                  const badgeClass = typeMap[group.examType] || 'badge-ct';
                  const formattedDate = new Date(group.examDate).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'});
                  const inputDate = new Date(group.examDate).toISOString().split('T')[0];
                  const isPast = new Date(group.examDate) < new Date();
                %>
                <tr class="exam-row <%= isPast ? 'opacity-60' : '' %>" data-type="<%= group.examType %>">
                  <td class="font-bold text-gray-900 search-subject"><%= group.subject %></td>
                  <td><span class="badge <%= badgeClass %>"><%= group.examType %></span></td>
                  <td class="font-semibold <%= isPast ? 'text-gray-400' : 'text-brand-purple' %>">
                    <%= formattedDate %><% if (isPast) { %> <span class="text-xs text-gray-400">(Past)</span><% } %>
                  </td>
                  <td class="text-gray-600"><%= group.chapters %></td>
                  <td>
                    <span class="text-xs font-semibold <%= group.isTeacherAdded ? 'text-purple-700' : 'text-blue-700' %>">
                      <%= group.isTeacherAdded ? '👩‍🏫 Teacher' : '🎓 ' + group.studentNames.join(', ') %>
                    </span>
                    <% if (group.ids.length > 1) { %>
                    <div class="mt-1"><span class="text-[0.65rem] bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded-sm"><%= group.ids.length %> students grouped</span></div>
                    <% } %>
                  </td>
                  <td class="text-center">
                    <div class="flex items-center justify-center gap-2">
                      <button onclick="openEditModal(this)"
                        data-id="<%= group.ids.join(',') %>"
                        data-standard="<%= group.batchId %>"
                        data-examtype="<%= group.examType %>"
                        data-subject="<%= group.subject %>"
                        data-date="<%= inputDate %>"
                        data-chapters="<%= group.chapters %>"
                        class="py-1 px-3 text-xs font-bold rounded-md btn-outline-purple">✏️ Edit</button>
                      <form method="POST" action="/teacher/timetable/delete/<%= group.ids.join(',') %>" onsubmit="return confirm('Delete this exam layout?')">
                        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
                        <button type="submit" class="py-1 px-3 text-xs font-bold rounded-md bg-red-50 text-red-600 border border-red-200 hover:bg-red-600 hover:text-white transition-all">🗑️</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% }) %>
      <div id="no-results-msg" class="hidden p-6 text-center text-gray-500 bg-gray-50 border border-t-0 border-gray-200 rounded-b-xl italic">No entries found for this search.</div>
      <% } %>
    </div>
  </div>

  <!-- =================== ADD MODAL PREMIUM =================== -->
  <div class="modal-overlay" id="add-modal">
    <div class="modal-box">
      <!-- Gradient Header -->
      <div class="modal-header">
        <div class="flex justify-between items-start">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-2xl">📅</span>
              <h2 class="text-2xl font-extrabold tracking-tight">Schedule Exams</h2>
            </div>
            <p class="text-purple-200 text-sm">Add multiple subjects at once for any batch &amp; exam type</p>
          </div>
          <button onclick="closeModal('add-modal')" class="text-white/60 hover:text-white text-3xl font-light leading-none mt-1">&times;</button>
        </div>
      </div>
      <!-- Body -->
      <div class="modal-body">
        <form method="POST" action="/teacher/timetable/bulk" id="add-form-teacher" onsubmit="return validateTeacherForm()">
<input type="hidden" name="_csrf" value="<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>">
          <!-- Class field -->
          <div class="mb-5">
            <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-2">① Select Batch</p>
            <select name="standard" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-300 focus:border-purple-400 transition-all font-medium text-gray-800" required>
              <option value="" disabled selected>Select Batch...</option>
              <% if (typeof batches !== 'undefined' && batches.length > 0) { %>
                <% batches.forEach(batch => { %>
                  <option value="<%= batch._id %>"><%= batch.name %> (<%= batch.academicYear %>)</option>
                <% }) %>
              <% } %>
            </select>
          </div>
          <!-- Exam Type pills -->
          <div class="mb-6">
            <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3">② Exam Type</p>
            <div class="flex flex-wrap gap-2" id="etype-pills">
              <% [['Unit Test 1','🧪'],['Unit Test 2','🧫'],['Semester 1','📘'],['Semester 2','📗'],['Class Test','✍️']].forEach(([t,icon]) => { %>
              <button type="button" class="etype-pill" data-val="<%= t %>" onclick="selectEtype(this)"><%= icon %> <%= t %></button>
              <% }) %>
            </div>
            <input type="hidden" name="examType" id="hidden-examType" />
          </div>
          <!-- Subjects -->
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3">③ Subjects &amp; Dates</p>
            <div id="subject-rows" class="space-y-2.5"></div>
            <div class="add-row-btn mt-3" onclick="addSubjectRow()">＋ Add another subject</div>
          </div>
          <button type="submit" class="btn-glow mt-7">Save All Exams ✓</button>
        </form>
      </div>
    </div>
  </div>

  <!-- =================== EDIT MODAL =================== -->
  <div class="modal-overlay" id="edit-modal">
    <div class="modal-box p-6 sm:p-8">
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-xl font-extrabold text-brand-purple">✏️ Edit Exam Entry</h2>
        <button onclick="closeModal('edit-modal')" class="text-gray-400 hover:text-gray-700 text-2xl font-bold">&times;</button>
      </div>
      <form method="POST" id="edit-form" class="space-y-5">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-1">Batch</label>
          <select name="standard" id="edit-standard" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-300 focus:border-purple-400 transition-all font-medium text-gray-800" required>
            <option value="" disabled selected>Select Batch...</option>
            <% if (typeof batches !== 'undefined' && batches.length > 0) { %>
              <% batches.forEach(batch => { %>
                <option value="<%= batch._id %>"><%= batch.name %> (<%= batch.academicYear %>)</option>
              <% }) %>
            <% } %>
          </select>
        </div>

        <div>
          <label class="block text-sm font-bold text-gray-700 mb-1">Exam Type</label>
          <select name="examType" id="edit-examType" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-300 focus:border-purple-400 transition-all font-medium text-gray-800" required>
            <option value="" disabled selected>Select Exam Type...</option>
            <option value="Unit Test 1">Unit Test 1</option>
            <option value="Unit Test 2">Unit Test 2</option>
            <option value="Semester 1">Semester 1</option>
            <option value="Semester 2">Semester 2</option>
            <option value="Class Test">Class Test</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-bold text-gray-700 mb-1">Subject</label>
          <select name="subject" id="edit-subject" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-300 focus:border-purple-400 transition-all font-medium text-gray-800" required>
            <option value="" disabled selected>Select Subject...</option>
            <option value="English">English</option>
            <option value="Maths I">Maths I</option>
            <option value="Maths II">Maths II</option>
            <option value="Science I">Science I</option>
            <option value="Science II">Science II</option>
            <option value="History-Civics">History-Civics</option>
            <option value="Geography">Geography</option>
            <option value="Hindi">Hindi</option>
            <option value="Marathi">Marathi</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-bold text-gray-700 mb-1">Exam Date</label>
          <input type="date" name="examDate" id="edit-examDate" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-300 focus:border-purple-400 transition-all font-medium text-gray-800" required />
        </div>

        <div>
          <label class="block text-sm font-bold text-gray-700 mb-1">Chapters / Portions</label>
          <textarea id="edit-chapters" name="chapters" rows="2" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-300 focus:border-purple-400 transition-all font-medium text-gray-800" required></textarea>
        </div>

        <button type="submit" class="w-full py-3 mt-4 btn-solid-purple rounded-xl font-bold shadow-md hover:shadow-lg transition-all text-lg tracking-wide">Update Exam ✓</button>
      </form>
    </div>
  </div>

  <script>
    function openAddModal() {
      document.getElementById('subject-rows').innerHTML = '';
      document.querySelectorAll('.etype-pill').forEach(p => p.classList.remove('selected'));
      document.getElementById('hidden-examType').value = '';
      addSubjectRow();
      document.getElementById('add-modal').classList.add('open');
    }
    function selectEtype(pill) {
      document.querySelectorAll('.etype-pill').forEach(p => p.classList.remove('selected'));
      pill.classList.add('selected');
      document.getElementById('hidden-examType').value = pill.dataset.val;
    }
    function addSubjectRow() {
      const rows = document.getElementById('subject-rows');
      const num = rows.children.length + 1;
      const div = document.createElement('div');
      div.className = 'subject-row-premium';
      div.innerHTML = `
        <span class="row-num">${num}</span>
        <select name="subjects[]" required class="srow-input cursor-pointer bg-transparent">
          <option value="" disabled selected>Select Subject...</option>
          <option value="English">English</option>
          <option value="Maths I">Maths I</option>
          <option value="Maths II">Maths II</option>
          <option value="Science I">Science I</option>
          <option value="Science II">Science II</option>
          <option value="History-Civics">History-Civics</option>
          <option value="Geography">Geography</option>
          <option value="Hindi">Hindi</option>
          <option value="Marathi">Marathi</option>
        </select>
        <input name="dates[]" type="date" required class="srow-input" />
        <input name="chapters[]" type="text" placeholder="Ch. 1, 2…" class="srow-input" />
        <button type="button" onclick="removeRow(this)" class="text-red-300 hover:text-red-500 text-xl font-bold leading-none">&times;</button>`;
      rows.appendChild(div);
      renumberRows();
    }
    function removeRow(btn) { btn.closest('.subject-row-premium').remove(); renumberRows(); }
    function renumberRows() { document.querySelectorAll('#subject-rows .row-num').forEach((el,i) => el.textContent = i+1); }
    function validateTeacherForm() {
      if (!document.getElementById('hidden-examType').value) {
        alert("Please select an Exam Type (e.g. Unit Test 1) before saving.");
        return false;
      }
      return true;
    }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }
    function openEditModal(btn) {
      const form = document.getElementById('edit-form');
      form.action = '/teacher/timetable/edit/' + btn.dataset.id;
      document.getElementById('edit-standard').value = btn.dataset.standard;
      document.getElementById('edit-examType').value = btn.dataset.examtype;
      document.getElementById('edit-subject').value = btn.dataset.subject;
      document.getElementById('edit-examDate').value = btn.dataset.date;
      document.getElementById('edit-chapters').value = btn.dataset.chapters;
      document.getElementById('edit-modal').classList.add('open');
    }
    document.querySelectorAll('.modal-overlay').forEach(o => o.addEventListener('click', function(e){ if(e.target===this) closeModal(this.id); }));

    function filterExams(type) {
      document.querySelectorAll('.tab-filter').forEach(btn => {
        const isActive = btn.dataset.type === type;
        btn.className = 'tab-filter py-1.5 px-4 rounded-full text-sm font-semibold border transition-all ' +
          (isActive ? 'bg-purple-700 text-white border-purple-700' : 'glass-card text-brand-purple border-purple-200 hover:bg-purple-50');
      });
      document.querySelectorAll('.exam-row').forEach(row => {
        row.style.display = (type === 'All' || row.dataset.type === type) ? '' : 'none';
      });
    }

    // Search
    const searchInput = document.getElementById('exam-search');
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        const q = searchInput.value.toLowerCase();
        let any = false;
        document.querySelectorAll('.exam-row').forEach(row => {
          const subj = row.querySelector('.search-subject')?.textContent.toLowerCase() || '';
          const match = subj.includes(q);
          row.style.display = match ? '' : 'none';
          if (match) any = true;
        });
        const noRes = document.getElementById('no-results-msg');
        if (noRes) noRes.classList.toggle('hidden', any || !q);
      });
    }

    // Auto-dismiss toasts
    setTimeout(() => {
      ['toast-success','toast-error'].forEach(id => { const el=document.getElementById(id); if(el) el.style.display='none'; });
    }, 4000);
  </script>
      </main>
    </div>
  </div>
</body>

</html>
